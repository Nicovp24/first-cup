---
import { getCollection, type CollectionEntry } from 'astro:content';
import Header from '../components/Header.astro';
import SEO from '../components/SEO.astro';
import '../styles/global.css';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const sorted = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return sorted.map((post, i) => ({
    params: { slug: post.slug },
    props: {
      post,
      prev: sorted[i + 1] ?? null,
      next: sorted[i - 1] ?? null,
      editionNum: sorted.length - i,
    },
  }));
}

interface Props {
  post: CollectionEntry<'posts'>;
  prev: CollectionEntry<'posts'> | null;
  next: CollectionEntry<'posts'> | null;
  editionNum: number;
}

const { post, prev, next, editionNum } = Astro.props;
const { Content } = await post.render();
const { title, date, description, tags, source_urls, cover } = post.data;

const words = post.body.split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.round(words / 200));
const readCups = Math.min(5, Math.max(1, Math.round(readingTime / 2)));

const formattedDate = date.toLocaleDateString('es-ES', {
  year: 'numeric', month: 'long', day: 'numeric',
});
const isoDate = date.toISOString();
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://firstcup.dev';
const canonicalUrl = `${siteUrl}/${post.slug}`;
const ogImage = cover ?? `${siteUrl}/og-default.svg`;
const editionLabel = `#${String(editionNum).padStart(3, '0')}`;
---

<!doctype html>
<html lang="es" data-theme="latte">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title} – First Cup</title>
  <SEO
    title={`${title} – First Cup`}
    description={description}
    canonical={canonicalUrl}
    image={ogImage}
    type="article"
    publishedAt={date}
    tags={tags}
  />
</head>

<body>
  <Header edition={editionNum} />

  <main class="main">
    <div class="container">

      <a href="/" class="back-link gz-mono">
        ← Todos los posts
      </a>

      <article class="article-wrap">

        <!-- Article header -->
        <header class="article-header anim-up">
          <div class="article-rule-top" aria-hidden="true"></div>

          <div class="article-eyebrow">
            <span class="kicker">{tags[0] ?? 'Digest'}</span>
            <span class="eyebrow-sep gz-mono" aria-hidden="true">·</span>
            <span class="kicker edition-label">{editionLabel}</span>
          </div>

          <h1 class="article-title">{title}</h1>
          <p class="article-stand">{description}</p>

          <div class="article-byline">
            <div class="byline-left">
              <span class="byline gz-mono">
                <span class="byline-by">por </span>
                <span class="byline-name">First Cup AI</span>
              </span>
              <span class="byline-sep gz-mono" aria-hidden="true">·</span>
              <time class="byline gz-mono" datetime={isoDate}>{formattedDate}</time>
            </div>
            <div class="byline-right">
              <span class="read-time gz-mono">
                <span class="read-cups">{'☕'.repeat(readCups)}</span>
                {readingTime} min
              </span>
            </div>
          </div>

          {tags.length > 0 && (
            <div class="article-tags">
              {tags.map(t => <span class="tag">{t}</span>)}
            </div>
          )}
        </header>

        <!-- Cover image -->
        {cover && (
          <figure class="article-cover">
            <img src={cover} alt="" loading="eager" decoding="async" />
          </figure>
        )}

        <!-- Body -->
        <div class="prose article-content">
          <Content />
        </div>

        <!-- Sources -->
        {source_urls && source_urls.length > 0 && (
          <aside class="sources-section">
            <h2 class="sources-title gz-mono">Fuentes</h2>
            <ul class="sources-list">
              {source_urls.map((url, i) => {
                let domain = url;
                try { domain = new URL(url).hostname.replace('www.', ''); } catch {}
                return (
                  <li>
                    <a href={url} target="_blank" rel="noopener noreferrer" class="source-link">
                      <span class="source-num gz-mono">{i + 1}</span>
                      <span class="source-domain">{domain}</span>
                      <span class="source-url gz-mono">{url}</span>
                    </a>
                  </li>
                );
              })}
            </ul>
          </aside>
        )}

      </article>

      <!-- Prev / Next navigation -->
      <nav class="post-nav gz-mono" aria-label="Navegación de posts">
        {prev ? (
          <a href={`/${prev.slug}`} class="nav-post nav-prev">
            <span class="nav-dir">← Anterior</span>
            <span class="nav-ptitle">{prev.data.title}</span>
          </a>
        ) : <div />}
        {next ? (
          <a href={`/${next.slug}`} class="nav-post nav-next">
            <span class="nav-dir">Siguiente →</span>
            <span class="nav-ptitle">{next.data.title}</span>
          </a>
        ) : <div />}
      </nav>

      <!-- Subscribe CTA -->
      <div class="post-cta">
        <div class="cta-inner">
          <div class="cta-rule-top" aria-hidden="true"></div>
          <span class="kicker">¿Te ha gustado este análisis?</span>
          <h3 class="cta-h">El café llega cada mañana.</h3>
          <p class="cta-p">Suscríbete gratis y recibe el digest de IA y tech en tu inbox.</p>
          <a href="/subscribe" class="cta-btn gz-mono">Suscribirme gratis →</a>
        </div>
      </div>

    </div>
  </main>

  <footer class="site-footer" id="site-footer">
    <div class="container footer-inner">
      <a href="/" class="footer-brand gz-mono">
        <span class="footer-fc">FC</span>
        First Cup
      </a>
      <span class="footer-copy gz-mono">© {new Date().getFullYear()} · Hecho con Astro</span>
    </div>
  </footer>

  <!-- Back to top -->
  <button class="btt" id="btt" aria-label="Volver arriba" title="Volver arriba">
    <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
      <path d="M8 12V4M4 7l4-4 4 4"
        stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <!-- Focus mode -->
  <button class="focus-fab" id="focus-btn" aria-label="Modo lectura" title="Modo lectura">
    <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
      <path d="M1 5V2h3M12 2h3v3M1 11v3h3M12 14h3v-3"
        stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </button>
</body>
</html>

<script>
  // ── Init theme ──
  const saved = localStorage.getItem('theme') ?? 'latte';
  document.documentElement.setAttribute('data-theme', saved);

  // ── Scroll progress scoped to article ──
  const bar = document.getElementById('scroll-progress');
  const article = document.querySelector<HTMLElement>('.article-wrap');
  if (bar && article) {
    window.addEventListener('scroll', () => {
      const rect = article.getBoundingClientRect();
      const total = article.offsetHeight - window.innerHeight;
      const scrolled = Math.max(0, -rect.top);
      bar.style.width = total > 0 ? Math.min(100, (scrolled / total) * 100) + '%' : '0%';
    }, { passive: true });
  }

  // ── Back to top ──
  const btt = document.getElementById('btt');
  window.addEventListener('scroll', () => {
    btt?.classList.toggle('visible', window.scrollY > 400);
  }, { passive: true });
  btt?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

  // ── Focus mode ──
  const focusBtn = document.getElementById('focus-btn');
  const hdr = document.querySelector<HTMLElement>('.dateline');
  const masthead = document.querySelector<HTMLElement>('.masthead');
  const footer = document.getElementById('site-footer');
  focusBtn?.addEventListener('click', () => {
    const active = document.body.classList.toggle('focus-mode');
    if (hdr)      hdr.style.display      = active ? 'none' : '';
    if (masthead) masthead.style.display  = active ? 'none' : '';
    if (footer)   footer.style.display    = active ? 'none' : '';
    focusBtn.classList.toggle('is-active', active);
    focusBtn.title = active ? 'Salir del modo lectura' : 'Modo lectura';
  });
</script>

<style>
  .main { padding: 2rem 0 5rem; }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.7rem;
    color: var(--ink-soft);
    margin-bottom: 2rem;
    transition: color 0.15s;
    text-decoration: none;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .back-link:hover { color: var(--spot); text-decoration: none; }

  /* ── Article ── */
  .article-wrap {
    max-width: 740px;
    margin-bottom: 4rem;
  }

  /* ── Article header ── */
  .article-header {
    margin-bottom: 2rem;
    padding-bottom: 1.75rem;
    border-bottom: 1px solid var(--rule);
  }

  .article-rule-top {
    height: 3px;
    background: linear-gradient(90deg, var(--spot) 0%, transparent 55%);
    margin-bottom: 1.25rem;
  }

  .article-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .edition-label { color: var(--ink-faint); }
  .eyebrow-sep { color: var(--ink-faint); font-size: 0.7rem; }

  .article-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4.5vw, 2.8rem);
    font-weight: 800;
    color: var(--ink);
    line-height: 1.1;
    letter-spacing: -0.022em;
    margin-bottom: 1rem;
  }

  .article-stand {
    font-size: 1.1rem;
    color: var(--ink-soft);
    line-height: 1.65;
    font-style: italic;
    margin-bottom: 1.25rem;
    max-width: 60ch;
  }

  .article-byline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 0.6rem 0;
    border-top: 1px solid var(--rule-soft);
    border-bottom: 1px solid var(--rule-soft);
    margin-bottom: 1rem;
  }

  .byline-left {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    flex-wrap: wrap;
  }

  .byline-sep { color: var(--rule); font-size: 0.7rem; }
  .byline-by { color: var(--ink-faint); }
  .byline-name { font-weight: 700; color: var(--ink); }

  .read-time {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.68rem;
    color: var(--ink-faint);
  }

  .read-cups {
    letter-spacing: 1px;
    color: var(--spot);
    font-size: 0.65rem;
  }

  .article-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; }

  /* ── Cover image ── */
  .article-cover {
    margin-bottom: 2.5rem;
    border: 1px solid var(--rule);
    border-top: 2px solid var(--ink);
    overflow: hidden;
    position: relative;
  }
  .article-cover img {
    width: 100%; height: auto;
    display: block;
    max-height: 440px;
    object-fit: cover;
  }

  /* ── Content ── */
  .article-content { margin-bottom: 2.5rem; }

  /* ── Sources ── */
  .sources-section {
    background: var(--paper-sink);
    border: 1px solid var(--rule);
    border-left: 3px double var(--spot);
    padding: 1.25rem 1.5rem;
    margin-bottom: 2.5rem;
  }

  .sources-title {
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--ink-soft);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.9rem;
  }

  .sources-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .source-link {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    padding: 0.3rem 0;
  }
  .source-link:hover .source-domain { color: var(--spot); }

  .source-num {
    font-size: 0.6rem;
    color: var(--spot);
    background: oklch(from var(--spot) l c h / .1);
    border: 1px solid oklch(from var(--spot) l c h / .2);
    border-radius: 2px;
    padding: 0.04rem 0.28rem;
    flex-shrink: 0;
    min-width: 1.4rem;
    text-align: center;
  }

  .source-domain {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink);
    flex-shrink: 0;
    transition: color 0.15s;
  }

  .source-url {
    font-size: 0.68rem;
    color: var(--ink-faint);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* ── Post nav ── */
  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    max-width: 740px;
    margin-bottom: 3rem;
    border: 1px solid var(--ink);
    border-top: 3px double var(--ink);
  }

  .nav-post {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1rem 1.25rem;
    text-decoration: none;
    transition: background 0.2s;
    border-right: 1px solid var(--rule);
  }
  .nav-post:last-child { border-right: none; }
  .nav-post:hover { background: var(--paper-sink); text-decoration: none; }
  .nav-next { text-align: right; }

  .nav-dir {
    font-size: 0.62rem;
    color: var(--spot);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .nav-ptitle {
    font-family: var(--font-display);
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--ink-soft);
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Subscribe CTA ── */
  .post-cta { max-width: 740px; margin-bottom: 3rem; }

  .cta-inner {
    background: var(--paper-sink);
    border: 1px solid var(--ink);
    padding: 2.25rem;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .cta-rule-top {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--spot) 0%, transparent 55%);
  }

  .cta-h {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--ink);
    letter-spacing: -0.01em;
  }

  .cta-p {
    font-size: 0.9rem;
    color: var(--ink-soft);
    line-height: 1.65;
    font-style: italic;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--spot);
    color: var(--paper-2);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.65rem 1.35rem;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.18s, color 0.18s;
    width: fit-content;
    margin-top: 0.4rem;
    border-radius: 0;
  }
  .cta-btn:hover { background: var(--spot-deep); color: var(--paper-2); text-decoration: none; }

  /* ── Footer ── */
  .site-footer {
    border-top: 3px double var(--ink);
    padding: 1.25rem 0;
    background: var(--paper-sink);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--ink-soft);
    text-decoration: none;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.15s;
  }
  .footer-brand:hover { color: var(--ink); text-decoration: none; }

  .footer-fc {
    width: 26px; height: 20px;
    background: var(--ink);
    color: var(--paper);
    font-size: 0.58rem; font-weight: 700;
    border-radius: 2px;
    display: inline-flex; align-items: center; justify-content: center;
  }

  .footer-copy { font-size: 0.65rem; color: var(--ink-faint); letter-spacing: 0.06em; }

  /* ── Floating buttons ── */
  .btt, .focus-fab {
    position: fixed;
    width: 38px; height: 38px;
    border: 1px solid var(--rule);
    background: var(--paper-sink);
    color: var(--ink-soft);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s, border-color 0.2s, transform 0.25s var(--spring), opacity 0.2s;
    z-index: 200;
    border-radius: 2px;
  }
  .btt:hover, .focus-fab:hover {
    color: var(--spot);
    border-color: oklch(from var(--spot) l c h / .4);
    transform: scale(1.08);
  }

  .btt {
    bottom: 2rem; right: 1.5rem;
    opacity: 0; pointer-events: none;
    transform: translateY(8px);
  }
  .btt.visible { opacity: 1; pointer-events: auto; transform: translateY(0); }

  .focus-fab { bottom: 2rem; left: 1.5rem; }
  .focus-fab.is-active {
    color: var(--spot);
    border-color: oklch(from var(--spot) l c h / .5);
    background: oklch(from var(--spot) l c h / .08);
  }

  @media (max-width: 600px) {
    .post-nav { grid-template-columns: 1fr; }
    .nav-post { border-right: none; border-bottom: 1px solid var(--rule); }
    .nav-post:last-child { border-bottom: none; }
    .nav-next { text-align: left; }
    .cta-inner { padding: 1.5rem; }
  }
</style>
