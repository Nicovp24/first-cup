---
import { getCollection, type CollectionEntry } from 'astro:content';
import Header from '../components/Header.astro';
import SEO from '../components/SEO.astro';
import '../styles/global.css';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const sorted = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return sorted.map((post, i) => ({
    params: { slug: post.slug },
    props: {
      post,
      prev: sorted[i + 1] ?? null,
      next: sorted[i - 1] ?? null,
      editionNum: sorted.length - i,
    },
  }));
}

interface Props {
  post: CollectionEntry<'posts'>;
  prev: CollectionEntry<'posts'> | null;
  next: CollectionEntry<'posts'> | null;
  editionNum: number;
}

const { post, prev, next, editionNum } = Astro.props;
const { Content } = await post.render();
const { title, date, description, tags, source_urls, cover } = post.data;

const words = post.body.split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.round(words / 200));
const readCups = Math.min(5, Math.max(1, Math.round(readingTime / 2)));

const formattedDate = date.toLocaleDateString('es-ES', {
  year: 'numeric', month: 'long', day: 'numeric',
});
const isoDate = date.toISOString();
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://first-cup.es';
const canonicalUrl = `${siteUrl}/${post.slug}`;
const ogImage = cover ?? `${siteUrl}/og-default.svg`;
const editionLabel = `#${String(editionNum).padStart(3, '0')}`;
const twitterShare = `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(canonicalUrl)}`;
---

<!doctype html>
<html lang="es" data-theme="latte">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title} – First Cup</title>
  <SEO
    title={`${title} – First Cup`}
    description={description}
    canonical={canonicalUrl}
    image={ogImage}
    type="article"
    publishedAt={date}
    tags={tags}
  />
</head>

<body>
  <Header edition={editionNum} />

  <!-- Full-width hero cover -->
  {cover && (
    <div class="hero-cover">
      <img src={cover} alt="" loading="eager" decoding="async"
        onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1461749280684-dccba630e2f6?auto=format&fit=crop&w=900&q=80'" />
    </div>
  )}

  <main class="main">
    <div class="container">

      <a href="/" class="back-link gz-mono">← Todos los posts</a>

      <div class="layout">

        <!-- ── ARTICLE ── -->
        <article class="article-wrap" id="article">

          <header class="article-header anim-up">

            <!-- Eyebrow: tags + edition -->
            <div class="article-eyebrow">
              <div class="eyebrow-tags">
                {tags.slice(0,3).map(t => <span class="kicker eyebrow-tag">{t}</span>)}
              </div>
              <span class="edition-chip gz-mono">{editionLabel}</span>
            </div>

            <!-- Title -->
            <h1 class="article-title">{title}</h1>

            <!-- Stand / description -->
            <p class="article-stand">{description}</p>

            <!-- Byline row -->
            <div class="article-byline">
              <div class="byline-left">
                <span class="byline-author gz-mono">First Cup AI</span>
                <span class="byline-sep" aria-hidden="true">—</span>
                <time class="byline gz-mono" datetime={isoDate}>{formattedDate}</time>
                <span class="read-time gz-mono">
                  {'☕'.repeat(readCups)} {readingTime} min de lectura
                </span>
              </div>
              <div class="share-row">
                <button class="share-btn gz-mono" id="copy-btn" data-url={canonicalUrl} aria-label="Copiar enlace">
                  <svg width="11" height="11" viewBox="0 0 16 16" fill="none"><path d="M5 4H3a1 1 0 00-1 1v8a1 1 0 001 1h8a1 1 0 001-1v-2M9 1h6v6M9.5 6.5L15 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <span id="copy-label">Copiar enlace</span>
                </button>
                <a href={twitterShare} target="_blank" rel="noopener noreferrer" class="share-btn gz-mono" aria-label="Compartir en X">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.74l7.73-8.835L1.254 2.25H8.08l4.258 5.624 5.906-5.624Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                  Compartir en X
                </a>
              </div>
            </div>

          </header>

          <!-- Body -->
          <div class="prose article-content">
            <Content />
          </div>

          <!-- Sources -->
          {source_urls && source_urls.length > 0 && (
            <aside class="sources-section">
              <h2 class="sources-title gz-mono">Fuentes</h2>
              <ul class="sources-list">
                {source_urls.map((url, i) => {
                  let domain = url;
                  try { domain = new URL(url).hostname.replace('www.', ''); } catch {}
                  return (
                    <li>
                      <a href={url} target="_blank" rel="noopener noreferrer" class="source-link">
                        <span class="source-num gz-mono">{i + 1}</span>
                        <span class="source-domain">{domain}</span>
                        <span class="source-url gz-mono">{url}</span>
                      </a>
                    </li>
                  );
                })}
              </ul>
            </aside>
          )}

        </article>

        <!-- ── SIDEBAR ── -->
        <aside class="sidebar">
          <div class="sidebar-sticky">
            <div class="sidebar-section">
              <h3 class="sidebar-head gz-mono">Edición</h3>
              <p class="sidebar-edition gz-mono">{editionLabel}</p>
            </div>
            <div class="sidebar-section">
              <h3 class="sidebar-head gz-mono">Tags</h3>
              <div class="sidebar-tags">
                {tags.map(t => <a href={`/?tag=${encodeURIComponent(t)}`} class="tag sidebar-tag">{t}</a>)}
              </div>
            </div>
            {source_urls && source_urls.length > 0 && (
              <div class="sidebar-section">
                <h3 class="sidebar-head gz-mono">Fuentes</h3>
                <ul class="sidebar-sources">
                  {source_urls.slice(0,4).map((url) => {
                    let domain = url;
                    try { domain = new URL(url).hostname.replace('www.', ''); } catch {}
                    return <li><a href={url} target="_blank" rel="noopener noreferrer">{domain}</a></li>;
                  })}
                </ul>
              </div>
            )}
            <div class="sidebar-section sidebar-cta-mini">
              <p class="sidebar-cta-text gz-mono">El café llega cada mañana.</p>
              <a href="/subscribe" class="sidebar-cta-btn gz-mono">Suscribirme →</a>
            </div>
          </div>
        </aside>

      </div>

      <!-- Prev / Next navigation -->
      <nav class="post-nav gz-mono" aria-label="Navegación de posts">
        {prev ? (
          <a href={`/${prev.slug}`} class="nav-post nav-prev">
            <span class="nav-dir">← Anterior</span>
            <span class="nav-ptitle">{prev.data.title}</span>
          </a>
        ) : <div />}
        {next ? (
          <a href={`/${next.slug}`} class="nav-post nav-next">
            <span class="nav-dir">Siguiente →</span>
            <span class="nav-ptitle">{next.data.title}</span>
          </a>
        ) : <div />}
      </nav>

    </div>
  </main>

  <!-- Subscribe coupon -->
  <section class="nl-section">
    <div class="container">
      <div class="coupon">
        <span class="coupon-scissors" aria-hidden="true">✂</span>
        <div class="coupon-inner">
          <span class="coupon-kicker gz-mono">Suscríbete · Gratis</span>
          <h2 class="coupon-title">Tu café tech, servido a las 07:00</h2>
          <p class="coupon-sub">Cada mañana, un agente lee internet por ti y te deja solo lo que importa en el inbox.</p>
          <form class="coupon-form" id="coupon-form" novalidate>
            <label for="coupon-email" class="sr-only">Tu email</label>
            <input id="coupon-email" type="email" name="email" placeholder="tu@email.com" autocomplete="email" required class="coupon-input gz-mono" />
            <button type="submit" class="coupon-btn gz-mono">
              <span class="coupon-btn-text">Suscribirme ▸</span>
              <span class="coupon-btn-loading" hidden>Enviando…</span>
            </button>
          </form>
          <p class="coupon-error gz-mono" id="coupon-error" role="alert" hidden></p>
          <div class="coupon-done gz-mono" id="coupon-done" hidden>✓ Suscrito — revisa tu inbox.</div>
          <div class="coupon-fine gz-mono">
            <span>+ Sin spam</span>
            <span>+ Cancela cuando quieras</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Wire ticker -->
  <div class="wire" aria-hidden="true">
    <span class="wire-tag gz-mono">FUENTES</span>
    <div class="wire-mask">
      <div class="wire-track">
        {['GitHub Trending', 'Hacker News', 'ArXiv Papers', 'Reddit r/ML', 'Dev.to', 'Product Hunt', 'GitHub API', 'RSS Feeds',
          'GitHub Trending', 'Hacker News', 'ArXiv Papers', 'Reddit r/ML', 'Dev.to', 'Product Hunt', 'GitHub API', 'RSS Feeds',
          'GitHub Trending', 'Hacker News', 'ArXiv Papers', 'Reddit r/ML', 'Dev.to', 'Product Hunt', 'GitHub API', 'RSS Feeds'].map(item => (
          <>
            <span class="wire-item gz-mono">{item}</span>
            <span class="wire-sep" aria-hidden="true">◆</span>
          </>
        ))}
      </div>
    </div>
  </div>

  <!-- Full newspaper footer -->
  <footer class="site-footer" id="site-footer">
    <div class="container">
      <div class="foot-top">
        <div class="foot-brand-col">
          <a href="/" class="foot-logo gz-mono">
            <span class="footer-fc">FC</span>
            First Cup
          </a>
          <p class="foot-tag">El diario del café tech. IA, desarrollo y tecnología curada cada mañana por un agente.</p>
        </div>
        <div class="foot-cols">
          <div class="foot-col">
            <h4 class="gz-mono">Contenido</h4>
            <a href="/">Posts</a>
            <a href="/subscribe">Newsletter</a>
            <a href="/rss.xml">RSS</a>
          </div>
          <div class="foot-col">
            <h4 class="gz-mono">Legal</h4>
            <a href="/privacidad">Privacidad</a>
            <a href="/terminos">Términos</a>
          </div>
          <div class="foot-col">
            <h4 class="gz-mono">Contacto</h4>
            <a href="mailto:hola@first-cup.es">hola@first-cup.es</a>
          </div>
        </div>
      </div>
      <div class="foot-base gz-mono">
        <span>© {new Date().getFullYear()} First Cup</span>
        <span>Hecho con Astro · IA generativa</span>
      </div>
    </div>
  </footer>

  <!-- Back to top -->
  <button class="btt" id="btt" aria-label="Volver arriba">
    <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
      <path d="M8 12V4M4 7l4-4 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <!-- Focus mode -->
  <button class="focus-fab" id="focus-btn" aria-label="Modo lectura" title="Modo lectura">
    <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
      <path d="M1 5V2h3M12 2h3v3M1 11v3h3M12 14h3v-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </button>
</body>
</html>

<script>
  // ── Init theme ──
  const saved = localStorage.getItem('theme') ?? 'latte';
  document.documentElement.setAttribute('data-theme', saved);

  // ── Back to top ──
  const btt = document.getElementById('btt');
  window.addEventListener('scroll', () => {
    btt?.classList.toggle('visible', window.scrollY > 500);
  }, { passive: true });
  btt?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

  // ── Focus mode ──
  const focusBtn = document.getElementById('focus-btn');
  const hdr = document.querySelector<HTMLElement>('.dateline');
  const masthead = document.querySelector<HTMLElement>('.masthead');
  const footer = document.getElementById('site-footer');
  focusBtn?.addEventListener('click', () => {
    const active = document.body.classList.toggle('focus-mode');
    if (hdr)      hdr.style.display      = active ? 'none' : '';
    if (masthead) masthead.style.display  = active ? 'none' : '';
    if (footer)   footer.style.display    = active ? 'none' : '';
    focusBtn.classList.toggle('is-active', active);
    focusBtn.title = active ? 'Salir del modo lectura' : 'Modo lectura';
  });

  // ── Copy link ──
  const copyBtn = document.getElementById('copy-btn');
  const copyLabel = document.getElementById('copy-label');
  copyBtn?.addEventListener('click', async () => {
    const url = copyBtn.getAttribute('data-url') ?? location.href;
    try {
      await navigator.clipboard.writeText(url);
      if (copyLabel) { copyLabel.textContent = '✓'; setTimeout(() => { copyLabel.textContent = 'Copiar'; }, 1800); }
    } catch {}
  });

  // ── Subscribe coupon form ──
  const couponForm = document.getElementById('coupon-form') as HTMLFormElement | null;
  if (couponForm) {
    couponForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input   = couponForm.querySelector<HTMLInputElement>('#coupon-email');
      const btnText = couponForm.querySelector<HTMLElement>('.coupon-btn-text');
      const btnLoad = couponForm.querySelector<HTMLElement>('.coupon-btn-loading');
      const btn     = couponForm.querySelector<HTMLButtonElement>('.coupon-btn');
      const errEl   = document.getElementById('coupon-error') as HTMLElement | null;
      const doneEl  = document.getElementById('coupon-done') as HTMLElement | null;
      if (!input || !errEl || !doneEl) return;
      const email = input.value.trim();
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        errEl.textContent = 'Introduce un email válido.';
        errEl.hidden = false;
        return;
      }
      errEl.hidden = true;
      if (btnText) btnText.hidden = true;
      if (btnLoad) btnLoad.hidden = false;
      if (btn) btn.disabled = true;
      try {
        const res = await fetch('/api/subscribe', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email }) });
        if (!res.ok) { const d = await res.json().catch(() => ({})); throw new Error((d as any).message || `Error ${res.status}`); }
        couponForm.hidden = true;
        doneEl.hidden = false;
      } catch (err: unknown) {
        errEl.textContent = err instanceof Error ? err.message : 'Algo salió mal.';
        errEl.hidden = false;
        if (btnText) btnText.hidden = false;
        if (btnLoad) btnLoad.hidden = true;
        if (btn) btn.disabled = false;
      }
    });
  }
</script>

<script define:vars={{ postSlug: post.slug }}>
  fetch('/api/view', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ slug: postSlug }),
  }).catch(() => {});
</script>

<style>
  .sr-only { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; }

  .main { padding: 2rem 0 0; }

  /* ── Hero cover ── */
  .hero-cover {
    width: 100%;
    height: clamp(220px, 38vw, 420px);
    overflow: hidden;
    border-top: 3px solid var(--ink);
    border-bottom: 1px solid var(--rule);
    margin-bottom: 0;
    background: var(--paper-sink);
  }
  .hero-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
    display: block;
  }

  /* ── Back link ── */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.68rem;
    color: var(--ink-soft);
    margin-bottom: 2rem;
    transition: color 0.15s;
    text-decoration: none;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .back-link:hover { color: var(--spot); text-decoration: none; }

  /* ── Layout: article + sidebar ── */
  .layout {
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: 3.5rem;
    align-items: start;
    margin-bottom: 3rem;
  }

  /* ── Article ── */
  .article-wrap { min-width: 0; }

  .article-header {
    margin-bottom: 2.5rem;
    padding-bottom: 0;
    border-top: 4px solid var(--ink);
    padding-top: 1.5rem;
  }

  .article-eyebrow {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .eyebrow-tags {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .eyebrow-tag { font-size: 0.62rem; }
  .edition-chip {
    font-size: 0.6rem;
    color: var(--ink-faint);
    letter-spacing: 0.1em;
    border: 1px solid var(--rule);
    padding: 0.1rem 0.45rem;
    white-space: nowrap;
  }

  .article-title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(2rem, 4.5vw, 3.4rem);
    font-weight: 800;
    color: var(--ink);
    line-height: 1.06;
    letter-spacing: -0.025em;
    margin-bottom: 1.25rem;
  }

  .article-stand {
    font-size: 1.1rem;
    color: var(--ink-soft);
    line-height: 1.65;
    font-style: italic;
    margin-bottom: 1.5rem;
    max-width: 62ch;
    padding-left: 1rem;
    border-left: 3px solid var(--spot);
  }

  .article-byline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 0.75rem 0;
    border-top: 3px double var(--ink);
    border-bottom: 1px solid var(--rule);
    margin-bottom: 2rem;
  }

  .byline-left {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    flex-wrap: wrap;
  }

  .byline-author {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: 0.04em;
  }

  .byline-sep { color: var(--rule); font-size: 0.8rem; }

  .read-time {
    font-size: 0.66rem;
    color: var(--ink-faint);
    letter-spacing: 0.04em;
  }

  /* ── Share ── */
  .share-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .share-label {
    font-size: 0.58rem;
    color: var(--ink-faint);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-right: 0.2rem;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.62rem;
    color: var(--ink-soft);
    background: none;
    border: 1px solid var(--rule);
    padding: 0.22rem 0.55rem;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
    text-decoration: none;
    letter-spacing: 0.05em;
    border-radius: 2px;
  }
  .share-btn:hover { color: var(--spot); border-color: oklch(from var(--spot) l c h / .4); text-decoration: none; }

  /* ── Prose content ── */
  .article-content {
    margin-bottom: 3rem;
    max-width: 68ch;
  }

  /* ── Sources ── */
  .sources-section {
    background: var(--paper-sink);
    border: 1px solid var(--rule);
    border-left: 3px solid var(--spot);
    padding: 1.25rem 1.5rem;
    margin-bottom: 2.5rem;
  }

  .sources-title {
    font-size: 0.62rem;
    font-weight: 700;
    color: var(--ink-soft);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.9rem;
  }

  .sources-list { list-style: none; display: flex; flex-direction: column; gap: 0.35rem; }

  .source-link {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    padding: 0.25rem 0;
  }
  .source-link:hover .source-domain { color: var(--spot); }

  .source-num {
    font-size: 0.6rem;
    color: var(--spot);
    background: oklch(from var(--spot) l c h / .1);
    border: 1px solid oklch(from var(--spot) l c h / .2);
    border-radius: 2px;
    padding: 0.04rem 0.28rem;
    flex-shrink: 0;
    min-width: 1.4rem;
    text-align: center;
  }
  .source-domain {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink);
    flex-shrink: 0;
    transition: color 0.15s;
  }
  .source-url {
    font-size: 0.65rem;
    color: var(--ink-faint);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* ── Sidebar ── */
  .sidebar { min-width: 0; }

  .sidebar-sticky {
    position: sticky;
    top: 5rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--rule);
    border-top: 3px double var(--ink);
  }

  .sidebar-section {
    padding: 1.1rem 1.25rem;
    border-bottom: 1px solid var(--rule-soft);
  }
  .sidebar-section:last-child { border-bottom: none; }

  .sidebar-head {
    font-size: 0.58rem;
    font-weight: 700;
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin-bottom: 0.6rem;
  }

  .sidebar-edition {
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--spot);
    letter-spacing: -0.02em;
  }

  .sidebar-tags { display: flex; flex-wrap: wrap; gap: 0.3rem; }
  .sidebar-tag { font-size: 0.58rem; }

  .sidebar-sources {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .sidebar-sources a {
    font-size: 0.8rem;
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 0.15s;
  }
  .sidebar-sources a:hover { color: var(--spot); }

  .sidebar-cta-mini { background: oklch(from var(--spot) l c h / .05); }

  .sidebar-cta-text {
    font-size: 0.7rem;
    color: var(--ink-soft);
    letter-spacing: 0.04em;
    margin-bottom: 0.65rem;
    line-height: 1.5;
  }

