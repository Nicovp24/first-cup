---
export const prerender = false;

const ADMIN_SECRET  = import.meta.env.ADMIN_SECRET;
const SUPABASE_URL  = import.meta.env.SUPABASE_URL;
const SUPABASE_KEY  = import.meta.env.SUPABASE_SERVICE_KEY;

// ── Auth ──────────────────────────────────────────────────────────────────
const cookieToken = Astro.cookies.get('fc_admin')?.value;
const isAuth      = ADMIN_SECRET && cookieToken === ADMIN_SECRET;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const pwd  = form.get('password')?.toString() ?? '';
  if (pwd === ADMIN_SECRET) {
    Astro.cookies.set('fc_admin', ADMIN_SECRET, {
      httpOnly: true, secure: true, path: '/',
      maxAge: 60 * 60 * 24 * 7,
    });
    return Astro.redirect('/admin');
  }
}

// ── Data fetching ─────────────────────────────────────────────────────────
type Sub  = { id: string; email: string; tier: string; confirmed: boolean; created_at: string };
type Post = { id: string; title: string; slug: string; tags: string[]; published_at: string };

let subs: Sub[]   = [];
let posts: Post[] = [];
let scrapedTotal  = 0;
let fetchErr      = '';

if (isAuth && SUPABASE_URL && SUPABASE_KEY) {
  const H = { apikey: SUPABASE_KEY, Authorization: `Bearer ${SUPABASE_KEY}` };

  const weekAgo = new Date(Date.now() - 7 * 864e5).toISOString();

  try {
    const [subsRes, postsRes, scrapedRes] = await Promise.all([
      fetch(`${SUPABASE_URL}/rest/v1/subscribers?select=id,email,tier,confirmed,created_at&order=created_at.desc`, { headers: H }),
      fetch(`${SUPABASE_URL}/rest/v1/posts?select=id,title,slug,tags,published_at&order=published_at.desc&limit=50`, { headers: H }),
      fetch(`${SUPABASE_URL}/rest/v1/scraped_items?select=id`, { headers: { ...H, 'Prefer': 'count=exact', Range: '0-0' } }),
    ]);
    subs         = await subsRes.json().catch(() => []);
    posts        = await postsRes.json().catch(() => []);
    const cRange = scrapedRes.headers.get('Content-Range') ?? '';
    scrapedTotal = parseInt(cRange.split('/')[1] ?? '0', 10) || 0;
  } catch (e) {
    fetchErr = String(e);
  }
}

// ── Computed stats ────────────────────────────────────────────────────────
const total     = subs.length;
const premium   = subs.filter(s => s.tier === 'premium').length;
const confirmed = subs.filter(s => s.confirmed).length;
const weekAgoD  = new Date(Date.now() - 7 * 864e5);
const newThisWk = subs.filter(s => new Date(s.created_at) > weekAgoD).length;
const postsWk   = posts.filter(p => new Date(p.published_at) > weekAgoD).length;

function maskEmail(email: string) {
  const [user, domain] = email.split('@');
  return `${user.slice(0, 2)}***@${domain}`;
}
function fmtDate(iso: string) {
  return new Date(iso).toLocaleString('es-ES', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' });
}
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="robots" content="noindex,nofollow"/>
  <title>Admin — First Cup</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink:   #1a0f06;
      --paper: #f5f0e8;
      --muted: #9a8572;
      --spot:  #8b4513;
      --card:  #fff;
      --border:#c5a882;
      --green: #2d6a4f;
      --red:   #c0392b;
      --mono:  'JetBrains Mono', 'Courier New', monospace;
    }

    body { background: var(--paper); color: var(--ink); font-family: Georgia, serif; min-height: 100vh; }

    /* ── Login ── */
    .login-wrap {
      display: flex; align-items: center; justify-content: center; min-height: 100vh;
    }
    .login-box {
      background: var(--card); border: 1px solid var(--border); padding: 2.5rem;
      width: 100%; max-width: 360px; text-align: center;
    }
    .login-title { font-size: 1.6rem; font-weight: 900; letter-spacing: -0.02em; margin-bottom: 0.25rem; }
    .login-sub { font-family: var(--mono); font-size: 0.6rem; color: var(--muted); letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 2rem; }
    .login-box input {
      width: 100%; padding: 0.65rem 0.85rem; border: 1px solid var(--border);
      background: var(--paper); font-size: 0.9rem; margin-bottom: 1rem; outline: none;
    }
    .login-box input:focus { border-color: var(--ink); }
    .login-btn {
      width: 100%; padding: 0.7rem; background: var(--ink); color: var(--paper);
      border: none; font-family: var(--mono); font-size: 0.7rem; letter-spacing: 0.14em;
      text-transform: uppercase; cursor: pointer;
    }
    .login-btn:hover { background: var(--spot); }

    /* ── Dashboard ── */
    .dash { max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem; }

    .dash-header {
      border-top: 3px solid var(--ink); border-bottom: 1px solid var(--border);
      padding: 1rem 0; margin-bottom: 2rem;
      display: flex; align-items: baseline; justify-content: space-between; gap: 1rem;
    }
    .dash-title { font-size: 2rem; font-weight: 900; letter-spacing: -0.02em; }
    .dash-meta { font-family: var(--mono); font-size: 0.6rem; color: var(--muted); letter-spacing: 0.12em; text-transform: uppercase; }

    /* Stats grid */
    .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
    .stat-card {
      background: var(--card); border: 1px solid var(--border); padding: 1.2rem 1rem;
    }
    .stat-label { font-family: var(--mono); font-size: 0.55rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.4rem; }
    .stat-value { font-size: 2.2rem; font-weight: 900; line-height: 1; color: var(--ink); }
    .stat-value.green { color: var(--green); }
    .stat-value.spot  { color: var(--spot); }
    .stat-sub { font-family: var(--mono); font-size: 0.58rem; color: var(--muted); margin-top: 0.3rem; }

    /* Tables */
    .section { margin-bottom: 2.5rem; }
    .section-title {
      font-family: var(--mono); font-size: 0.6rem; letter-spacing: 0.18em; text-transform: uppercase;
      color: var(--ink); border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; margin-bottom: 1rem;
    }
    table { width: 100%; border-collapse: collapse; background: var(--card); }
    th {
      font-family: var(--mono); font-size: 0.55rem; letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--muted); text-align: left; padding: 0.6rem 0.75rem; border-bottom: 1px solid var(--border);
      background: var(--paper);
    }
    td { padding: 0.6rem 0.75rem; font-size: 0.82rem; border-bottom: 1px solid #ede8df; vertical-align: middle; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #faf7f2; }

    .badge {
      display: inline-block; font-family: var(--mono); font-size: 0.52rem; letter-spacing: 0.1em;
      text-transform: uppercase; padding: 0.2rem 0.5rem; border-radius: 2px;
    }
    .badge-premium { background: #fef3c7; color: #92400e; }
    .badge-free    { background: #f0fdf4; color: #166534; }
    .badge-no      { background: #fef2f2; color: #991b1b; }
    .badge-yes     { background: #f0fdf4; color: #166534; }

    .post-title { font-weight: 700; color: var(--ink); text-decoration: none; }
    .post-title:hover { color: var(--spot); }
    .tag { display: inline-block; font-family: var(--mono); font-size: 0.5rem; letter-spacing: 0.08em; padding: 0.15rem 0.4rem; background: var(--paper); border: 1px solid var(--border); margin-right: 0.25rem; text-transform: uppercase; }

    /* Links */
    .links { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 2rem; }
    .ext-link {
      font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.12em; text-transform: uppercase;
      padding: 0.55rem 1rem; border: 1px solid var(--border); color: var(--ink); text-decoration: none;
      background: var(--card);
    }
    .ext-link:hover { background: var(--ink); color: var(--paper); }

    .err { color: var(--red); font-family: var(--mono); font-size: 0.75rem; padding: 1rem; background: #fef2f2; border: 1px solid #fca5a5; margin-bottom: 1rem; }

    @media (max-width: 600px) {
      .dash-header { flex-direction: column; }
      .stats { grid-template-columns: 1fr 1fr; }
      table { font-size: 0.75rem; }
      td, th { padding: 0.5rem; }
    }
  </style>
</head>
<body>

{!isAuth ? (
  <div class="login-wrap">
    <div class="login-box">
      <p class="login-sub">Panel de control</p>
      <h1 class="login-title">First Cup</h1>
      <form method="POST">
        <input type="password" name="password" placeholder="Contraseña" autofocus autocomplete="current-password"/>
        <button type="submit" class="login-btn">Entrar →</button>
      </form>
    </div>
  </div>
) : (
  <div class="dash">

    <div class="dash-header">
      <h1 class="dash-title">First Cup Admin</h1>
      <span class="dash-meta">{new Date().toLocaleString('es-ES', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' })}</span>
    </div>

    {fetchErr && <div class="err">Error cargando datos: {fetchErr}</div>}

    <!-- Stats -->
    <div class="stats">
      <div class="stat-card">
        <div class="stat-label">Suscriptores totales</div>
        <div class="stat-value">{total}</div>
        <div class="stat-sub">+{newThisWk} esta semana</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Premium</div>
        <div class="stat-value spot">{premium}</div>
        <div class="stat-sub">{total > 0 ? Math.round(premium / total * 100) : 0}% del total</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Confirmados</div>
        <div class="stat-value green">{confirmed}</div>
        <div class="stat-sub">{total - confirmed} pendientes</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Posts publicados</div>
        <div class="stat-value">{posts.length}</div>
        <div class="stat-sub">{postsWk} esta semana</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">URLs scrapeadas</div>
        <div class="stat-value">{scrapedTotal}</div>
        <div class="stat-sub">En base de datos</div>
      </div>
    </div>

    <!-- Quick links -->
    <div class="links">
      <a class="ext-link" href="https://github.com/Nicovp24/first-cup/actions" target="_blank">GitHub Actions ↗</a>
      <a class="ext-link" href="https://supabase.com/dashboard" target="_blank">Supabase ↗</a>
      <a class="ext-link" href="https://dashboard.stripe.com" target="_blank">Stripe ↗</a>
      <a class="ext-link" href="https://resend.com/emails" target="_blank">Resend ↗</a>
      <a class="ext-link" href="https://search.google.com/search-console" target="_blank">Search Console ↗</a>
    </div>

    <!-- Recent posts -->
    <div class="section">
      <div class="section-title">Últimos posts publicados ({posts.length})</div>
      <table>
        <thead>
          <tr>
            <th>Título</th>
            <th>Tags</th>
            <th>Publicado</th>
          </tr>
        </thead>
        <tbody>
          {posts.slice(0, 20).map(p => (
            <tr>
              <td><a class="post-title" href={`/${p.slug}`} target="_blank">{p.title}</a></td>
              <td>{(p.tags ?? []).slice(0, 3).map(t => <span class="tag">{t}</span>)}</td>
              <td style="font-family:var(--mono);font-size:0.7rem;color:var(--muted);white-space:nowrap">{fmtDate(p.published_at)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Subscribers -->
    <div class="section">
      <div class="section-title">Suscriptores ({total})</div>
      <table>
        <thead>
          <tr>
            <th>Email</th>
            <th>Plan</th>
            <th>Confirmado</th>
            <th>Registro</th>
          </tr>
        </thead>
        <tbody>
          {subs.slice(0, 30).map(s => (
            <tr>
              <td style="font-family:var(--mono);font-size:0.75rem">{maskEmail(s.email)}</td>
              <td>
                <span class={`badge ${s.tier === 'premium' ? 'badge-premium' : 'badge-free'}`}>
                  {s.tier}
                </span>
              </td>
              <td>
                <span class={`badge ${s.confirmed ? 'badge-yes' : 'badge-no'}`}>
                  {s.confirmed ? 'sí' : 'no'}
                </span>
              </td>
              <td style="font-family:var(--mono);font-size:0.7rem;color:var(--muted);white-space:nowrap">{fmtDate(s.created_at)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

  </div>
)}

</body>
</html>
