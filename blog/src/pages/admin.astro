---
export const prerender = false;

const ADMIN_SECRET = import.meta.env.ADMIN_SECRET  as string | undefined;
const SUPABASE_URL = import.meta.env.SUPABASE_URL  as string | undefined;
const SUPABASE_KEY = import.meta.env.SUPABASE_SERVICE_KEY as string | undefined;

// ── Login POST ────────────────────────────────────────────────────────────
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const pwd  = form.get('password')?.toString() ?? '';
  if (ADMIN_SECRET && pwd === ADMIN_SECRET) {
    Astro.cookies.set('fc_admin', ADMIN_SECRET, {
      httpOnly: true, secure: true, path: '/', maxAge: 86400 * 7, sameSite: 'lax',
    });
  }
  return Astro.redirect('/admin');
}

// ── Auth check ────────────────────────────────────────────────────────────
const token  = Astro.cookies.get('fc_admin')?.value ?? '';
const isAuth = Boolean(ADMIN_SECRET) && token === ADMIN_SECRET;

// ── Fetch data ────────────────────────────────────────────────────────────
interface Sub  { email: string; tier: string; confirmed: boolean; created_at: string }
interface Post { title: string; slug: string; tags: string[]; published_at: string }

let subs:  Sub[]  = [];
let posts: Post[] = [];
let err           = '';

if (isAuth && SUPABASE_URL && SUPABASE_KEY) {
  const H = { apikey: SUPABASE_KEY, Authorization: `Bearer ${SUPABASE_KEY}` };
  try {
    const [r1, r2] = await Promise.all([
      fetch(`${SUPABASE_URL}/rest/v1/subscribers?select=email,tier,confirmed,created_at&order=created_at.desc`, { headers: H }),
      fetch(`${SUPABASE_URL}/rest/v1/posts?select=title,slug,tags,published_at&order=published_at.desc&limit=50`, { headers: H }),
    ]);
    const d1 = await r1.json().catch(() => []);
    const d2 = await r2.json().catch(() => []);
    if (Array.isArray(d1)) subs  = d1;
    if (Array.isArray(d2)) posts = d2;
    if (!Array.isArray(d1)) err = `Supabase subscribers error: ${JSON.stringify(d1)}`;
  } catch (e) {
    err = String(e);
  }
}

// ── Stats ─────────────────────────────────────────────────────────────────
const total     = subs.length;
const premium   = subs.filter(s => s.tier === 'premium').length;
const confirmed = subs.filter(s => s.confirmed).length;
const cutoff    = new Date(Date.now() - 7 * 86400000);
const newWk     = subs.filter(s => new Date(s.created_at) > cutoff).length;
const postsWk   = posts.filter(p => new Date(p.published_at) > cutoff).length;

const fmt = (iso: string) =>
  new Date(iso).toLocaleString('es-ES', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' });

const mask = (email: string) => {
  const at = email.indexOf('@');
  return at < 2 ? email : email.slice(0, 2) + '***' + email.slice(at);
};
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <meta name="robots" content="noindex,nofollow"/>
  <title>Admin — First Cup</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml"/>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    :root{
      --ink:#1a0f06;--paper:#f5f0e8;--muted:#9a8572;--spot:#8b4513;
      --card:#fff;--border:#c5a882;--green:#2d6a4f;--red:#c0392b;
      --mono:'JetBrains Mono','Courier New',monospace;
    }
    body{background:var(--paper);color:var(--ink);font-family:Georgia,serif;min-height:100vh}

    /* Login */
    .login{display:flex;align-items:center;justify-content:center;min-height:100vh}
    .login-box{background:var(--card);border:1px solid var(--border);padding:2.5rem;width:100%;max-width:340px;text-align:center}
    .login-box h1{font-size:1.8rem;font-weight:900;letter-spacing:-.02em;margin-bottom:.25rem}
    .login-box p{font-family:var(--mono);font-size:.6rem;color:var(--muted);letter-spacing:.15em;text-transform:uppercase;margin-bottom:2rem}
    .login-box input{width:100%;padding:.65rem .85rem;border:1px solid var(--border);background:var(--paper);font-size:.9rem;margin-bottom:1rem;outline:none;font-family:inherit}
    .login-box input:focus{border-color:var(--ink)}
    .login-box button{width:100%;padding:.7rem;background:var(--ink);color:var(--paper);border:none;font-family:var(--mono);font-size:.7rem;letter-spacing:.14em;text-transform:uppercase;cursor:pointer}
    .login-box button:hover{background:var(--spot)}

    /* Dashboard */
    .dash{max-width:1100px;margin:0 auto;padding:2rem 1.5rem}
    .dh{border-top:3px solid var(--ink);border-bottom:1px solid var(--border);padding:1rem 0;margin-bottom:2rem;display:flex;align-items:baseline;justify-content:space-between;gap:1rem;flex-wrap:wrap}
    .dh h1{font-size:2rem;font-weight:900;letter-spacing:-.02em}
    .dh span{font-family:var(--mono);font-size:.6rem;color:var(--muted);letter-spacing:.12em;text-transform:uppercase}

    .stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:1rem;margin-bottom:2rem}
    .card{background:var(--card);border:1px solid var(--border);padding:1.2rem 1rem}
    .card-label{font-family:var(--mono);font-size:.55rem;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);margin-bottom:.4rem}
    .card-val{font-size:2.2rem;font-weight:900;line-height:1}
    .card-val.g{color:var(--green)}.card-val.s{color:var(--spot)}.card-val.r{color:var(--red)}
    .card-sub{font-family:var(--mono);font-size:.58rem;color:var(--muted);margin-top:.3rem}

    .links{display:flex;gap:.75rem;flex-wrap:wrap;margin-bottom:2rem}
    .lnk{font-family:var(--mono);font-size:.6rem;letter-spacing:.1em;text-transform:uppercase;padding:.5rem .9rem;border:1px solid var(--border);color:var(--ink);text-decoration:none;background:var(--card)}
    .lnk:hover{background:var(--ink);color:var(--paper)}

    .sec{margin-bottom:2.5rem}
    .sec-title{font-family:var(--mono);font-size:.6rem;letter-spacing:.18em;text-transform:uppercase;border-bottom:1px solid var(--border);padding-bottom:.5rem;margin-bottom:1rem}
    table{width:100%;border-collapse:collapse;background:var(--card)}
    th{font-family:var(--mono);font-size:.54rem;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);text-align:left;padding:.6rem .75rem;border-bottom:1px solid var(--border);background:var(--paper)}
    td{padding:.6rem .75rem;font-size:.82rem;border-bottom:1px solid #ede8df;vertical-align:middle}
    tr:last-child td{border-bottom:none}
    tr:hover td{background:#faf7f2}
    .badge{display:inline-block;font-family:var(--mono);font-size:.52rem;letter-spacing:.1em;text-transform:uppercase;padding:.2rem .5rem}
    .bp{background:#fef3c7;color:#92400e}.bf{background:#f0fdf4;color:#166534}
    .by{background:#f0fdf4;color:#166534}.bn{background:#fef2f2;color:#991b1b}
    .post-a{font-weight:700;color:var(--ink);text-decoration:none}
    .post-a:hover{color:var(--spot)}
    .tag{display:inline-block;font-family:var(--mono);font-size:.5rem;padding:.15rem .4rem;background:var(--paper);border:1px solid var(--border);margin-right:.2rem;text-transform:uppercase}
    .mono{font-family:var(--mono);font-size:.7rem;color:var(--muted);white-space:nowrap}
    .err{color:var(--red);font-family:var(--mono);font-size:.75rem;padding:.75rem;background:#fef2f2;border:1px solid #fca5a5;margin-bottom:1rem}
  </style>
</head>
<body>

{!isAuth && (
  <div class="login">
    <div class="login-box">
      <h1>First Cup</h1>
      <p>Panel de control</p>
      <form method="POST">
        <input type="password" name="password" placeholder="Contraseña" autofocus autocomplete="current-password"/>
        <button type="submit">Entrar →</button>
      </form>
    </div>
  </div>
)}

{isAuth && (
  <div class="dash">
    <div class="dh">
      <h1>First Cup Admin</h1>
      <span>{new Date().toLocaleString('es-ES',{weekday:'long',day:'numeric',month:'long',year:'numeric'})}</span>
    </div>

    {err && <p class="err">Error: {err}</p>}

    <div class="stats">
      <div class="card">
        <div class="card-label">Total suscriptores</div>
        <div class="card-val">{total}</div>
        <div class="card-sub">+{newWk} esta semana</div>
      </div>
      <div class="card">
        <div class="card-label">Premium</div>
        <div class="card-val s">{premium}</div>
        <div class="card-sub">{total > 0 ? Math.round(premium/total*100) : 0}% del total</div>
      </div>
      <div class="card">
        <div class="card-label">Confirmados</div>
        <div class="card-val g">{confirmed}</div>
        <div class="card-sub">{total - confirmed} pendientes</div>
      </div>
      <div class="card">
        <div class="card-label">Posts publicados</div>
        <div class="card-val">{posts.length}</div>
        <div class="card-sub">{postsWk} esta semana</div>
      </div>
    </div>

    <div class="links">
      <a class="lnk" href="https://github.com/Nicovp24/first-cup/actions" target="_blank">GitHub Actions ↗</a>
      <a class="lnk" href="https://supabase.com/dashboard" target="_blank">Supabase ↗</a>
      <a class="lnk" href="https://dashboard.stripe.com" target="_blank">Stripe ↗</a>
      <a class="lnk" href="https://resend.com/emails" target="_blank">Resend ↗</a>
      <a class="lnk" href="https://search.google.com/search-console" target="_blank">Search Console ↗</a>
    </div>

    <div class="sec">
      <div class="sec-title">Últimos posts ({posts.length})</div>
      <table>
        <thead><tr><th>Título</th><th>Tags</th><th>Fecha</th></tr></thead>
        <tbody>
          {posts.slice(0,20).map(p => (
            <tr>
              <td><a class="post-a" href={`/${p.slug}`} target="_blank">{p.title}</a></td>
              <td>{(p.tags ?? []).slice(0,3).map(t => <span class="tag">{t}</span>)}</td>
              <td class="mono">{fmt(p.published_at)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="sec">
      <div class="sec-title">Suscriptores ({total})</div>
      <table>
        <thead><tr><th>Email</th><th>Plan</th><th>Confirmado</th><th>Registro</th></tr></thead>
        <tbody>
          {subs.slice(0,30).map(s => (
            <tr>
              <td class="mono">{mask(s.email)}</td>
              <td><span class={`badge ${s.tier === 'premium' ? 'bp' : 'bf'}`}>{s.tier}</span></td>
              <td><span class={`badge ${s.confirmed ? 'by' : 'bn'}`}>{s.confirmed ? 'sí' : 'no'}</span></td>
              <td class="mono">{fmt(s.created_at)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
)}

</body>
</html>
