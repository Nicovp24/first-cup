---
import { getCollection } from 'astro:content';
import Header from '../components/Header.astro';
import PostCard from '../components/PostCard.astro';
import SEO from '../components/SEO.astro';
import '../styles/global.css';

const all = await getCollection('posts');

// Group posts by UTC date (YYYY-MM-DD) → editions
const byDate = new Map<string, typeof all>();
for (const p of all) {
  const k = p.data.date.toISOString().slice(0, 10);
  if (!byDate.has(k)) byDate.set(k, []);
  byDate.get(k)!.push(p);
}
for (const [, posts] of byDate) {
  posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
}

// Editions sorted ascending: index 0 = oldest (Edición #1)
const editionDates = [...byDate.keys()].sort();
const totalEditions = editionDates.length;

// Current = latest edition
const currentDate  = editionDates[totalEditions - 1];
const editionPosts = byDate.get(currentDate)!;
const [featured, ...rest] = editionPosts;

const editionDateFormatted = new Date(currentDate + 'T12:00:00Z').toLocaleDateString('es-ES', {
  weekday: 'long', day: 'numeric', month: 'long', year: 'numeric'
});

const editionTags = [...new Set(editionPosts.flatMap(p => p.data.tags))].sort();

const hasPrev    = totalEditions > 1;
const prevEdNum  = totalEditions - 1;

const SITE      = (Astro.site?.toString() ?? 'https://first-cup.es').replace(/\/$/, '');
const TITLE     = 'First Cup — Blog Tech en Español | Noticias de IA, Dev y Tecnología';
const DESC      = 'First Cup es el blog tech diario en español. Noticias de inteligencia artificial, programación, GitHub Trending y tecnología — curadas por IA cada mañana. Gratis.';
const CANONICAL = `${SITE}/`;

// JSON-LD: Blog + ItemList for Google sitelinks
const recentPosts = all
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 10);

const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'First Cup',
  url: SITE,
  description: DESC,
  inLanguage: 'es-ES',
  publisher: { '@type': 'Organization', name: 'First Cup', url: SITE },
  blogPost: recentPosts.map(p => ({
    '@type': 'BlogPosting',
    headline: p.data.title,
    url: `${SITE}/${p.slug}/`,
    datePublished: p.data.date.toISOString(),
    description: p.data.description ?? '',
    keywords: (p.data.tags ?? []).join(', '),
  })),
};
---

<!doctype html>
<html lang="es" data-theme="latte">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <title>{TITLE}</title>
  <SEO title={TITLE} description={DESC} canonical={CANONICAL} type="website" />
  <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />
</head>

<body>
<Header edition={totalEditions}/>

<main>

  <!-- ════════════ POSTS ════════════ -->
  <section class="edition-section" id="posts">
    <div class="container">

      {editionPosts.length === 0 ? (
        <div class="empty anim-up">
          <span class="kicker">Próximamente</span>
          <h2 class="empty-h">El primer digest llega pronto</h2>
          <p class="empty-p">Suscríbete para recibirlo cuando salga.</p>
          <a href="/subscribe" class="pill-btn">Suscribirme gratis</a>
        </div>
      ) : (
        <>
          {/* ── Edition banner ── */}
          <div class="ed-banner anim-in">
            <div class="ed-banner-left">
              <span class="ed-number gz-mono">
                Edición #{String(totalEditions).padStart(3, '0')}
              </span>
              <span class="ed-date gz-mono">{editionDateFormatted}</span>
            </div>
            {hasPrev && (
              <a href={`/edicion/${prevEdNum}`} class="ed-prev gz-mono">
                ← Edición #{String(prevEdNum).padStart(3, '0')}
              </a>
            )}
          </div>

          {/* LEAD — featured post, horizontal newspaper layout */}
          {featured && (
            <div class="lead-wrap anim-up">

              <!-- Eyebrow row -->
              <div class="lead-eyebrow">
                <span class="kicker">{featured.data.tags[0] ?? 'Digest'}</span>
              </div>

              <!-- Two-column: image left, text right -->
              <a href={`/${featured.slug}`} class="lead-link">
                <div class="lead-img">
                  {featured.data.cover
                    ? <img src={featured.data.cover} alt="" loading="eager" decoding="async"
                        onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1461749280684-dccba630e2f6?auto=format&fit=crop&w=900&q=80'" />
                    : <div class="lead-img-placeholder gz-mono">#{String(totalEditions).padStart(3,'0')}</div>
                  }
                </div>

                <div class="lead-content">
                  <h2 class="lead-title">{featured.data.title}</h2>
                  <p class="lead-stand">{featured.data.description}</p>
                  <div class="lead-byline">
                    <time class="byline gz-mono" datetime={featured.data.date.toISOString()}>
                      {featured.data.date.toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' })}
                    </time>
                    <span class="lead-byline-sep gz-mono" aria-hidden="true">·</span>
                    <span class="lead-readon gz-mono">Leer artículo →</span>
                  </div>
                </div>
              </a>
            </div>
          )}

          {/* Grid of the rest */}
          {rest.length > 0 && (
            <div class="grid-wrap">
              <div class="grid-header">
                <div class="grid-header-top">
                  <h2 class="section-head gz-mono">
                    Publicaciones
                    <span class="section-count">{rest.length}</span>
                  </h2>
                  <span id="search-count" class="gz-mono"></span>
                </div>
                <div class="search-filter-row">
                  <div class="search-wrap">
                    <input id="search-input" type="search" placeholder="Buscar artículos…" class="search-input gz-mono" autocomplete="off" />
                  </div>
                  {editionTags.length > 0 && (
                    <div class="tag-filter" id="tag-filter">
                      <button class="tf-btn active gz-mono" data-tag="all">Todos</button>
                      {editionTags.map(t => (
                        <button class="tf-btn gz-mono" data-tag={t}>{t}</button>
                      ))}
                    </div>
                  )}
                </div>
              </div>

              <div class="posts-grid" id="posts-grid">
                {rest.map((p, i) => (
                  <PostCard
                    title={p.data.title}
                    slug={p.slug}
                    date={p.data.date}
                    description={p.data.description}
                    tags={p.data.tags}
                    index={i}
                    editionNum={totalEditions}
                    cover={p.data.cover}
                  />
                ))}
              </div>
            </div>
          )}
        </>
      )}

    </div>
  </section>


  <!-- ════════════ NEWSLETTER COUPON ════════════ -->
  <section class="nl-section">
    <div class="container">
      <div class="coupon">
        <span class="coupon-scissors" aria-hidden="true">✂</span>
        <div class="coupon-inner">
          <span class="coupon-kicker gz-mono">Suscríbete · Gratis</span>
          <h2 class="coupon-title">Tu café tech, servido a las 07:00</h2>
          <p class="coupon-sub">Cada mañana, un agente lee internet por ti y te deja en el inbox solo lo que importa.</p>
          <form class="coupon-form" id="coupon-form" novalidate>
            <label for="coupon-email" class="sr-only">Tu email</label>
            <input id="coupon-email" type="email" name="email" placeholder="tu@email.com" autocomplete="email" required class="coupon-input gz-mono" />
            <button type="submit" class="coupon-btn gz-mono">
              <span class="coupon-btn-text">Suscribirme ▸</span>
              <span class="coupon-btn-loading" hidden>Enviando…</span>
            </button>
          </form>
          <p class="coupon-error gz-mono" id="coupon-error" role="alert" hidden></p>
          <div class="coupon-done gz-mono" id="coupon-done" hidden>✓ Suscrito — revisa tu inbox para confirmar.</div>
          <div class="coupon-fine gz-mono">
            <span>+ Sin spam</span>
            <span>+ Cancela cuando quieras</span>
          </div>
        </div>
      </div>
    </div>
  </section>

</main>

<!-- ════════════ WIRE TICKER ════════════ -->
<div class="wire wire-bottom" aria-hidden="true">
  <span class="wire-tag gz-mono">FUENTES</span>
  <div class="wire-mask">
    <div class="wire-track">
      {['GitHub Trending', 'Hacker News', 'ArXiv Papers', 'Reddit r/ML', 'Dev.to', 'Product Hunt', 'GitHub API', 'RSS Feeds',
        'GitHub Trending', 'Hacker News', 'ArXiv Papers', 'Reddit r/ML', 'Dev.to', 'Product Hunt', 'GitHub API', 'RSS Feeds',
        'GitHub Trending', 'Hacker News', 'ArXiv Papers', 'Reddit r/ML', 'Dev.to', 'Product Hunt', 'GitHub API', 'RSS Feeds'].map(item => (
        <>
          <span class="wire-item gz-mono">{item}</span>
          <span class="wire-sep" aria-hidden="true">◆</span>
        </>
      ))}
    </div>
  </div>
</div>

<!-- ════════════ FOOTER ════════════ -->
<footer class="site-footer">
  <div class="container">
    <div class="foot-top">
      <div class="foot-brand-col">
        <a href="/" class="foot-logo gz-mono">
          <span class="footer-fc">FC</span>
          First Cup
        </a>
        <p class="foot-tag">El diario del café tech. IA, desarrollo y tecnología curada cada mañana por un agente.</p>
      </div>
      <div class="foot-cols">
        <div class="foot-col">
          <h4 class="gz-mono">Contenido</h4>
          <a href="/">Posts</a>
          <a href="/subscribe">Newsletter</a>
          <a href="/rss.xml">RSS</a>
        </div>
        <div class="foot-col">
          <h4 class="gz-mono">Cuenta</h4>
          <a href="/cuenta">Mi suscripción</a>
          <a href="/privacidad">Privacidad</a>
          <a href="/terminos">Términos</a>
        </div>
        <div class="foot-col">
          <h4 class="gz-mono">Contacto</h4>
          <a href="mailto:hola@first-cup.es">hola@first-cup.es</a>
        </div>
      </div>
    </div>
    <div class="foot-base gz-mono">
      <span>© {new Date().getFullYear()} First Cup</span>
      <span>Hecho con Astro · IA generativa</span>
    </div>
  </div>
</footer>

<script>
  // ── Coupon subscribe form ──
  const couponForm = document.getElementById('coupon-form') as HTMLFormElement | null;
  if (couponForm) {
    couponForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = couponForm.querySelector<HTMLInputElement>('#coupon-email');
      const btnText = couponForm.querySelector<HTMLElement>('.coupon-btn-text');
      const btnLoading = couponForm.querySelector<HTMLElement>('.coupon-btn-loading');
      const btn = couponForm.querySelector<HTMLButtonElement>('.coupon-btn');
      const errorEl = document.getElementById('coupon-error') as HTMLElement | null;
      const doneEl = document.getElementById('coupon-done') as HTMLElement | null;
      if (!input || !errorEl || !doneEl) return;
      const email = input.value.trim();
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        errorEl.textContent = 'Introduce un email válido.';
        errorEl.hidden = false;
        input.focus();
        return;
      }
      errorEl.hidden = true;
      if (btnText) btnText.hidden = true;
      if (btnLoading) btnLoading.hidden = false;
      if (btn) btn.disabled = true;
      try {
        const res = await fetch('/api/subscribe', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email }) });
        if (!res.ok) { const d = await res.json().catch(() => ({})); throw new Error((d as any).message || `Error ${res.status}`); }
        couponForm.hidden = true;
        doneEl.hidden = false;
      } catch (err: unknown) {
        errorEl.textContent = err instanceof Error ? err.message : 'Algo salió mal.';
        errorEl.hidden = false;
        if (btnText) btnText.hidden = false;
        if (btnLoading) btnLoading.hidden = true;
        if (btn) btn.disabled = false;
      }
    });
  }

  // ── Init theme from localStorage ──
  const saved = localStorage.getItem('theme') ?? 'latte';
  document.documentElement.setAttribute('data-theme', saved);

  // ── Card scroll reveal ──
  const cards = document.querySelectorAll<HTMLElement>('.story-card');
  const cardObs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      (entry.target as HTMLElement).classList.add('in-view');
      cardObs.unobserve(entry.target);
    });
  }, { threshold: 0.06, rootMargin: '0px 0px -30px 0px' });
  cards.forEach(c => cardObs.observe(c));

  // ── Search + tag filter (combined) ──
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.tf-btn');
  const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
  const searchCount = document.getElementById('search-count') as HTMLElement | null;

  function applyFilters() {
    const query = searchInput?.value.trim().toLowerCase() ?? '';
    const activeTag = document.querySelector<HTMLButtonElement>('.tf-btn.active')?.dataset.tag ?? 'all';
    let visible = 0;
    document.querySelectorAll<HTMLElement>('.story-card').forEach(card => {
      const tags  = card.getAttribute('data-tags')?.split(',') ?? [];
      const title = card.getAttribute('data-title') ?? '';
      const show  = (activeTag === 'all' || tags.includes(activeTag)) && (!query || title.includes(query));
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (searchCount) {
      const total = document.querySelectorAll<HTMLElement>('.story-card').length;
      searchCount.textContent = (query || activeTag !== 'all') ? `${visible} resultado${visible !== 1 ? 's' : ''}` : '';
    }
  }

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      applyFilters();
    });
  });
  searchInput?.addEventListener('input', applyFilters);

  // ── Steam cursor particles ──
  let lastParticle = 0;
  document.addEventListener('mousemove', (e: MouseEvent) => {
    const now = Date.now();
    if (now - lastParticle < 60) return;
    lastParticle = now;
    const p = document.createElement('div');
    p.className = 'steam-particle';
    const ox = (Math.random() - 0.5) * 10;
    const oy = (Math.random() - 0.5) * 6;
    p.style.left = (e.clientX + ox) + 'px';
    p.style.top  = (e.clientY + oy) + 'px';
    const dx = (Math.random() - 0.5) * 14;
    document.body.appendChild(p);
    p.animate([
      { opacity: 0.35, transform: 'translate(-50%,-50%) scale(1)' },
      { opacity: 0,    transform: `translate(calc(-50% + ${dx}px), calc(-50% - 24px)) scale(0.2)` }
    ], { duration: 900, easing: 'ease-out', fill: 'forwards' })
      .addEventListener('finish', () => p.remove());
  });
</script>

<style>

  /* ── WIRE TICKER ── */
  .wire-bottom { margin-top: 3.5rem; }

  .wire {
    display: flex;
    align-items: stretch;
    border-bottom: 1px solid var(--rule);
    border-top: 1px solid var(--rule);
    background: var(--paper-sink);
  }

  .wire-tag {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    background: var(--spot);
    color: var(--paper);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    padding: 0 14px;
    text-transform: uppercase;
  }

  .wire-mask {
    flex: 1;
    overflow: hidden;
    padding: 0.6rem 0;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 4%, #000 96%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 4%, #000 96%, transparent);
  }

  .wire-track {
    display: flex;
    align-items: center;
    gap: 0;
    width: max-content;
    animation: wireScroll 42s linear infinite;
  }
  .wire-track:hover { animation-play-state: paused; }

  @keyframes wireScroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-33.33%); }
  }

  .wire-item {
    display: inline-flex;
    align-items: center;
    font-size: 0.7rem;
    color: var(--ink-soft);
    white-space: nowrap;
    padding: 0 0.75rem;
    letter-spacing: 0.04em;
  }

  .wire-sep {
    color: var(--spot);
    font-size: 0.42rem;
    opacity: 0.55;
    padding: 0 0.1rem;
    flex-shrink: 0;
  }


  /* ── EDITION SECTION ── */
  .edition-section { padding: 2.5rem 0 5rem; }

  /* ── EDITION BANNER ── */
  .ed-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding: 0.7rem 1rem;
    background: var(--paper-sink);
    border: 1px solid var(--rule);
    border-top: 3px solid var(--ink);
    margin-bottom: 2.5rem;
  }

  .ed-banner-left {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .ed-number {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--spot);
    letter-spacing: 0.02em;
  }

  .ed-date {
    font-size: 0.88rem;
    color: var(--ink-soft);
    letter-spacing: 0.01em;
  }

  .ed-prev {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--ink-soft);
    text-decoration: none;
    letter-spacing: 0.01em;
    border: 1px solid var(--rule);
    padding: 0.28rem 0.7rem;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }
  .ed-prev:hover {
    color: var(--spot);
    border-color: oklch(from var(--spot) l c h / .45);
    background: oklch(from var(--spot) l c h / .06);
    text-decoration: none;
  }

  /* ── LEAD — horizontal newspaper layout ── */
  .lead-wrap {
    padding-bottom: 3rem;
    border-bottom: 3px double var(--ink);
    margin-bottom: 3rem;
  }

  .lead-eyebrow {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--rule);
  }

  .lead-link {
    display: grid;
    grid-template-columns: 44% 1fr;
    gap: 2.5rem;
    align-items: start;
    text-decoration: none;
    color: inherit;
  }
  .lead-link:hover { text-decoration: none; }

  .lead-img {
    overflow: hidden;
    border: 1px solid var(--rule);
    border-top: 2px solid var(--ink);
    aspect-ratio: 4/3;
    width: 100%;
    flex-shrink: 0;
    position: relative;
  }
  .lead-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.65s var(--spring);
    display: block;
  }
  .lead-link:hover .lead-img img { transform: scale(1.035); }

  .lead-img-placeholder {
    width: 100%; height: 100%;
    background: var(--paper-sink);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--rule);
    letter-spacing: 0.06em;
    min-height: 260px;
  }

  .lead-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 0.25rem;
  }

  .lead-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.8rem, 3.2vw, 3rem);
    line-height: 1.08;
    letter-spacing: -0.025em;
    color: var(--ink);
    transition: color 0.2s;
  }
  .lead-link:hover .lead-title { color: var(--spot); }

  .lead-stand {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--ink-soft);
  }

  .lead-byline {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    padding: 0.65rem 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .lead-byline-sep { color: var(--rule); font-size: 0.8rem; }

  .lead-readon {
    font-family: 'Times New Roman', Times, serif;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--spot);
    letter-spacing: 0.01em;
    transition: color 0.15s;
  }
  .lead-link:hover .lead-readon { color: var(--spot-deep); }


  /* ── GRID OF POSTS ── */
  .grid-header {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.65rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--ink);
    margin-bottom: 1.75rem;
  }
  .grid-header-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }
  #search-count {
    font-family: 'Times New Roman', Times, serif;
    font-size: 0.85rem;
    color: var(--ink-faint);
    letter-spacing: 0.01em;
  }
  .search-filter-row {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    flex-wrap: wrap;
  }
  .search-wrap { flex: 1; min-width: 160px; }
  .search-input {
    width: 100%;
    font-size: 0.9rem;
    font-family: 'Times New Roman', Times, serif;
    letter-spacing: 0.01em;
    color: var(--ink);
    background: var(--paper);
    border: 1px solid var(--rule);
    padding: 0.28rem 0.65rem;
    outline: none;
    border-radius: 2px;
    transition: border-color 0.15s;
    box-sizing: border-box;
  }
  .search-input:focus { border-color: var(--spot); }
  .search-input::placeholder { color: var(--ink-faint); }

  .section-head {
    font-family: 'Times New Roman', Times, serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: 0.01em;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .section-count {
    font-size: 0.88rem;
    color: var(--spot);
    background: oklch(from var(--spot) l c h / .1);
    border: 1px solid oklch(from var(--spot) l c h / .22);
    border-radius: 2px;
    padding: 0.06rem 0.38rem;
    font-weight: 400;
  }

  /* ── TAG FILTER ── */
  .tag-filter {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .tf-btn {
    font-family: 'Times New Roman', Times, serif;
    font-size: 0.88rem;
