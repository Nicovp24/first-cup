---
import { getCollection } from 'astro:content';
import Header from '../components/Header.astro';
import PostCard from '../components/PostCard.astro';
import SubscribeForm from '../components/SubscribeForm.astro';
import CoffeeCup from '../components/CoffeeCup.astro';
import '../styles/global.css';

const all   = await getCollection('posts');
const posts = all.sort((a,b) => b.data.date.getTime() - a.data.date.getTime());
const [featured, ...rest] = posts;
const total = posts.length;
const allTags = [...new Set(posts.flatMap(p => p.data.tags))].sort();

const tagCounts: Record<string, number> = {};
posts.forEach(p => p.data.tags.forEach(t => { tagCounts[t] = (tagCounts[t] ?? 0) + 1; }));
const topTags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]).slice(0, 7).map(([t]) => t);

const T = 'First Cup — IA, Dev & Tech';
const D = 'Tu café tech de cada mañana. IA, desarrollo y tecnología en tu inbox.';
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://firstcup.dev';
const ogImg = `${siteUrl}/og-default.svg`;
---

<!doctype html>
<html lang="es" data-theme="latte">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <meta name="description" content={D}/>
  <meta property="og:type" content="website"/>
  <meta property="og:url" content={`${siteUrl}/`}/>
  <meta property="og:title" content={T}/>
  <meta property="og:description" content={D}/>
  <meta property="og:image" content={ogImg}/>
  <meta property="og:site_name" content="First Cup"/>
  <meta name="twitter:card" content="summary_large_image"/>
  <meta name="twitter:title" content={T}/>
  <meta name="twitter:description" content={D}/>
  <meta name="twitter:image" content={ogImg}/>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <link rel="canonical" href={`${siteUrl}/`}/>
  <link rel="sitemap" href="/sitemap.xml"/>
  <link rel="alternate" type="application/rss+xml" title="First Cup RSS" href="/rss.xml"/>
  <title>{T}</title>
</head>

<body>
<Header/>

<main>

  <!-- ════════════ WIRE TICKER ════════════ -->
  <div class="wire" aria-hidden="true">
    <span class="wire-tag gz-mono">FUENTES</span>
    <div class="wire-mask">
      <div class="wire-track">
        {['GitHub Trending', 'Hacker News', 'ArXiv Papers', 'Reddit r/ML', 'Dev.to', 'Product Hunt', 'GitHub API', 'RSS Feeds',
          'GitHub Trending', 'Hacker News', 'ArXiv Papers', 'Reddit r/ML', 'Dev.to', 'Product Hunt', 'GitHub API', 'RSS Feeds',
          'GitHub Trending', 'Hacker News', 'ArXiv Papers', 'Reddit r/ML', 'Dev.to', 'Product Hunt', 'GitHub API', 'RSS Feeds'].map(item => (
          <>
            <span class="wire-item gz-mono">{item}</span>
            <span class="wire-sep" aria-hidden="true">◆</span>
          </>
        ))}
      </div>
    </div>
  </div>


  <!-- ════════════ POSTS ════════════ -->
  <section class="edition-section" id="posts">
    <div class="container">

      {posts.length === 0 ? (
        <div class="empty anim-up">
          <span class="kicker">Próximamente</span>
          <h2 class="empty-h">El primer digest llega pronto</h2>
          <p class="empty-p">Suscríbete para recibirlo cuando salga.</p>
          <a href="/subscribe" class="pill-btn">Suscribirme gratis</a>
        </div>
      ) : (
        <>
          {/* LEAD — featured post, newspaper front-page style */}
          {featured && (
            <div class="lead-wrap anim-up">
              <div class="lead-edition">
                <span class="kicker">Última edición</span>
                <span class="edition-num gz-mono">
                  #{String(total).padStart(3, '0')}
                </span>
              </div>

              <a href={`/${featured.slug}`} class="lead-link">
                {featured.data.cover && (
                  <div class="lead-img">
                    <img src={featured.data.cover} alt="" loading="eager" decoding="async"/>
                  </div>
                )}
                <div class="lead-body">
                  <span class="kicker lead-kicker">
                    {featured.data.tags[0] ?? 'Digest'}
                  </span>
                  <h2 class="lead-title">{featured.data.title}</h2>
                  <p class="lead-stand">{featured.data.description}</p>
                  <div class="lead-byline">
                    <span class="byline gz-mono">
                      <time datetime={featured.data.date.toISOString()}>
                        {featured.data.date.toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' })}
                      </time>
                    </span>
                    <span class="lead-readon gz-mono">Leer artículo →</span>
                  </div>
                </div>
              </a>
            </div>
          )}

          {/* Grid of the rest */}
          {rest.length > 0 && (
            <div class="grid-wrap">
              <div class="grid-header">
                <h2 class="section-head gz-mono">
                  Publicaciones
                  <span class="section-count">{rest.length}</span>
                </h2>
                {allTags.length > 0 && (
                  <div class="tag-filter" id="tag-filter">
                    <button class="tf-btn active gz-mono" data-tag="all">Todos</button>
                    {allTags.map(t => (
                      <button class="tf-btn gz-mono" data-tag={t}>{t}</button>
                    ))}
                  </div>
                )}
              </div>

              <div class="posts-grid" id="posts-grid">
                {rest.map((p, i) => (
                  <PostCard
                    title={p.data.title}
                    slug={p.slug}
                    date={p.data.date}
                    description={p.data.description}
                    tags={p.data.tags}
                    index={i}
                    editionNum={total - 1 - i}
                    cover={p.data.cover}
                  />
                ))}
              </div>
            </div>
          )}
        </>
      )}

    </div>
  </section>


  <!-- ════════════ NEWSLETTER ════════════ -->
  <section class="nl-section">
    <div class="container">
      <div class="nl-box">
        <div class="nl-rule-top" aria-hidden="true"></div>

        <div class="nl-inner">
          <div class="nl-left">
            <span class="kicker">Newsletter · Free</span>
            <h2 class="nl-h">
              Todo lo importante,<br/>
              <em>en tu inbox.</em>
            </h2>
            <p class="nl-p">
              Sin spam. Sin relleno. Cancela cuando quieras.
            </p>
            <ul class="nl-list">
              <li>GitHub Trending diario</li>
              <li>Papers de ArXiv en lenguaje humano</li>
              <li>Hacker News + Reddit curado</li>
              <li>Los mejores blogs del sector</li>
            </ul>
          </div>
          <div class="nl-right">
            <SubscribeForm compact={false}/>
          </div>
        </div>

      </div>
    </div>
  </section>

</main>

<!-- ════════════ FOOTER ════════════ -->
<footer class="site-footer">
  <div class="container footer-inner">
    <span class="footer-brand gz-mono">
      <span class="footer-fc">FC</span>
      First Cup
    </span>
    <nav class="footer-nav">
      <a href="/" class="gz-mono">Posts</a>
      <a href="/subscribe" class="gz-mono">Suscribirse</a>
    </nav>
    <span class="footer-copy gz-mono">© {new Date().getFullYear()} · Hecho con Astro</span>
  </div>
</footer>

<script>
  // ── Init theme from localStorage ──
  const saved = localStorage.getItem('theme') ?? 'latte';
  document.documentElement.setAttribute('data-theme', saved);

  // ── Card scroll reveal ──
  const cards = document.querySelectorAll<HTMLElement>('.story-card');
  const cardObs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      (entry.target as HTMLElement).classList.add('in-view');
      cardObs.unobserve(entry.target);
    });
  }, { threshold: 0.06, rootMargin: '0px 0px -30px 0px' });
  cards.forEach(c => cardObs.observe(c));

  // ── Tag filter ──
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.tf-btn');
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const tag = btn.dataset.tag ?? 'all';
      document.querySelectorAll<HTMLElement>('.story-card').forEach(card => {
        const tags = card.getAttribute('data-tags')?.split(',') ?? [];
        card.style.display = tag === 'all' || tags.includes(tag) ? '' : 'none';
      });
    });
  });

  // ── Steam cursor particles ──
  let lastParticle = 0;
  document.addEventListener('mousemove', (e: MouseEvent) => {
    const now = Date.now();
    if (now - lastParticle < 60) return;
    lastParticle = now;
    const p = document.createElement('div');
    p.className = 'steam-particle';
    const ox = (Math.random() - 0.5) * 10;
    const oy = (Math.random() - 0.5) * 6;
    p.style.left = (e.clientX + ox) + 'px';
    p.style.top  = (e.clientY + oy) + 'px';
    const dx = (Math.random() - 0.5) * 14;
    document.body.appendChild(p);
    p.animate([
      { opacity: 0.35, transform: 'translate(-50%,-50%) scale(1)' },
      { opacity: 0,    transform: `translate(calc(-50% + ${dx}px), calc(-50% - 24px)) scale(0.2)` }
    ], { duration: 900, easing: 'ease-out', fill: 'forwards' })
      .addEventListener('finish', () => p.remove());
  });
</script>

<style>

  /* ── WIRE TICKER ── */
  .wire {
    display: flex;
    align-items: stretch;
    border-bottom: 1px solid var(--rule);
    border-top: 1px solid var(--rule);
    background: var(--paper-sink);
  }

  .wire-tag {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    background: var(--spot);
    color: var(--paper);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    padding: 0 14px;
    text-transform: uppercase;
  }

  .wire-mask {
    flex: 1;
    overflow: hidden;
    padding: 0.55rem 0;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 4%, #000 96%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 4%, #000 96%, transparent);
  }

  .wire-track {
    display: flex;
    align-items: center;
    gap: 0;
    width: max-content;
    animation: wireScroll 42s linear infinite;
  }
  .wire-track:hover { animation-play-state: paused; }

  @keyframes wireScroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-33.33%); }
  }

  .wire-item {
    display: inline-flex;
    align-items: center;
    font-size: 0.68rem;
    color: var(--ink-soft);
    white-space: nowrap;
    padding: 0 0.5rem;
  }

  .wire-sep {
    color: var(--spot);
    font-size: 0.45rem;
    opacity: 0.6;
    padding: 0 0.25rem;
    flex-shrink: 0;
  }


  /* ── EDITION SECTION ── */
  .edition-section { padding: 2.5rem 0 5rem; }

  /* ── LEAD ── */
  .lead-wrap {
    margin-bottom: 0;
    padding-bottom: 2.5rem;
    border-bottom: 3px double var(--ink);
    margin-bottom: 2.5rem;
  }

  .lead-edition {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .edition-num {
    font-size: 0.7rem;
    color: var(--ink-faint);
    letter-spacing: 0.1em;
  }

  .lead-link {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
    text-decoration: none;
    color: inherit;
  }
  .lead-link:hover { text-decoration: none; }
  @media (max-width: 780px) {
    .lead-link { grid-template-columns: 1fr; gap: 1.5rem; }
  }

  .lead-img {
    overflow: hidden;
    border: 1px solid var(--ink);
    aspect-ratio: 16/9;
  }
  .lead-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.5s var(--spring);
  }
  .lead-link:hover .lead-img img { transform: scale(1.03); }

  .lead-body {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    padding-top: 0.25rem;
  }

  .lead-kicker { margin-bottom: 0.1rem; }

  .lead-title {
    font-family: 'Bodoni Moda', serif;
    font-optical-sizing: auto;
    font-weight: 800;
    font-size: clamp(1.8rem, 3.5vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.022em;
    color: var(--ink);
    transition: color 0.18s;
  }
  .lead-link:hover .lead-title { color: var(--spot-deep); }

  .lead-stand {
    font-size: 1.1rem;
    line-height: 1.6;
    font-style: italic;
    color: var(--ink-soft);
    max-width: 55ch;
  }

  .lead-byline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding-top: 0.75rem;
    border-top: 1px solid var(--rule);
  }

  .lead-readon {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--spot);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }


  /* ── GRID OF POSTS ── */
  .grid-wrap { }

  .grid-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--ink);
    margin-bottom: 1.75rem;
  }

  .section-head {
    font-size: 0.68rem;
    font-weight: 700;
    color: var(--ink);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .section-count {
    font-size: 0.62rem;
    color: var(--spot);
    background: oklch(from var(--spot) l c h / .1);
    border: 1px solid oklch(from var(--spot) l c h / .22);
    border-radius: 2px;
    padding: 0.06rem 0.38rem;
    font-weight: 400;
  }

  /* ── TAG FILTER ── */
  .tag-filter {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .tf-btn {
    font-size: 0.62rem;
    font-weight: 400;
    color: var(--ink-soft);
    background: none;
    border: 1px solid var(--rule);
    border-radius: 2px;
    padding: 0.22rem 0.55rem;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
    letter-spacing: 0.05em;
    text-transform: lowercase;
  }
  .tf-btn:hover {
    color: var(--spot);
    border-color: oklch(from var(--spot) l c h / .4);
    background: oklch(from var(--spot) l c h / .06);
  }
  .tf-btn.active {
    color: var(--paper);
    background: var(--ink);
    border-color: var(--ink);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-left: 1px solid var(--rule);
    border-top: 1px solid var(--rule);
  }

  /* ── EMPTY STATE ── */
  .empty {
    padding: 5rem 0;
    border-top: 3px double var(--ink);
    max-width: 480px;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .empty-h {
    font-family: 'Bodoni Moda', serif;
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--ink);
    letter-spacing: -0.02em;
    line-height: 1.15;
  }
  .empty-p { color: var(--ink-soft); font-size: 0.9rem; line-height: 1.65; }
  .pill-btn {
    display: inline-block;
    background: var(--ink);
    color: var(--paper);
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.8rem;
    padding: 0.6rem 1.35rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    transition: opacity 0.15s;
    border-radius: 0;
    width: fit-content;
    margin-top: 0.5rem;
  }
  .pill-btn:hover { opacity: 0.8; text-decoration: none; }


  /* ── NEWSLETTER ── */
  .nl-section { padding-bottom: 5rem; }

  .nl-box {
    border: 1px solid var(--ink);
    position: relative;
  }

  .nl-rule-top {
    height: 3px;
    background: linear-gradient(90deg, var(--spot) 0%, transparent 60%);
    border-bottom: 1px solid var(--rule);
  }

  .nl-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
    padding: 2.5rem;
  }

  .nl-h {
    font-family: 'Bodoni Moda', serif;
    font-size: 1.9rem;
    font-weight: 800;
    color: var(--ink);
    letter-spacing: -0.025em;
    line-height: 1.15;
    margin: 0.75rem 0;
  }
  .nl-h em { font-style: italic; color: var(--spot); font-weight: 400; }

  .nl-p { color: var(--ink-soft); font-size: 0.9rem; line-height: 1.7; margin-bottom: 1.25rem; }

  .nl-list { list-style: none; display: flex; flex-direction: column; gap: 0.4rem; }
  .nl-list li {
    font-size: 0.875rem; color: var(--ink-soft);
    padding-left: 1rem; position: relative;
  }
  .nl-list li::before {
    content: '·';
    position: absolute; left: 0;
    color: var(--spot); font-size: 1rem; line-height: 1.3;
  }

  .nl-right { padding-top: 2rem; }


  /* ── FOOTER ── */
  .site-footer {
    border-top: 3px double var(--ink);
    padding: 1.25rem 0;
    background: var(--paper-sink);
  }

  .footer-inner {
    display: flex; align-items: center;
    justify-content: space-between;
    flex-wrap: wrap; gap: 1rem;
  }

  .footer-brand {
    display: flex; align-items: center; gap: 0.45rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--ink-soft);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .footer-fc {
    width: 26px; height: 20px;
    background: var(--ink); color: var(--paper);
    font-size: 0.58rem; font-weight: 700;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 2px;
  }

  .footer-nav { display: flex; gap: 1.5rem; }
  .footer-nav a {
    font-size: 0.68rem; color: var(--ink-soft);
    text-transform: uppercase; letter-spacing: 0.08em;
    transition: color 0.15s;
  }
  .footer-nav a:hover { color: var(--ink); text-decoration: none; }

  .footer-copy { font-size: 0.65rem; color: var(--ink-faint); letter-spacing: 0.06em; }


  /* ── RESPONSIVE ── */
  @media (max-width: 860px) {
    .posts-grid { grid-template-columns: repeat(2, 1fr); }
    .nl-inner { grid-template-columns: 1fr; gap: 2rem; padding: 1.75rem; }
    .nl-right { padding-top: 0; }
  }

  @media (max-width: 560px) {
    .posts-grid { grid-template-columns: 1fr; }
    .footer-inner { flex-direction: column; align-items: flex-start; }
  }
</style>
