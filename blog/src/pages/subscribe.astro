---
import Header from '../components/Header.astro';
import SubscribeForm from '../components/SubscribeForm.astro';
import SEO from '../components/SEO.astro';
import '../styles/global.css';

const SITE = (Astro.site?.toString() ?? 'https://first-cup-kappa.vercel.app').replace(/\/$/, '');
---

<!doctype html>
<html lang="es" data-theme="latte">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>Suscribirse gratis – First Cup</title>
  <SEO
    title="Suscribirse gratis – First Cup | Digest tech diario"
    description="Recibe cada mañana el mejor tech en tu inbox: IA, GitHub, papers, dev tools. Gratis, sin spam, cancela cuando quieras."
    canonical={`${SITE}/subscribe`}
    type="website"
  />
</head>

<body>
  <Header />

  <main class="main">
    <div class="container">

      <!-- Page header -->
      <div class="page-header anim-up">
        <div class="header-rule-top" aria-hidden="true"></div>
        <span class="kicker">Newsletter · Daily digest</span>
        <h1 class="page-title">
          Tu café tech,<br/>
          <em>cada mañana.</em>
        </h1>
        <p class="page-subtitle">
          First Cup analiza automáticamente cientos de fuentes cada día
          y te entrega solo lo que vale la pena — sin ruido, sin spam.
        </p>
      </div>

      <!-- Stats strip -->
      <div class="stats-strip anim-up" style="animation-delay:60ms" aria-label="Métricas del digest">
        <div class="stat-item">
          <span class="stat-num">500+</span>
          <span class="stat-label gz-mono">Fuentes analizadas</span>
        </div>
        <span class="stat-sep" aria-hidden="true">·</span>
        <div class="stat-item">
          <span class="stat-num">2×</span>
          <span class="stat-label gz-mono">Al día</span>
        </div>
        <span class="stat-sep" aria-hidden="true">·</span>
        <div class="stat-item">
          <span class="stat-num">6</span>
          <span class="stat-label gz-mono">Posts por edición</span>
        </div>
        <span class="stat-sep" aria-hidden="true">·</span>
        <div class="stat-item">
          <span class="stat-num">0€</span>
          <span class="stat-label gz-mono">Para empezar</span>
        </div>
      </div>

      <!-- Plans -->
      <div class="plans-wrap anim-up" style="animation-delay:80ms">

        <div class="plans-grid">

          <!-- Free plan -->
          <div class="plan-card">
            <div class="plan-ornament gz-mono" aria-hidden="true">— ✦ —</div>
            <div class="plan-tier gz-mono">Lector</div>
            <div class="plan-price">
              <span class="price-amount">0<span class="price-cur">€</span></span>
              <span class="price-period gz-mono">para siempre</span>
            </div>
            <p class="plan-description">
              Acceso completo al blog, digest semanal en tu inbox
              y archivo histórico. Sin tarjeta, sin compromiso.
            </p>
            <ul class="plan-features" aria-label="Características del plan gratuito">
              <li class="feature"><span class="fc" aria-hidden="true">✓</span>Blog público con todos los posts</li>
              <li class="feature"><span class="fc" aria-hidden="true">✓</span>Email semanal con el resumen tech</li>
              <li class="feature"><span class="fc" aria-hidden="true">✓</span>Archivo histórico completo</li>
              <li class="feature"><span class="fc" aria-hidden="true">✓</span>RSS feed para tu lector favorito</li>
              <li class="feature fc-empty"><span class="fc fc-no" aria-hidden="true">–</span>Digest diario</li>
              <li class="feature fc-empty"><span class="fc fc-no" aria-hidden="true">–</span>Mini cursos prácticos</li>
            </ul>
            <div class="plan-action">
              <p class="subscribe-label gz-mono">Tu email:</p>
              <SubscribeForm compact={true} />
            </div>
          </div>

          <!-- Divider -->
          <div class="plans-divider" aria-hidden="true">
            <span class="pd-line"></span>
            <span class="pd-or gz-mono">O</span>
            <span class="pd-line"></span>
          </div>

          <!-- Premium plan -->
          <div class="plan-card plan-premium">
            <div class="plan-badge gz-mono">RECOMENDADO</div>
            <div class="plan-ornament plan-ornament--spot gz-mono" aria-hidden="true">— ✦ —</div>
            <div class="plan-tier gz-mono plan-tier--spot">Premium</div>
            <div class="plan-price">
              <span class="price-amount price-amount--spot">5<span class="price-cur">€</span></span>
              <span class="price-period gz-mono">al mes</span>
            </div>
            <p class="plan-description">
              Para quienes quieren estar un paso por delante.
              Análisis diarios, formación práctica y sin anuncios.
            </p>
            <ul class="plan-features" aria-label="Características del plan premium">
              <li class="feature"><span class="fc fc-spot" aria-hidden="true">✓</span>Todo lo del plan Lector</li>
              <li class="feature"><span class="fc fc-spot" aria-hidden="true">✓</span><strong>Digest diario</strong> – análisis de lunes a viernes</li>
              <li class="feature"><span class="fc fc-spot" aria-hidden="true">✓</span><strong>Mini cursos</strong> – guías sobre tendencias tech</li>
              <li class="feature"><span class="fc fc-spot" aria-hidden="true">✓</span>Acceso anticipado a nuevas funciones</li>
              <li class="feature"><span class="fc fc-spot" aria-hidden="true">✓</span>Sin anuncios, nunca</li>
              <li class="feature"><span class="fc fc-spot" aria-hidden="true">✓</span>Cancela cuando quieras</li>
            </ul>
            <div class="plan-action">
              <form id="premium-form" novalidate>
                <label for="premium-email" class="subscribe-label gz-mono">Tu email:</label>
                <input
                  id="premium-email"
                  type="email"
                  name="email"
                  placeholder="tu@email.com"
                  autocomplete="email"
                  required
                  class="premium-input gz-mono"
                />
                <button type="submit" class="premium-btn gz-mono" id="premium-btn">
                  <span class="premium-btn-text">Empezar plan Premium →</span>
                  <span class="premium-btn-loading" hidden>Redirigiendo…</span>
                </button>
              </form>
              <p class="premium-error gz-mono" id="premium-error" role="alert" hidden></p>
              <p class="premium-note gz-mono">Pago seguro con Stripe</p>
            </div>
          </div>

        </div>
      </div>

      <!-- FAQ -->
      <section class="faq-section" aria-label="Preguntas frecuentes">
        <div class="faq-header">
          <h2 class="faq-heading gz-mono">Preguntas frecuentes</h2>
        </div>
        <div class="faq-grid">
          <div class="faq-item">
            <h3>¿Con qué frecuencia se publica?</h3>
            <p>
              El digest gratuito sale los lunes. El plan Premium
              incluye análisis de lunes a viernes, todos los días laborables.
            </p>
          </div>
          <div class="faq-item">
            <h3>¿Quién escribe el contenido?</h3>
            <p>
              Un agente de IA analiza cientos de fuentes (Hacker News,
              GitHub Trending, ArXiv, feeds RSS) y redacta los análisis,
              que son revisados antes de publicarse.
            </p>
          </div>
          <div class="faq-item">
            <h3>¿Puedo cancelar en cualquier momento?</h3>
            <p>
              Sí, sin permanencia ni penalizaciones. Cancela desde tu cuenta
              o escríbenos y lo gestionamos en 24h.
            </p>
          </div>
          <div class="faq-item">
            <h3>¿Qué temas cubre First Cup?</h3>
            <p>
              Inteligencia artificial, ingeniería de software, herramientas dev,
              tendencias de la industria tech, open source y startups relevantes.
            </p>
          </div>
        </div>
      </section>

    </div>
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="foot-top">
        <div class="foot-brand-col">
          <a href="/" class="foot-logo gz-mono">
            <span class="footer-fc">FC</span>
            First Cup
          </a>
          <p class="foot-tag">El diario del café tech. IA, desarrollo y tecnología curada cada mañana por un agente.</p>
        </div>
        <div class="foot-cols">
          <div class="foot-col">
            <h4 class="gz-mono">Contenido</h4>
            <a href="/">Posts</a>
            <a href="/subscribe">Newsletter</a>
            <a href="/rss.xml">RSS</a>
          </div>
          <div class="foot-col">
            <h4 class="gz-mono">Plataforma</h4>
            <span>First Cup AI</span>
            <span>Astro SSG</span>
          </div>
          <div class="foot-col">
            <h4 class="gz-mono">Contacto</h4>
            <a href="mailto:hola@firstcup.es">hola@firstcup.es</a>
          </div>
        </div>
      </div>
      <div class="foot-base gz-mono">
        <span>© {new Date().getFullYear()} First Cup</span>
        <span>Hecho con Astro · IA generativa</span>
      </div>
    </div>
  </footer>
</body>
</html>

<script>
  const saved = localStorage.getItem('theme') ?? 'latte';
  document.documentElement.setAttribute('data-theme', saved);

  // ── Premium checkout form ──
  const premiumForm = document.getElementById('premium-form') as HTMLFormElement | null;
  if (premiumForm) {
    premiumForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input   = premiumForm.querySelector<HTMLInputElement>('#premium-email');
      const btn     = premiumForm.querySelector<HTMLButtonElement>('#premium-btn');
      const btnText = premiumForm.querySelector<HTMLElement>('.premium-btn-text');
      const btnLoad = premiumForm.querySelector<HTMLElement>('.premium-btn-loading');
      const errEl   = document.getElementById('premium-error') as HTMLElement | null;
      if (!input || !errEl) return;

      const email = input.value.trim();
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        errEl.textContent = 'Introduce un email válido.';
        errEl.hidden = false;
        input.focus();
        return;
      }
      errEl.hidden = true;
      if (btn) btn.disabled = true;
      if (btnText) btnText.hidden = true;
      if (btnLoad) btnLoad.hidden = false;

      try {
        const res = await fetch('/api/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        const data = await res.json() as { url?: string; message?: string };
        if (!res.ok || !data.url) throw new Error(data.message ?? `Error ${res.status}`);
        window.location.href = data.url;
      } catch (err: unknown) {
        errEl.textContent = err instanceof Error ? err.message : 'Algo salió mal. Inténtalo de nuevo.';
        errEl.hidden = false;
        if (btn) btn.disabled = false;
        if (btnText) btnText.hidden = false;
        if (btnLoad) btnLoad.hidden = true;
      }
    });
  }
</script>

<style>
  .main { padding: 3rem 0 5rem; }

  /* ── Page header ── */
  .page-header {
    max-width: 600px;
    margin: 0 auto 4rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .header-rule-top {
    width: 60px;
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--spot), transparent);
    margin-bottom: 0.5rem;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 800;
    color: var(--ink);
    line-height: 1.1;
    letter-spacing: -0.022em;
  }
  .page-title em { font-style: italic; color: var(--spot); font-weight: 400; }

  .page-subtitle {
    font-size: 1rem;
    color: var(--ink-soft);
    line-height: 1.7;
    font-style: italic;
  }

  /* ── Stats strip ── */
  .stats-strip {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    border-top: 3px double var(--ink);
    border-bottom: 1px solid var(--rule);
    padding: 1.4rem 0 1.5rem;
    margin-bottom: 4rem;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }

  .stat-num {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--spot);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .stat-label {
    font-size: 0.6rem;
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .stat-sep {
    color: var(--rule);
    font-size: 1.4rem;
    line-height: 1;
    align-self: center;
  }

  /* ── Plans wrap ── */
  .plans-wrap {
    margin-bottom: 5rem;
    border-top: 3px double var(--ink);
    border-bottom: 3px double var(--ink);
  }

  .plans-grid {
    display: grid;
    grid-template-columns: 1fr 40px 1fr;
    gap: 0;
  }

  /* Vertical divider */
  .plans-divider {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 2rem 0;
    border-left: 1px solid var(--rule);
    border-right: 1px solid var(--rule);
  }
  .pd-line {
    display: block;
    width: 1px;
    flex: 1;
    background: var(--rule);
  }
  .pd-or {
    font-size: 0.58rem;
    font-weight: 700;
    color: var(--ink-faint);
    letter-spacing: 0.18em;
  }

  .plan-card {
    background: var(--paper);
    padding: 2.5rem 2.25rem;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .plan-premium {
    background: var(--paper-sink);
  }

  .plan-badge {
    position: absolute;
    top: 0; left: 50%;
    transform: translate(-50%, -50%);
    background: var(--spot);
    color: var(--paper);
    font-size: 0.54rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    padding: 0.22rem 0.9rem;
    white-space: nowrap;
  }

  .plan-ornament {
    text-align: center;
    font-size: 0.62rem;
    color: var(--rule);
    letter-spacing: 0.25em;
    margin-bottom: -0.5rem;
  }
  .plan-ornament--spot { color: oklch(from var(--spot) l c h / .45); }

  .plan-tier {
    text-align: center;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
  .plan-tier--spot { color: var(--spot); }

  .plan-price {
    text-align: center;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding: 1.1rem 0;
  }

  .price-amount {
    display: block;
    font-family: var(--font-display);
    font-size: 3.5rem;
    font-weight: 900;
    color: var(--ink);
    line-height: 1;
    letter-spacing: -0.03em;
  }
  .price-amount--spot { color: var(--spot); }

  .price-cur {
    font-size: 1.6rem;
    font-weight: 700;
    vertical-align: super;
    letter-spacing: 0;
    margin-left: 2px;
  }

  .price-period {
    display: block;
    font-size: 0.62rem;
    color: var(--ink-faint);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-top: 0.4rem;
  }

  .plan-description {
    font-size: 0.875rem;
    color: var(--ink-soft);
    line-height: 1.68;
    font-style: italic;
    text-align: center;
  }

  .plan-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    flex: 1;
    border-top: 1px solid var(--rule-soft);
    padding-top: 1.25rem;
  }

  .feature {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    font-size: 0.875rem;
    color: var(--ink);
    line-height: 1.5;
  }
  .fc-empty { color: var(--ink-faint); }

  .fc {
    flex-shrink: 0;
    font-weight: 700;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    margin-top: 0.12rem;
    color: oklch(0.52 0.14 155);
  }
  .fc-no  { color: var(--rule); font-weight: 400; }
  .fc-spot { color: var(--spot); }
  .feature strong { color: var(--ink); font-weight: 700; }

  .subscribe-label {
    font-size: 0.62rem;
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: 0.5rem;
  }

  #premium-form {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .premium-input {
    font-size: 0.875rem;
    color: var(--ink);
    background: var(--paper);
    border: 1px solid var(--ink);
    padding: 0.7rem 0.9rem;
    outline: none;
    border-radius: 0;
    transition: border-color 0.12s;
    width: 100%;
  }
  .premium-input:focus { border-color: var(--spot); }
  .premium-input::placeholder { color: var(--ink-faint); }

  .premium-btn {
    display: block;
    text-align: center;
    background: var(--spot);
    color: var(--paper-2);
    font-weight: 700;
    font-size: 0.76rem;
    padding: 0.9rem 1.5rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: background 0.18s;
    border: none;
    cursor: pointer;
    width: 100%;
    border-radius: 0;
  }
  .premium-btn:hover:not(:disabled) { background: var(--spot-deep); }
  .premium-btn:disabled { opacity: 0.55; cursor: not-allowed; }

  .premium-error {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: oklch(0.55 0.22 28);
    margin-top: 0.25rem;
  }

  .premium-note {
    text-align: center;
    font-size: 0.62rem;
    color: var(--ink-faint);
    margin-top: 0.5rem;
    letter-spacing: 0.06em;
  }

  /* ── FAQ ── */
  .faq-section { margin-bottom: 2rem; }

  .faq-header {
    padding-bottom: 0.6rem;
    border-bottom: 3px double var(--ink);
    margin-bottom: 1.5rem;
  }

  .faq-heading {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--ink);
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid var(--rule);
    border-top: none;
  }

  .faq-item {
    background: var(--paper);
    padding: 1.4rem 1.6rem;
    border-right: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    transition: background 0.2s;
  }
  .faq-item:nth-child(even) { border-right: none; }
  .faq-item:hover { background: var(--paper-sink); }

  .faq-item h3 {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 0.55rem;
    line-height: 1.35;
  }

  .faq-item p {
    font-size: 0.875rem;
    color: var(--ink-soft);
    line-height: 1.65;
    font-style: italic;
  }

  /* ── Footer ── */
  .site-footer {
    border-top: 3px double var(--ink);
    background: var(--paper-sink);
    padding: 0;
  }

  .foot-top {
    display: grid;
    grid-template-columns: 1.4fr 2fr;
    gap: 2.75rem;
    padding: 2.5rem 0 1.75rem;
  }

  .foot-brand-col { display: flex; flex-direction: column; gap: 0.75rem; }

  .foot-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--ink-soft);
    text-decoration: none;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.15s;
  }
  .foot-logo:hover { color: var(--ink); text-decoration: none; }

  .footer-fc {
    width: 26px; height: 20px;
    background: var(--ink); color: var(--paper);
    font-size: 0.58rem; font-weight: 700;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .foot-tag {
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 38ch;
  }

  .foot-cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .foot-col {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.55rem;
  }

  .foot-col h4 {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 0.2rem;
  }

  .foot-col a, .foot-col span {
    font-size: 0.9rem;
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 0.15s;
  }
  .foot-col a:hover { color: var(--spot); text-decoration: none; }

  .foot-base {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 1rem 0 1.75rem;
    border-top: 1px solid var(--rule);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    color: var(--ink-faint);
    text-transform: uppercase;
  }

  @media (max-width: 800px) {
    .plans-grid {
      grid-template-columns: 1fr;
    }
    .plans-divider {
      flex-direction: row;
      padding: 0 2rem;
      height: 40px;
      border-left: none;
      border-right: none;
      border-top: 1px solid var(--rule);
      border-bottom: 1px solid var(--rule);
    }
    .pd-line { flex: 1; width: auto; height: 1px; }
    .plan-card { padding: 2rem 1.5rem; }
    .plan-badge { top: 0; transform: translate(-50%, -50%); }
    .faq-grid   { grid-template-columns: 1fr; }
    .faq-item   { border-right: none; }
    .foot-top   { grid-template-columns: 1fr; gap: 1.75rem; }
    .foot-cols  { grid-template-columns: repeat(3, 1fr); }
  }

