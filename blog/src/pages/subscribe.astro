---
import Header from '../components/Header.astro';
import SubscribeForm from '../components/SubscribeForm.astro';
import '../styles/global.css';
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="Suscríbete a First Cup y recibe el mejor tech de cada mañana en tu inbox. Gratis, sin spam." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://firstcup.es/subscribe" />
  <meta property="og:title" content="Suscribirse – First Cup" />
  <meta property="og:description" content="Tu café tech de cada mañana. IA, dev y tech curada en tu inbox." />
  <link rel="canonical" href="https://firstcup.es/subscribe" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>Suscribirse – First Cup</title>
</head>

<body>
  <Header />

  <main class="main">
    <div class="container">

      <!-- Page header -->
      <div class="page-header">
        <div class="page-eyebrow">
          <span class="pulse" aria-hidden="true"></span>
          Newsletter · Daily digest
        </div>
        <h1 class="page-title">
          Tu café tech,<br/>
          <em>cada mañana.</em>
        </h1>
        <p class="page-subtitle">
          First Cup analiza automáticamente cientos de fuentes cada día
          y te entrega solo lo que vale la pena. Elige tu plan.
        </p>
      </div>

      <!-- Plans -->
      <div class="plans-grid">

        <!-- Free plan -->
        <div class="plan-card">
          <div class="plan-header">
            <div class="plan-badge free">Gratis</div>
            <div class="plan-price">
              <span class="price-amount">0€</span>
              <span class="price-period">/ siempre</span>
            </div>
          </div>

          <p class="plan-description">
            Acceso completo al blog público y al digest semanal en tu inbox.
            Sin tarjeta. Sin compromiso.
          </p>

          <ul class="plan-features" aria-label="Características del plan gratuito">
            <li class="feature">
              <span class="feature-check" aria-hidden="true">✓</span>
              Blog público con todos los posts
            </li>
            <li class="feature">
              <span class="feature-check" aria-hidden="true">✓</span>
              Email semanal con el resumen tech
            </li>
            <li class="feature">
              <span class="feature-check" aria-hidden="true">✓</span>
              Acceso al archivo histórico completo
            </li>
            <li class="feature">
              <span class="feature-check" aria-hidden="true">✓</span>
              RSS feed para tu lector favorito
            </li>
          </ul>

          <div class="plan-action">
            <p class="subscribe-label">Suscríbete con tu email:</p>
            <SubscribeForm compact={true} />
          </div>
        </div>

        <!-- Premium plan -->
        <div class="plan-card premium">
          <div class="plan-recommended">RECOMENDADO</div>
          <div class="plan-header">
            <div class="plan-badge premium-badge">Premium</div>
            <div class="plan-price">
              <span class="price-amount">9€</span>
              <span class="price-period">/ mes</span>
            </div>
          </div>

          <p class="plan-description">
            Para los profesionales que quieren estar un paso por delante.
            Análisis diarios, canal privado y formación continua.
          </p>

          <ul class="plan-features" aria-label="Características del plan premium">
            <li class="feature">
              <span class="feature-check accent" aria-hidden="true">✓</span>
              Todo lo del plan gratuito
            </li>
            <li class="feature">
              <span class="feature-check accent" aria-hidden="true">✓</span>
              <strong>Daily digest</strong> – análisis profundo cada día laboral
            </li>
            <li class="feature">
              <span class="feature-check accent" aria-hidden="true">✓</span>
              <strong>Telegram privado</strong> – canal exclusivo con breaking news
            </li>
            <li class="feature">
              <span class="feature-check accent" aria-hidden="true">✓</span>
              <strong>Mini cursos</strong> – guías prácticas sobre tendencias tech
            </li>
            <li class="feature">
              <span class="feature-check accent" aria-hidden="true">✓</span>
              Acceso anticipado a nuevas funcionalidades
            </li>
            <li class="feature">
              <span class="feature-check accent" aria-hidden="true">✓</span>
              Sin anuncios, nunca
            </li>
          </ul>

          <div class="plan-action">
            <a
              href="mailto:hola@firstcup.es?subject=Suscripci%C3%B3n%20Premium"
              class="premium-btn"
              aria-label="Empezar plan Premium"
            >
              Empezar plan Premium →
            </a>
            <p class="premium-note">Cancela cuando quieras · Pago seguro</p>
          </div>
        </div>

      </div>

      <!-- FAQ -->
      <section class="faq-section" aria-label="Preguntas frecuentes">
        <h2 class="faq-title">Preguntas frecuentes</h2>
        <div class="faq-grid">
          <div class="faq-item">
            <h3>¿Con qué frecuencia se publica?</h3>
            <p>
              El digest gratuito sale los lunes. El plan Premium
              incluye análisis de lunes a viernes, todos los días laborables.
            </p>
          </div>
          <div class="faq-item">
            <h3>¿Quién escribe el contenido?</h3>
            <p>
              Un agente de IA analiza cientos de fuentes (Hacker News,
              GitHub Trending, ArXiv, feeds RSS) y redacta los análisis,
              que son revisados antes de publicarse.
            </p>
          </div>
          <div class="faq-item">
            <h3>¿Puedo cancelar en cualquier momento?</h3>
            <p>
              Sí, sin permanencia ni penalizaciones. Cancela desde tu cuenta
              o escríbenos y lo gestionamos en 24h.
            </p>
          </div>
          <div class="faq-item">
            <h3>¿Qué temas cubre First Cup?</h3>
            <p>
              Inteligencia artificial, ingeniería de software, herramientas dev,
              tendencias de la industria tech, open source y startups relevantes.
            </p>
          </div>
        </div>
      </section>

    </div>
  </main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <a href="/" class="footer-brand">
        <span class="footer-fc">FC</span>
        First<em>Cup</em>
      </a>
      <span class="footer-copy">© {new Date().getFullYear()} · Hecho con Astro</span>
    </div>
  </footer>
</body>
</html>

<style>
  .main { padding: 3rem 0 5rem; }

  /* ── Page header ── */
  .page-header {
    text-align: center;
    max-width: 560px;
    margin: 0 auto 4rem;
  }

  .page-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    font-family: var(--font-mono);
    font-size: .63rem;
    color: var(--amber);
    letter-spacing: .08em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    background: var(--amber-dim);
    border: 1px solid rgba(201,165,116,.28);
    border-radius: 100px;
    padding: .34rem .8rem;
  }

  .pulse {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--amber);
    animation: breathe 2.5s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes breathe {
    0%,100% { transform:scale(1); opacity:1; }
    50%      { transform:scale(.6); opacity:.4; }
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: var(--text);
    line-height: 1.15;
    letter-spacing: -.02em;
    margin-bottom: 1rem;
  }
  .page-title em { font-style: italic; color: var(--amber); }

  .page-subtitle {
    font-size: 1rem;
    color: var(--text-2);
    line-height: 1.7;
  }

  /* ── Plans grid ── */
  .plans-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 5rem;
  }

  .plan-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 2rem;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    transition: border-color .2s;
  }
  .plan-card:hover { border-color: rgba(201,165,116,.2); }

  .plan-card.premium {
    background: var(--surface);
    border-color: rgba(201,165,116,.25);
  }
  .plan-card.premium:hover { border-color: rgba(201,165,116,.45); }

  .plan-recommended {
    position: absolute;
    top: -.85rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--accent);
    color: var(--bg);
    font-family: var(--font-mono);
    font-size: .6rem;
    font-weight: 700;
    letter-spacing: .12em;
    padding: .22rem .75rem;
    border-radius: 9999px;
    white-space: nowrap;
  }

  .plan-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .plan-badge {
    font-family: var(--font-mono);
    font-size: .67rem;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    padding: .22rem .58rem;
    border-radius: 5px;
  }

  .plan-badge.free {
    background: rgba(184,168,152,.1);
    color: var(--text-2);
    border: 1px solid var(--border);
  }

  .plan-badge.premium-badge {
    background: var(--amber-dim);
    color: var(--amber);
    border: 1px solid rgba(201,165,116,.3);
  }

  .plan-price { text-align: right; }

  .price-amount {
    display: block;
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1;
    letter-spacing: -.02em;
  }

  .price-period {
    font-family: var(--font-mono);
    font-size: .72rem;
    color: var(--text-3);
  }

  .plan-description {
    font-size: .875rem;
    color: var(--text-2);
    line-height: 1.65;
  }

  .plan-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: .65rem;
    flex: 1;
  }

  .feature {
    display: flex;
    align-items: flex-start;
    gap: .6rem;
    font-size: .875rem;
    color: var(--text);
    line-height: 1.5;
  }

  .feature-check {
    flex-shrink: 0;
    color: #5fb87a;
    font-weight: 700;
    margin-top: .05rem;
  }
  .feature-check.accent { color: var(--amber); }
  .feature strong { color: var(--text); }

  .subscribe-label {
    font-family: var(--font-mono);
    font-size: .67rem;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: .05em;
    margin-bottom: .6rem;
  }

  .premium-btn {
    display: block;
    text-align: center;
    background: var(--accent);
    color: var(--bg);
    font-weight: 700;
    font-size: .9rem;
    padding: .85rem 1.5rem;
    border-radius: 10px;
    transition: opacity .15s, transform .25s var(--spring);
    text-decoration: none;
    width: 100%;
  }
  .premium-btn:hover { opacity: .85; transform: translateY(-1px); text-decoration: none; }

  .premium-note {
    text-align: center;
    font-family: var(--font-mono);
    font-size: .67rem;
    color: var(--text-3);
    margin-top: .55rem;
    letter-spacing: .02em;
  }

  /* ── FAQ ── */
  .faq-section { margin-bottom: 2rem; }

  .faq-title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -.01em;
    margin-bottom: 1.5rem;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .faq-item {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    transition: border-color .2s;
  }
  .faq-item:hover { border-color: rgba(201,165,116,.22); }

  .faq-item h3 {
    font-family: var(--font-display);
    font-size: .95rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: .55rem;
    line-height: 1.35;
  }

  .faq-item p {
    font-size: .85rem;
    color: var(--text-2);
    line-height: 1.65;
  }

  /* ── Footer ── */
  .site-footer { border-top: 1px solid var(--border); padding: 1.5rem 0; }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: .45rem;
    font-family: var(--font-display);
    font-size: .88rem;
    font-weight: 700;
    color: var(--text-2);
    text-decoration: none;
    transition: color .15s;
  }
  .footer-brand:hover { color: var(--text); text-decoration: none; }
  .footer-brand em { font-style: italic; color: var(--amber); }

  .footer-fc {
    width: 26px; height: 20px;
    background: var(--accent);
    color: var(--bg);
    font-family: var(--font-body);
    font-size: .58rem;
    font-weight: 700;
    border-radius: 3px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .footer-copy { font-size: .75rem; color: var(--text-3); }

  @media (max-width: 800px) {
    .plans-grid { grid-template-columns: 1fr; }
    .faq-grid   { grid-template-columns: 1fr; }
  }
</style>
