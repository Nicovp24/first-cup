---
import Header from '../components/Header.astro';
import SubscribeForm from '../components/SubscribeForm.astro';
import SEO from '../components/SEO.astro';
import '../styles/global.css';

const SITE = (Astro.site?.toString() ?? 'https://first-cup-kappa.vercel.app').replace(/\/$/, '');
---

<!doctype html>
<html lang="es" data-theme="latte">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>Suscribirse gratis – First Cup</title>
  <SEO
    title="Suscribirse gratis – First Cup | Digest tech diario"
    description="Recibe cada mañana el mejor tech en tu inbox: IA, GitHub, papers, dev tools. Gratis, sin spam, cancela cuando quieras."
    canonical={`${SITE}/subscribe`}
    type="website"
  />
</head>

<body>
  <Header />

  <main class="main">
    <div class="container">

      <!-- Page header -->
      <div class="page-header anim-up">
        <div class="header-rule-top" aria-hidden="true"></div>
        <span class="kicker">Newsletter · Daily digest</span>
        <h1 class="page-title">
          Tu café tech,<br/>
          <em>cada mañana.</em>
        </h1>
        <p class="page-subtitle">
          First Cup analiza automáticamente cientos de fuentes cada día
          y te entrega solo lo que vale la pena — sin ruido, sin spam.
        </p>
      </div>

      <!-- Stats strip -->
      <div class="stats-strip anim-up" style="animation-delay:60ms" aria-label="Métricas del digest">
        <div class="stat-item">
          <span class="stat-num">500+</span>
          <span class="stat-label gz-mono">Fuentes analizadas</span>
        </div>
        <span class="stat-sep" aria-hidden="true">·</span>
        <div class="stat-item">
          <span class="stat-num">2×</span>
          <span class="stat-label gz-mono">Al día</span>
        </div>
        <span class="stat-sep" aria-hidden="true">·</span>
        <div class="stat-item">
          <span class="stat-num">6</span>
          <span class="stat-label gz-mono">Posts por edición</span>
        </div>
        <span class="stat-sep" aria-hidden="true">·</span>
        <div class="stat-item">
          <span class="stat-num">0€</span>
          <span class="stat-label gz-mono">Para empezar</span>
        </div>
      </div>

      <!-- Plans -->
      <div class="plans-wrap anim-up" style="animation-delay:80ms">

        <div class="plans-grid">

          <!-- Free plan -->
          <div class="plan-card">
            <div class="plan-ornament gz-mono" aria-hidden="true">— ✦ —</div>
            <div class="plan-tier gz-mono">Lector</div>
            <div class="plan-price">
              <span class="price-amount">0<span class="price-cur">€</span></span>
              <span class="price-period gz-mono">para siempre</span>
            </div>
            <p class="plan-description">
              Acceso completo al blog y al digest en tu inbox.
              Sin tarjeta, sin compromiso.
            </p>
            <ul class="plan-features" aria-label="Características del plan gratuito">
              <li class="feature"><span class="fc" aria-hidden="true">✓</span>Blog público con todos los posts</li>
              <li class="feature"><span class="fc" aria-hidden="true">✓</span>Archivo histórico completo</li>
              <li class="feature"><span class="fc" aria-hidden="true">✓</span>RSS feed para tu lector favorito</li>
              <li class="feature fc-empty"><span class="fc fc-no" aria-hidden="true">–</span>Digest diario en el inbox</li>
              <li class="feature fc-empty"><span class="fc fc-no" aria-hidden="true">–</span>☕ Shots del día</li>
              <li class="feature fc-empty"><span class="fc fc-no" aria-hidden="true">–</span>Alertas breaking news</li>
              <li class="feature fc-empty"><span class="fc fc-no" aria-hidden="true">–</span>Resumen semanal</li>
            </ul>
            <div class="plan-action">
              <p class="subscribe-label gz-mono">Tu email:</p>
              <SubscribeForm compact={true} />
            </div>
          </div>

          <!-- Premium plan -->
          <div class="plan-card plan-premium">
            <div class="plan-glow" aria-hidden="true"></div>
            <div class="plan-badge">⭐ Recomendado</div>
            <div class="plan-ornament plan-ornament--spot gz-mono" aria-hidden="true">— ✦ —</div>
            <div class="plan-tier gz-mono plan-tier--spot">Premium</div>
            <div class="plan-price">
              <span class="price-amount price-amount--spot">5<span class="price-cur">€</span></span>
              <span class="price-period gz-mono">al mes</span>
            </div>
            <p class="plan-description">
              Para quienes quieren estar un paso por delante.
              Análisis diarios, formación práctica y sin anuncios.
            </p>
            <ul class="plan-features" aria-label="Características del plan premium">
              <li class="feature"><span class="fc fc-spot" aria-hidden="true">✓</span>Blog público completo</li>
              <li class="feature"><span class="fc fc-spot" aria-hidden="true">✓</span><strong>Digest diario en tu inbox</strong> — 6 artículos cada mañana a las 07:00</li>
              <li class="feature"><span class="fc fc-spot" aria-hidden="true">✓</span><strong>☕ Shots del día</strong> — micro-dosis de lo que también pasó, en segundos</li>
              <li class="feature"><span class="fc fc-spot" aria-hidden="true">✓</span><strong>Alertas breaking news</strong> — email instantáneo cuando hay algo urgente</li>
              <li class="feature"><span class="fc fc-spot" aria-hidden="true">✓</span><strong>Resumen semanal</strong> — lo mejor de la semana, cada domingo</li>
              <li class="feature"><span class="fc fc-spot" aria-hidden="true">✓</span>Sin anuncios, nunca · Cancela cuando quieras</li>
            </ul>
            <div class="plan-action">
              <form id="premium-form" novalidate>
                <label for="premium-email" class="subscribe-label gz-mono">Tu email:</label>
                <input
                  id="premium-email"
                  type="email"
                  name="email"
                  placeholder="tu@email.com"
                  autocomplete="email"
                  required
                  class="premium-input gz-mono"
                />
                <button type="submit" class="premium-btn" id="premium-btn">
                  <span class="premium-btn-text">Empezar Premium
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="btn-arrow"><path d="M2.5 7h9M9 3.5L12.5 7 9 10.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </span>
                  <span class="premium-btn-loading" hidden>Redirigiendo…</span>
                </button>
              </form>
              <p class="premium-error gz-mono" id="premium-error" role="alert" hidden></p>
              <p class="premium-note gz-mono">Pago seguro con Stripe</p>
            </div>
          </div>

        </div>
      </div>

      <!-- FAQ -->
      <section class="faq-section" aria-label="Preguntas frecuentes">
        <div class="faq-header">
          <h2 class="faq-heading gz-mono">Preguntas frecuentes</h2>
        </div>
        <div class="faq-grid">
          <div class="faq-item">
            <h3>¿Con qué frecuencia se publica?</h3>
            <p>
              El digest se publica dos veces al día. El plan Premium
              incluye el email diario con análisis en profundidad.
            </p>
          </div>
          <div class="faq-item">
            <h3>¿Quién escribe el contenido?</h3>
            <p>
              Un agente de IA analiza cientos de fuentes (Hacker News,
              GitHub Trending, ArXiv, feeds RSS) y redacta los análisis,
              que son revisados antes de publicarse.
            </p>
          </div>
          <div class="faq-item">
            <h3>¿Puedo cancelar en cualquier momento?</h3>
            <p>
              Sí, sin permanencia ni penalizaciones. Cancela desde tu cuenta
              o escríbenos y lo gestionamos en 24h.
            </p>
          </div>
          <div class="faq-item">
            <h3>¿Qué temas cubre First Cup?</h3>
            <p>
              Inteligencia artificial, ingeniería de software, herramientas dev,
              tendencias de la industria tech, open source y startups relevantes.
            </p>
          </div>
        </div>
      </section>

    </div>
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="foot-top">
        <div class="foot-brand-col">
          <a href="/" class="foot-logo gz-mono">
            <span class="footer-fc">FC</span>
            First Cup
          </a>
          <p class="foot-tag">El diario del café tech. IA, desarrollo y tecnología curada cada mañana por un agente.</p>
        </div>
        <div class="foot-cols">
          <div class="foot-col">
            <h4 class="gz-mono">Contenido</h4>
            <a href="/">Posts</a>
            <a href="/subscribe">Newsletter</a>
            <a href="/rss.xml">RSS</a>
          </div>
          <div class="foot-col">
            <h4 class="gz-mono">Legal</h4>
            <a href="/privacidad">Privacidad</a>
            <a href="/terminos">Términos</a>
          </div>
          <div class="foot-col">
            <h4 class="gz-mono">Contacto</h4>
            <a href="mailto:hola@first-cup.es">hola@first-cup.es</a>
          </div>
        </div>
      </div>
      <div class="foot-base gz-mono">
        <span>© {new Date().getFullYear()} First Cup</span>
        <span>Hecho con Astro · IA generativa</span>
      </div>
    </div>
  </footer>
</body>
</html>

<script>
  const saved = localStorage.getItem('theme') ?? 'latte';
  document.documentElement.setAttribute('data-theme', saved);

  // ── Premium checkout form ──
  const premiumForm = document.getElementById('premium-form') as HTMLFormElement | null;
  if (premiumForm) {
    premiumForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input   = premiumForm.querySelector<HTMLInputElement>('#premium-email');
      const btn     = premiumForm.querySelector<HTMLButtonElement>('#premium-btn');
      const btnText = premiumForm.querySelector<HTMLElement>('.premium-btn-text');
      const btnLoad = premiumForm.querySelector<HTMLElement>('.premium-btn-loading');
      const errEl   = document.getElementById('premium-error') as HTMLElement | null;
      if (!input || !errEl) return;

      const email = input.value.trim();
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        errEl.textContent = 'Introduce un email válido.';
        errEl.hidden = false;
        input.focus();
        return;
      }
      errEl.hidden = true;
      if (btn) btn.disabled = true;
      if (btnText) btnText.hidden = true;
      if (btnLoad) btnLoad.hidden = false;

      try {
        const res = await fetch('/api/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        const data = await res.json() as { url?: string; message?: string };
        if (!res.ok || !data.url) throw new Error(data.message ?? `Error ${res.status}`);
        window.location.href = data.url;
      } catch (err: unknown) {
        errEl.textContent = err instanceof Error ? err.message : 'Algo salió mal. Inténtalo de nuevo.';
        errEl.hidden = false;
        if (btn) btn.disabled = false;
        if (btnText) btnText.hidden = false;
        if (btnLoad) btnLoad.hidden = true;
      }
    });
  }
</script>

<style>
  .main { padding: 3rem 0 5rem; }

  /* ── Page header ── */
  .page-header {
    max-width: 600px;
    margin: 0 auto 4rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }
  .header-rule-top {
    width: 60px; height: 3px;
    background: linear-gradient(90deg, transparent, var(--spot), transparent);
    margin-bottom: 0.5rem;
  }
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 800;
    color: var(--ink);
    line-height: 1.1;
    letter-spacing: -0.022em;
  }
  .page-title em { font-style: normal; color: var(--spot); font-weight: 400; }
  .page-subtitle {
    font-size: 1rem;
    color: var(--ink-soft);
    line-height: 1.7;
  }

  /* ── Stats strip ── */
  .stats-strip {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    border-top: 3px double var(--ink);
    border-bottom: 1px solid var(--rule);
    padding: 1.4rem 0 1.5rem;
    margin-bottom: 4rem;
  }
  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }
  .stat-num {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--spot);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .stat-label {
    font-size: 0.6rem;
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .stat-sep {
    color: var(--rule);
    font-size: 1.4rem;
    line-height: 1;
    align-self: center;
  }

  /* ── Plans ── */
  .plans-wrap { margin-bottom: 5rem; }

  .plans-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  /* ── Plan card base ── */
  .plan-card {
    background: var(--paper);
    border: 1px solid var(--rule);
    border-radius: 16px;
    padding: 2.5rem 2.25rem;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    transition: transform 0.3s cubic-bezier(.16,1,.3,1), box-shadow 0.3s;
    overflow: hidden;
  }
  .plan-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px oklch(0 0 0 / .08);
  }

  /* ── Premium card ── */
  .plan-premium {
    background: var(--paper-sink);
    border-color: oklch(from var(--spot) l c h / .4);
    box-shadow:
      0 0 0 1px oklch(from var(--spot) l c h / .12),
      0 8px 24px oklch(from var(--spot) l c h / .1);
  }
  .plan-premium:hover {
    transform: translateY(-4px);
    box-shadow:
      0 0 0 1px oklch(from var(--spot) l c h / .3),
      0 16px 40px oklch(from var(--spot) l c h / .18);
  }

  /* Gradient glow overlay for premium */
  .plan-glow {
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    background: linear-gradient(
      135deg,
      oklch(from var(--spot) l c h / .08) 0%,
      transparent 55%
    );
    pointer-events: none;
    z-index: 0;
  }

  /* Accent top stripe on premium */
  .plan-premium::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--spot), var(--spot-deep));
    border-radius: 16px 16px 0 0;
    z-index: 1;
  }

  /* Make sure content is above glow */
  .plan-card > *:not(.plan-glow) { position: relative; z-index: 1; }

  /* ── Plan badge ── */
  .plan-badge {
    position: absolute;
    top: -1px; right: 1.5rem;
    background: var(--spot);
    color: var(--paper);
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    padding: 0.3rem 0.9rem;
    border-radius: 0 0 10px 10px;
    white-space: nowrap;
    animation: badge-pop 0.5s cubic-bezier(.16,1,.3,1) both;
    animation-delay: 200ms;
  }
  @keyframes badge-pop {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .plan-ornament {
    text-align: center;
    font-size: 0.62rem;
    color: var(--rule);
    letter-spacing: 0.25em;
    margin-bottom: -0.5rem;
  }
  .plan-ornament--spot { color: oklch(from var(--spot) l c h / .45); }

  .plan-tier {
    text-align: center;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-soft);
    font-family: 'Inter', system-ui, sans-serif;
  }
  .plan-tier--spot { color: var(--spot); }

  .plan-price {
    text-align: center;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding: 1.1rem 0;
  }
  .price-amount {
    display: block;
    font-family: var(--font-display);
    font-size: 3.5rem;
    font-weight: 900;
    color: var(--ink);
    line-height: 1;
    letter-spacing: -0.03em;
  }
  .price-amount--spot { color: var(--spot); }
  .price-cur {
    font-size: 1.6rem;
    font-weight: 700;
    vertical-align: super;
    letter-spacing: 0;
    margin-left: 2px;
  }
  .price-period {
    display: block;
    font-size: 0.62rem;
    color: var(--ink-faint);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-top: 0.4rem;
    font-family: 'Inter', system-ui, sans-serif;
  }

  .plan-description {
    font-size: 0.875rem;
    color: var(--ink-soft);
    line-height: 1.68;
    text-align: center;
  }

  .plan-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    flex: 1;
    border-top: 1px solid var(--rule-soft);
    padding-top: 1.25rem;
  }
  .feature {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    font-size: 0.875rem;
    color: var(--ink);
    line-height: 1.5;
  }
  .fc-empty { color: var(--ink-faint); }
  .fc {
    flex-shrink: 0;
    font-weight: 700;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    margin-top: 0.12rem;
    color: oklch(0.52 0.14 155);
  }
  .fc-no  { color: var(--rule); font-weight: 400; }
  .fc-spot { color: var(--spot); }
  .feature strong { color: var(--ink); font-weight: 700; }

  /* ── Plan action area ── */
  .subscribe-label {
    font-size: 0.62rem;
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: 0.5rem;
    font-family: 'Inter', system-ui, sans-serif;
  }

  #premium-form {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .premium-input {
    font-size: 0.88rem;
    font-family: 'Inter', system-ui, sans-serif;
    color: var(--ink);
    background: var(--paper);
    border: 1px solid var(--rule);
    padding: 0.72rem 1rem;
    outline: none;
    border-radius: 10px;
    width: 100%;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .premium-input:focus {
    border-color: oklch(from var(--spot) l c h / .7);
    box-shadow: 0 0 0 3px oklch(from var(--spot) l c h / .14);
  }
  .premium-input::placeholder { color: var(--ink-faint); }

  /* ── Premium CTA button ── */
  .premium-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    background: var(--spot);
    color: var(--paper);
    font-weight: 700;
    font-size: 0.82rem;
    font-family: 'Inter', system-ui, sans-serif;
    letter-spacing: 0.03em;
    padding: 0.9rem 1.5rem;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    width: 100%;
    overflow: hidden;
    transition: background 0.2s, transform 0.2s cubic-bezier(.16,1,.3,1), box-shadow 0.2s;
  }
  .premium-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, transparent 35%, oklch(1 0 0 / .25) 50%, transparent 65%);
    transform: translateX(-100%);
    transition: transform 0.5s cubic-bezier(.16,1,.3,1);
  }
  .premium-btn:hover:not(:disabled) {
    background: var(--spot-deep);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px oklch(from var(--spot) l c h / .4);
  }
  .premium-btn:hover::before { transform: translateX(100%); }
  .premium-btn:disabled { opacity: 0.55; cursor: not-allowed; }

  .premium-btn-text {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .btn-arrow {
    transition: transform 0.2s cubic-bezier(.16,1,.3,1);
  }
  .premium-btn:hover .btn-arrow { transform: translateX(3px); }

  .premium-error {
    font-size: 0.76rem;
    font-family: 'Inter', system-ui, sans-serif;
    color: oklch(0.55 0.22 28);
  }

  .premium-note {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    text-align: center;
    font-size: 0.66rem;
    font-family: 'Inter', system-ui, sans-serif;
    color: var(--ink-faint);
    margin-top: 0.25rem;
    letter-spacing: 0.03em;
  }
  .premium-note::before {
    content: '🔒';
    font-size: 0.7rem;
  }

  /* ── FAQ ── */
  .faq-section { margin-bottom: 2rem; }
  .faq-header {
    padding-bottom: 0.6rem;
    border-bottom: 3px double var(--ink);
    margin-bottom: 1.5rem;
  }
  .faq-heading {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--ink);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-family: 'Inter', system-ui, sans-serif;
  }
  .faq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .faq-item {
    background: var(--paper);
    border: 1px solid var(--rule-soft);
    border-radius: 12px;
    padding: 1.4rem 1.6rem;
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
  }
  .faq-item:hover {
    background: var(--paper-sink);
    border-color: oklch(from var(--spot) l c h / .3);
    transform: translateY(-2px);
  }
  .faq-item h3 {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 0.55rem;
    line-height: 1.35;
  }
  .faq-item p {
    font-size: 0.875rem;
    color: var(--ink-soft);
    line-height: 1.65;
