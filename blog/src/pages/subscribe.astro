---
import Header from '../components/Header.astro';
import SubscribeForm from '../components/SubscribeForm.astro';
import SEO from '../components/SEO.astro';
import '../styles/global.css';

const SITE = (Astro.site?.toString() ?? 'https://first-cup-kappa.vercel.app').replace(/\/$/, '');
---

<!doctype html>
<html lang="es" data-theme="latte">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>Suscribirse gratis – First Cup</title>
  <SEO
    title="Suscribirse gratis – First Cup | Digest tech diario"
    description="Recibe cada mañana el mejor tech en tu inbox: IA, GitHub, papers, dev tools. Gratis, sin spam, cancela cuando quieras."
    canonical={`${SITE}/subscribe`}
    type="website"
  />
</head>

<body>
  <Header />

  <main class="main">
    <div class="container">

      <!-- Page header -->
      <div class="page-header anim-up">
        <div class="header-rule-top" aria-hidden="true"></div>
        <span class="kicker">Newsletter · Daily digest</span>
        <h1 class="page-title">
          Tu café tech,<br/>
          <em>cada mañana.</em>
        </h1>
        <p class="page-subtitle">
          First Cup analiza automáticamente cientos de fuentes cada día
          y te entrega solo lo que vale la pena — sin ruido, sin spam.
        </p>
      </div>

      <!-- Stats strip -->
      <div class="stats-strip anim-up" style="animation-delay:60ms" aria-label="Métricas del digest">
        <div class="stat-item">
          <span class="stat-num">500+</span>
          <span class="stat-label gz-mono">Fuentes analizadas</span>
        </div>
        <span class="stat-sep" aria-hidden="true">·</span>
        <div class="stat-item">
          <span class="stat-num">2×</span>
          <span class="stat-label gz-mono">Al día</span>
        </div>
        <span class="stat-sep" aria-hidden="true">·</span>
        <div class="stat-item">
          <span class="stat-num">6</span>
          <span class="stat-label gz-mono">Posts por edición</span>
        </div>
        <span class="stat-sep" aria-hidden="true">·</span>
        <div class="stat-item">
          <span class="stat-num">0€</span>
          <span class="stat-label gz-mono">Para empezar</span>
        </div>
      </div>

      <!-- Plans -->
      <div class="plans-grid">

        <!-- Free plan -->
        <div class="plan-card anim-up" style="animation-delay:80ms">
          <div class="plan-header">
            <span class="kicker plan-kicker">Gratis</span>
            <div class="plan-price">
              <span class="price-amount">0€</span>
              <span class="price-period gz-mono">/ siempre</span>
            </div>
          </div>

          <p class="plan-description">
            Acceso completo al blog público y al digest semanal en tu inbox.
            Sin tarjeta. Sin compromiso.
          </p>

          <ul class="plan-features" aria-label="Características del plan gratuito">
            <li class="feature">
              <span class="feature-check" aria-hidden="true">✓</span>
              Blog público con todos los posts
            </li>
            <li class="feature">
              <span class="feature-check" aria-hidden="true">✓</span>
              Email semanal con el resumen tech
            </li>
            <li class="feature">
              <span class="feature-check" aria-hidden="true">✓</span>
              Acceso al archivo histórico completo
            </li>
            <li class="feature">
              <span class="feature-check" aria-hidden="true">✓</span>
              RSS feed para tu lector favorito
            </li>
          </ul>

          <div class="plan-action">
            <p class="subscribe-label gz-mono">Suscríbete con tu email:</p>
            <SubscribeForm compact={true} />
          </div>
        </div>

        <!-- Premium plan -->
        <div class="plan-card plan-premium anim-up" style="animation-delay:140ms">
          <div class="plan-recommended gz-mono">RECOMENDADO</div>
          <div class="plan-header">
            <span class="kicker plan-kicker premium-kicker">Premium</span>
            <div class="plan-price">
              <span class="price-amount">9€</span>
              <span class="price-period gz-mono">/ mes</span>
            </div>
          </div>

          <p class="plan-description">
            Para los profesionales que quieren estar un paso por delante.
            Análisis diarios, canal privado y formación continua.
          </p>

          <ul class="plan-features" aria-label="Características del plan premium">
            <li class="feature">
              <span class="feature-check feature-spot" aria-hidden="true">✓</span>
              Todo lo del plan gratuito
            </li>
            <li class="feature">
              <span class="feature-check feature-spot" aria-hidden="true">✓</span>
              <strong>Daily digest</strong> – análisis profundo cada día laboral
            </li>
            <li class="feature">
              <span class="feature-check feature-spot" aria-hidden="true">✓</span>
              <strong>Telegram privado</strong> – canal exclusivo con breaking news
            </li>
            <li class="feature">
              <span class="feature-check feature-spot" aria-hidden="true">✓</span>
              <strong>Mini cursos</strong> – guías prácticas sobre tendencias tech
            </li>
            <li class="feature">
              <span class="feature-check feature-spot" aria-hidden="true">✓</span>
              Acceso anticipado a nuevas funcionalidades
            </li>
            <li class="feature">
              <span class="feature-check feature-spot" aria-hidden="true">✓</span>
              Sin anuncios, nunca
            </li>
          </ul>

          <div class="plan-action">
            <a
              href="mailto:hola@firstcup.es?subject=Suscripci%C3%B3n%20Premium"
              class="premium-btn gz-mono"
              aria-label="Empezar plan Premium"
            >
              Empezar plan Premium →
            </a>
            <p class="premium-note gz-mono">Cancela cuando quieras · Pago seguro</p>
          </div>
        </div>

      </div>

      <!-- FAQ -->
      <section class="faq-section" aria-label="Preguntas frecuentes">
        <div class="faq-header">
          <h2 class="faq-heading gz-mono">Preguntas frecuentes</h2>
        </div>
        <div class="faq-grid">
          <div class="faq-item">
            <h3>¿Con qué frecuencia se publica?</h3>
            <p>
              El digest gratuito sale los lunes. El plan Premium
              incluye análisis de lunes a viernes, todos los días laborables.
            </p>
          </div>
          <div class="faq-item">
            <h3>¿Quién escribe el contenido?</h3>
            <p>
              Un agente de IA analiza cientos de fuentes (Hacker News,
              GitHub Trending, ArXiv, feeds RSS) y redacta los análisis,
              que son revisados antes de publicarse.
            </p>
          </div>
          <div class="faq-item">
            <h3>¿Puedo cancelar en cualquier momento?</h3>
            <p>
              Sí, sin permanencia ni penalizaciones. Cancela desde tu cuenta
              o escríbenos y lo gestionamos en 24h.
            </p>
          </div>
          <div class="faq-item">
            <h3>¿Qué temas cubre First Cup?</h3>
            <p>
              Inteligencia artificial, ingeniería de software, herramientas dev,
              tendencias de la industria tech, open source y startups relevantes.
            </p>
          </div>
        </div>
      </section>

    </div>
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="foot-top">
        <div class="foot-brand-col">
          <a href="/" class="foot-logo gz-mono">
            <span class="footer-fc">FC</span>
            First Cup
          </a>
          <p class="foot-tag">El diario del café tech. IA, desarrollo y tecnología curada cada mañana por un agente.</p>
        </div>
        <div class="foot-cols">
          <div class="foot-col">
            <h4 class="gz-mono">Contenido</h4>
            <a href="/">Posts</a>
            <a href="/subscribe">Newsletter</a>
            <a href="/rss.xml">RSS</a>
          </div>
          <div class="foot-col">
            <h4 class="gz-mono">Plataforma</h4>
            <span>First Cup AI</span>
            <span>Astro SSG</span>
          </div>
          <div class="foot-col">
            <h4 class="gz-mono">Contacto</h4>
            <a href="mailto:hola@firstcup.es">hola@firstcup.es</a>
          </div>
        </div>
      </div>
      <div class="foot-base gz-mono">
        <span>© {new Date().getFullYear()} First Cup</span>
        <span>Hecho con Astro · IA generativa</span>
      </div>
    </div>
  </footer>
</body>
</html>

<script>
  const saved = localStorage.getItem('theme') ?? 'latte';
  document.documentElement.setAttribute('data-theme', saved);
</script>

<style>
  .main { padding: 3rem 0 5rem; }

  /* ── Page header ── */
  .page-header {
    max-width: 600px;
    margin: 0 auto 4rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .header-rule-top {
    width: 60px;
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--spot), transparent);
    margin-bottom: 0.5rem;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 800;
    color: var(--ink);
    line-height: 1.1;
    letter-spacing: -0.022em;
  }
  .page-title em { font-style: italic; color: var(--spot); font-weight: 400; }

  .page-subtitle {
    font-size: 1rem;
    color: var(--ink-soft);
    line-height: 1.7;
    font-style: italic;
  }

  /* ── Stats strip ── */
  .stats-strip {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    border-top: 3px double var(--ink);
    border-bottom: 1px solid var(--rule);
    padding: 1.4rem 0 1.5rem;
    margin-bottom: 4rem;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }

  .stat-num {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--spot);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .stat-label {
    font-size: 0.6rem;
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .stat-sep {
    color: var(--rule);
    font-size: 1.4rem;
    line-height: 1;
    align-self: center;
  }

  /* ── Plans grid ── */
  .plans-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    margin-bottom: 5rem;
    border: 1px solid var(--ink);
    border-top: 3px double var(--ink);
  }

  .plan-card {
    background: var(--paper);
    padding: 2rem;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    border-right: 1px solid var(--rule);
    transition: background 0.2s;
  }
  .plan-card:last-child { border-right: none; }
  .plan-card:hover { background: var(--paper-sink); }

  .plan-premium {
    background: var(--paper-sink);
  }
  .plan-premium:hover { background: var(--paper-2); }

  .plan-recommended {
    position: absolute;
    top: -1rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--ink);
    color: var(--paper);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    padding: 0.2rem 0.75rem;
    white-space: nowrap;
    border-radius: 0;
  }

  .plan-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .plan-kicker { font-size: 0.7rem; }
  .premium-kicker { color: var(--spot); }

  .plan-price { text-align: right; }

  .price-amount {
    display: block;
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--ink);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .price-period {
    font-size: 0.68rem;
    color: var(--ink-faint);
  }

  .plan-description {
    font-size: 0.88rem;
    color: var(--ink-soft);
    line-height: 1.65;
    font-style: italic;
  }

  .plan-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1;
  }

  .feature {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.88rem;
    color: var(--ink);
    line-height: 1.5;
  }

  .feature-check {
    flex-shrink: 0;
    color: oklch(0.55 0.14 155);
    font-weight: 700;
    margin-top: 0.05rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }
  .feature-spot { color: var(--spot); }
  .feature strong { color: var(--ink); }

  .subscribe-label {
    font-size: 0.65rem;
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.55rem;
  }

  .premium-btn {
    display: block;
    text-align: center;
    background: var(--spot);
    color: var(--paper-2);
    font-weight: 700;
    font-size: 0.78rem;
    padding: 0.85rem 1.5rem;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    transition: background 0.18s, color 0.18s;
    text-decoration: none;
    width: 100%;
    border-radius: 0;
  }
  .premium-btn:hover { background: var(--spot-deep); color: var(--paper-2); text-decoration: none; }

  .premium-note {
    text-align: center;
    font-size: 0.64rem;
    color: var(--ink-faint);
    margin-top: 0.5rem;
    letter-spacing: 0.04em;
  }

  /* ── FAQ ── */
  .faq-section { margin-bottom: 2rem; }

  .faq-header {
    padding-bottom: 0.6rem;
    border-bottom: 3px double var(--ink);
    margin-bottom: 1.5rem;
  }

  .faq-heading {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--ink);
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid var(--rule);
    border-top: none;
  }

  .faq-item {
    background: var(--paper);
    padding: 1.4rem 1.6rem;
    border-right: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    transition: background 0.2s;
  }
  .faq-item:nth-child(even) { border-right: none; }
  .faq-item:hover { background: var(--paper-sink); }

  .faq-item h3 {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 0.55rem;
    line-height: 1.35;
  }

  .faq-item p {
    font-size: 0.875rem;
    color: var(--ink-soft);
    line-height: 1.65;
    font-style: italic;
  }

  /* ── Footer ── */
  .site-footer {
    border-top: 3px double var(--ink);
    background: var(--paper-sink);
    padding: 0;
  }

  .foot-top {
    display: grid;
    grid-template-columns: 1.4fr 2fr;
    gap: 2.75rem;
    padding: 2.5rem 0 1.75rem;
  }

  .foot-brand-col { display: flex; flex-direction: column; gap: 0.75rem; }

  .foot-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--ink-soft);
    text-decoration: none;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.15s;
  }
  .foot-logo:hover { color: var(--ink); text-decoration: none; }

  .footer-fc {
    width: 26px; height: 20px;
    background: var(--ink); color: var(--paper);
    font-size: 0.58rem; font-weight: 700;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .foot-tag {
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 38ch;
  }

  .foot-cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .foot-col {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.55rem;
  }

  .foot-col h4 {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 0.2rem;
  }

  .foot-col a, .foot-col span {
    font-size: 0.9rem;
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 0.15s;
  }
  .foot-col a:hover { color: var(--spot); text-decoration: none; }

  .foot-base {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 1rem 0 1.75rem;
    border-top: 1px solid var(--rule);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    color: var(--ink-faint);
    text-transform: uppercase;
  }

  @media (max-width: 800px) {
    .plans-grid { grid-template-columns: 1fr; }
    .plan-card { border-right: none; border-bottom: 1px solid var(--rule); }
    .plan-card:last-child { border-bottom: none; }
    .faq-grid   { grid-template-columns: 1fr; }
    .faq-item   { border-right: none; }
    .foot-top   { grid-template-columns: 1fr; gap: 1.75rem; }
    .foot-cols  { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 640px) {
    .foot-cols { grid-template-columns: 1fr 1fr; }
  }
</style>
