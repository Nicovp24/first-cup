---
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
---

<div class="subscribe-wrapper">
  <form
    id="subscribe-form"
    class="subscribe-form"
    novalidate
    aria-label="Formulario de suscripción"
  >
    <div class="form-row">
      <label for="email-input" class="sr-only">Tu dirección de email</label>
      <input
        id="email-input"
        type="email"
        name="email"
        placeholder="tu@email.com"
        autocomplete="email"
        required
        class="email-input"
      />
      <button type="submit" class="submit-btn">
        <span class="btn-text">Suscribirme</span>
        <span class="btn-loading" hidden>Enviando…</span>
      </button>
    </div>
    <p class="form-error" id="form-error" role="alert" hidden></p>
  </form>

  <div
    id="subscribe-success"
    class="subscribe-success"
    role="status"
    aria-live="polite"
    hidden
  >
    <span class="success-check" aria-hidden="true">✓</span>
    <div>
      <strong>¡Listo! Revisa tu inbox</strong>
      <p>Te hemos enviado un enlace de confirmación.</p>
    </div>
  </div>

  {!compact && (
    <p class="form-note">Sin spam · Cancela en cualquier momento · Gratis</p>
  )}
</div>

<script>
  const form = document.getElementById('subscribe-form') as HTMLFormElement | null;
  const successEl = document.getElementById('subscribe-success') as HTMLElement | null;
  const errorEl = document.getElementById('form-error') as HTMLElement | null;

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!errorEl || !successEl) return;

      const emailInput = form.querySelector<HTMLInputElement>('#email-input');
      const btnText = form.querySelector<HTMLElement>('.btn-text');
      const btnLoading = form.querySelector<HTMLElement>('.btn-loading');
      const submitBtn = form.querySelector<HTMLButtonElement>('.submit-btn');

      if (!emailInput) return;
      const email = emailInput.value.trim();

      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        errorEl.textContent = 'Por favor introduce un email válido.';
        errorEl.hidden = false;
        emailInput.focus();
        return;
      }

      errorEl.hidden = true;
      if (btnText) btnText.hidden = true;
      if (btnLoading) btnLoading.hidden = false;
      if (submitBtn) submitBtn.disabled = true;

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });

        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error((data as { message?: string }).message || `Error ${res.status}`);
        }

        form.hidden = true;
        successEl.hidden = false;
      } catch (err: unknown) {
        const message = err instanceof Error ? err.message : 'Algo salió mal. Inténtalo de nuevo.';
        errorEl.textContent = message;
        errorEl.hidden = false;
        if (btnText) btnText.hidden = false;
        if (btnLoading) btnLoading.hidden = true;
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  }
</script>

<style>
  .subscribe-wrapper { width: 100%; }
  .subscribe-form { width: 100%; }

  .form-row {
    display: flex;
    gap: 0.5rem;
  }

  .email-input {
    flex: 1;
    min-width: 0;
    background: var(--paper-2);
    border: 1px solid var(--rule);
    border-radius: 20px;
    color: var(--ink);
    font-size: 0.88rem;
    font-family: 'Inter', system-ui, sans-serif;
    padding: 0 1.1rem;
    height: 42px;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .email-input::placeholder { color: var(--ink-faint); }
  .email-input:focus {
    border-color: oklch(from var(--spot) l c h / .7);
    box-shadow: 0 0 0 3px oklch(from var(--spot) l c h / .14);
  }

  .submit-btn {
    position: relative;
    height: 42px;
    padding: 0 1.25rem;
    background: var(--spot);
    color: var(--paper);
    border: none;
    border-radius: 20px;
    font-size: 0.76rem;
    font-weight: 700;
    font-family: 'Inter', system-ui, sans-serif;
    letter-spacing: 0.06em;
    cursor: pointer;
    white-space: nowrap;
    overflow: hidden;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .submit-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, transparent 40%, oklch(1 0 0 / .22) 50%, transparent 60%);
    transform: translateX(-100%);
    transition: transform 0.45s cubic-bezier(.16,1,.3,1);
  }
  .submit-btn:hover:not(:disabled) {
    background: var(--spot-deep);
    transform: translateY(-1px);
    box-shadow: 0 4px 14px oklch(from var(--spot) l c h / .35);
  }
  .submit-btn:hover::before { transform: translateX(100%); }
  .submit-btn:disabled { opacity: 0.45; cursor: not-allowed; }

  .form-error {
    margin-top: 0.5rem;
    font-size: 0.78rem;
    color: oklch(0.55 0.22 28);
    font-family: 'Inter', system-ui, sans-serif;
    padding-left: 0.25rem;
  }

  .subscribe-success {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.9rem 1.1rem;
    background: oklch(from var(--spot) l c h / .07);
    border: 1px solid oklch(from var(--spot) l c h / .3);
    border-radius: 10px;
    animation: success-pop 0.4s cubic-bezier(.16,1,.3,1) both;
  }
  @keyframes success-pop {
    from { opacity: 0; transform: scale(0.96) translateY(4px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }

  .success-check {
    color: oklch(0.55 0.14 155);
    font-size: 1rem;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 0.1rem;
    width: 22px; height: 22px;
    background: oklch(0.55 0.14 155 / .15);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.72rem;
  }

  .subscribe-success strong {
    display: block;
    color: var(--ink);
    font-size: 0.88rem;
    font-family: 'Inter', system-ui, sans-serif;
    margin-bottom: 0.1rem;
  }
  .subscribe-success p {
    font-size: 0.78rem;
    color: var(--ink-soft);
    margin: 0;
    font-family: 'Inter', system-ui, sans-serif;
  }

  .form-note {
    margin-top: 0.65rem;
    font-size: 0.68rem;
    color: var(--ink-faint);
    text-align: center;
    letter-spacing: 0.04em;
    font-family: 'Inter', system-ui, sans-serif;
  }

  .sr-only {
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }

  @media (max-width: 480px) {
    .form-row { flex-direction: column; }
    .submit-btn { width: 100%; height: 44px; border-radius: 20px; }
    .email-input { height: 44px; }
  }
</style>
