---
interface Props { edition?: number; }
const { edition } = Astro.props;

const p = Astro.url.pathname;
const now = new Date();
const dateStr = now.toLocaleDateString('es-ES', {
  weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
});

function toRoman(n: number): string {
  const v = [1000,900,500,400,100,90,50,40,10,9,5,4,1];
  const s = ['M','CM','D','CD','C','XC','L','XL','X','IX','V','IV','I'];
  let r = '';
  for (let i = 0; i < v.length; i++) while (n >= v[i]) { r += s[i]; n -= v[i]; }
  return r;
}
---

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<script defer src="/_vercel/insights/script.js"></script>

<!-- ── Dateline bar ── -->
<div class="dateline" id="dateline">
  <div id="scroll-progress"></div>
  <div class="container dateline-inner">

    <span class="dateline-left">{dateStr}</span>

    <span class="dateline-center">
      <span class="live-pulse">
        <span class="live-dot" aria-hidden="true"></span>
        En prensa
      </span>
    </span>

    <span class="dateline-right">
      <a href="/" class={`nav-link${p==='/' ? ' active' : ''}`}>Inicio</a>
      <a href="/bienvenido-a-first-cup" class={`nav-link${p==='/bienvenido-a-first-cup' ? ' active' : ''}`}>El Barista</a>

      <a href="/subscribe" class={`cta-btn${p==='/subscribe' ? ' active' : ''}`} aria-label="Suscribirse a First Cup">
        <span class="cta-shimmer"></span>
        <span class="cta-label">Suscribirse</span>
        <svg class="cta-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2.5 7h9M8 3.5L11.5 7 8 10.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>

      <!-- iOS-style toggle -->
      <label class="theme-toggle" id="theme-toggle" aria-label="Cambiar tema">
        <span class="toggle-label toggle-label--left">Latte</span>
        <span class="toggle-track" role="switch" aria-checked="true" tabindex="0">
          <span class="toggle-thumb"></span>
          <span class="toggle-icon toggle-icon--latte" aria-hidden="true">☀</span>
          <span class="toggle-icon toggle-icon--espresso" aria-hidden="true">☾</span>
        </span>
        <span class="toggle-label toggle-label--right">Espresso</span>
      </label>
    </span>

  </div>
</div>

<!-- ── Masthead ── -->
<header class="masthead" id="masthead">
  <div class="container masthead-inner">

    <div class="mast-side mast-left">
      <span class="mast-label">EST. MMXXVI</span>
      <span class="mast-rule" aria-hidden="true"></span>
      <span class="mast-tagword">CÁDIZ</span>
    </div>

    <div class="nameplate">
      <span class="nameplate-cup" aria-hidden="true">
        <span class="cup gz-cup gz-cup-lg">
          <span class="gz-steam" aria-hidden="true">
            <i style="left:18%; animation-delay:.2s; height:14px"></i>
            <i style="left:44%; animation-delay:.8s; height:18px"></i>
            <i style="left:68%; animation-delay:.4s; height:12px"></i>
          </span>
        </span>
      </span>
      <a href="/" class="nameplate-text">First Cup</a>
    </div>

    <div class="mast-side mast-right">
      {edition
        ? <span class="mast-label">N° {toRoman(edition)}</span>
        : <span class="mast-label">DIARIO</span>
      }
      <span class="mast-rule" aria-hidden="true"></span>
      <span class="mast-tagword">DIGITAL</span>
    </div>

    <div class="mast-motto">
      El diario del café tech &nbsp;<span class="fleuron" aria-hidden="true">❦</span>&nbsp; IA · Desarrollo · Tecnología &nbsp;—&nbsp; recién hecho cada mañana por un agente
    </div>

  </div>
</header>

<script>
  const html = document.documentElement;
  const track = document.querySelector<HTMLElement>('.toggle-track');

  function applyTheme(t: string) {
    html.setAttribute('data-theme', t);
    localStorage.setItem('theme', t);
    if (track) {
      const isEspresso = t === 'espresso';
      track.classList.toggle('is-espresso', isEspresso);
      track.setAttribute('aria-checked', isEspresso ? 'false' : 'true');
    }
  }

  applyTheme(localStorage.getItem('theme') ?? 'latte');

  track?.addEventListener('click', () => {
    applyTheme(html.getAttribute('data-theme') === 'latte' ? 'espresso' : 'latte');
  });

  track?.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === ' ' || e.key === 'Enter') {
      e.preventDefault();
      applyTheme(html.getAttribute('data-theme') === 'latte' ? 'espresso' : 'latte');
    }
  });

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key !== 't' || e.ctrlKey || e.metaKey || e.altKey) return;
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
    applyTheme(html.getAttribute('data-theme') === 'latte' ? 'espresso' : 'latte');
  });

  // Scroll progress
  const bar = document.getElementById('scroll-progress');
  window.addEventListener('scroll', () => {
    if (!bar) return;
    const d = document.documentElement;
    const pct = d.scrollTop / (d.scrollHeight - d.clientHeight) * 100;
    bar.style.width = Math.min(100, pct) + '%';
  }, { passive: true });

  // Compact masthead on scroll
  const masthead = document.getElementById('masthead');
  window.addEventListener('scroll', () => {
    if (masthead) masthead.classList.toggle('compact', window.scrollY > 80);
  }, { passive: true });
</script>

<style>
  /* ── DATELINE BAR ── */
  .dateline {
    background: var(--dl-bg);
    color: var(--dl-text);
    position: sticky;
    top: 0;
    z-index: 100;
    overflow: hidden;
    border-bottom: 1px solid oklch(from var(--dl-text) l c h / .12);
  }

  #scroll-progress {
    position: absolute;
    bottom: 0; left: 0;
    height: 2px; width: 0%;
    background: linear-gradient(90deg, var(--spot-deep) 0%, var(--spot) 60%, oklch(from var(--spot) l c h / .5) 100%);
    z-index: 2;
    transition: width 0.08s linear;
    pointer-events: none;
  }

  .dateline-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 56px;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.82rem;
    letter-spacing: 0.01em;
  }

  .dateline-left {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: oklch(from var(--dl-text) l c h / .55);
    font-size: 0.78rem;
  }

  .dateline-center { text-align: center; }

  .live-pulse {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: oklch(from var(--dl-text) l c h / .55);
  }

  .live-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--spot);
    flex-shrink: 0;
    animation: blip 2.4s ease-in-out infinite;
  }
  @keyframes blip {
    0%,100% { box-shadow: 0 0 0 0 color-mix(in oklab, var(--spot) 60%, transparent); }
    60%     { box-shadow: 0 0 0 6px transparent; }
  }

  /* ── Nav links ── */
  .dateline-right {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 1.25rem;
  }

  .nav-link {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.82rem;
    font-weight: 500;
    color: oklch(from var(--dl-text) l c h / .65);
    text-decoration: none;
    position: relative;
    transition: color 0.2s;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px; left: 0;
    width: 0; height: 1.5px;
    background: var(--spot);
    transition: width 0.25s cubic-bezier(.4,0,.2,1);
  }
  .nav-link:hover { color: var(--dl-text); text-decoration: none; }
  .nav-link:hover::after { width: 100%; }
  .nav-link.active { color: var(--spot); }
  .nav-link.active::after { width: 100%; }

  /* ── CTA Subscribe button ── */
  .cta-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 0 14px;
    height: 32px;
    background: var(--spot);
    color: #fff !important;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    border-radius: 6px;
    overflow: hidden;
    transition: transform 0.18s cubic-bezier(.4,0,.2,1),
                box-shadow 0.18s cubic-bezier(.4,0,.2,1),
                filter 0.18s;
    box-shadow: 0 1px 3px oklch(from var(--spot) l c h / .3),
                0 0 0 0 oklch(from var(--spot) l c h / .0);
  }
  .cta-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 14px oklch(from var(--spot) l c h / .45),
                0 0 0 3px oklch(from var(--spot) l c h / .15);
    filter: brightness(1.08);
    text-decoration: none;
  }
  .cta-btn:active { transform: translateY(0); }
  .cta-btn.active {
    background: var(--spot-deep);
  }

  /* shimmer sweep */
  .cta-shimmer {
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, transparent 40%, oklch(1 0 0 / .22) 50%, transparent 60%);
    background-size: 200% 100%;
    background-position: -100% 0;
    animation: shimmer 2.8s ease-in-out infinite 1s;
    pointer-events: none;
  }
  @keyframes shimmer {
    0%   { background-position: -100% 0; }
    40%  { background-position: 200% 0; }
    100% { background-position: 200% 0; }
  }

  .cta-label { position: relative; }
  .cta-arrow {
    position: relative;
    transition: transform 0.2s cubic-bezier(.4,0,.2,1);
    flex-shrink: 0;
  }
  .cta-btn:hover .cta-arrow { transform: translateX(3px); }

  /* ── iOS-style theme toggle ── */
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    user-select: none;
  }

  .toggle-label {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: oklch(from var(--dl-text) l c h / .45);
    transition: color 0.25s;
  }

  .theme-toggle:has(.toggle-track:not(.is-espresso)) .toggle-label--right,
  .theme-toggle:has(.toggle-track.is-espresso) .toggle-label--left {
    color: oklch(from var(--dl-text) l c h / .28);
  }
  .theme-toggle:has(.toggle-track:not(.is-espresso)) .toggle-label--left,
  .theme-toggle:has(.toggle-track.is-espresso) .toggle-label--right {
    color: oklch(from var(--dl-text) l c h / .75);
  }

  /* The track */
  .toggle-track {
    position: relative;
    width: 46px;
    height: 26px;
    border-radius: 13px;
    background: oklch(from var(--spot) l c h / .25);
    border: 1.5px solid oklch(from var(--spot) l c h / .35);
    cursor: pointer;
    transition: background 0.3s cubic-bezier(.4,0,.2,1),
                border-color 0.3s;
    flex-shrink: 0;
    outline: none;
  }
  .toggle-track:focus-visible {
    box-shadow: 0 0 0 3px oklch(from var(--spot) l c h / .3);
  }
  .toggle-track.is-espresso {
    background: oklch(from var(--spot) calc(l * .7) c h / .35);
    border-color: oklch(from var(--spot) l c h / .5);
  }

  /* Thumb */
  .toggle-thumb {
    position: absolute;
    top: 2px; left: 2px;
    width: 20px; height: 20px;
    border-radius: 50%;
    background: var(--spot);
    box-shadow: 0 1px 4px oklch(from var(--spot) l c h / .5);
    transition: transform 0.3s cubic-bezier(.4,0,.2,1),
                background 0.3s;
    pointer-events: none;
  }
  .toggle-track.is-espresso .toggle-thumb {
    transform: translateX(20px);
    background: oklch(from var(--spot) calc(l * 1.1) c h);
  }

  /* Icons inside track */
  .toggle-icon {
    position: absolute;
    top: 50%; transform: translateY(-50%);
    font-size: 10px;
    pointer-events: none;
    transition: opacity 0.25s;
  }
  .toggle-icon--latte  { left: 5px;  opacity: 1; }
  .toggle-icon--espresso { right: 5px; opacity: 0.4; }
  .toggle-track.is-espresso .toggle-icon--latte    { opacity: 0.4; }
  .toggle-track.is-espresso .toggle-icon--espresso { opacity: 1; }

  /* ── Responsive ── */
  @media (max-width: 720px) {
    .dateline-center { display: none; }
    .dateline-left   { display: none; }
    .dateline-inner  { grid-template-columns: 1fr auto; }
    .dateline-right  { gap: 0.8rem; }
  }
  @media (max-width: 480px) {
    .nav-link:not([href="/subscribe"]) { display: none; }
    .toggle-label { display: none; }
  }

  /* ── MASTHEAD ── */
  .masthead {
    background: var(--paper);
    transition: background 0.45s ease;
  }

  .masthead-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    grid-template-rows: auto auto;
    align-items: center;
    gap: 2rem;
    padding: 2.25rem 2.5rem 0;
    border-top: 3px double var(--ink);
  }

  .mast-side {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 7px;
    font-family: 'Times New Roman', Times, serif;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: var(--ink-soft);
  }

  .mast-rule {
    width: 36px; height: 1px;
    background: var(--rule);
    flex-shrink: 0;
  }

  .mast-label  { color: var(--ink-faint); }
  .mast-tagword { font-weight: 700; color: var(--ink-soft); }

  /* ── Nameplate ── */
  .nameplate {
    display: flex;
    align-items: flex-end;
    gap: 22px;
    justify-content: center;
  }

  .nameplate-cup {
    position: relative;
    display: inline-flex;
    align-items: flex-end;
    padding-bottom: 0.4rem;
  }

  .gz-cup {
    position: relative;
    display: inline-block;
    background: var(--spot);
    border-radius: 2px 2px 7px 7px;
  }
  .gz-cup-lg {
    width: 34px; height: 27px;
    border-radius: 3px 3px 14px 14px;
  }
  .gz-cup-lg::after {
    content: '';
    position: absolute;
    right: -11px; top: 4px;
    width: 12px; height: 15px;
    border: 3px solid var(--spot);
    border-left: none;
    border-radius: 0 8px 8px 0;
  }

  .gz-steam {
    position: absolute;
    bottom: 100%; left: 50%;
    transform: translateX(-50%);
    display: block;
    color: var(--spot);
    width: 34px; height: 26px;
  }
  .gz-steam i {
    position: absolute;
    bottom: -2px;
    width: 3px;
    border-radius: 4px;
    background: currentColor;
    filter: blur(1.5px);
    opacity: 0;
    animation: steam 3.6s ease-in-out infinite;
  }
  @keyframes steam {
    0%   { opacity:0; transform:translateY(3px) scaleY(.5); }
    25%  { opacity:.45; }
    55%  { opacity:.3; transform:translateY(-8px) scaleY(1) translateX(2px); }
    100% { opacity:0; transform:translateY(-18px) scaleY(1.2) translateX(-1px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .gz-steam i { animation: none; opacity: .12; }
    .cta-shimmer { animation: none; }
    .live-dot    { animation: none; }
  }

  .nameplate-text {
    font-family: 'Times New Roman', Times, serif;
    font-weight: 900;
    font-size: clamp(2.75rem, 8.5vw, 6rem);
    line-height: 0.92;
    letter-spacing: -0.02em;
    color: var(--ink);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nameplate-text:hover { color: var(--spot); text-decoration: none; }

  /* ── Motto strip ── */
  .mast-motto {
    grid-column: 1 / -1;
    margin-top: 1.25rem;
    padding: 0.6rem 0;
    border-top: 1px solid var(--ink);
    border-bottom: 3px double var(--ink);
    text-align: center;
    font-family: 'Times New Roman', Times, serif;
    font-size: 0.92rem;
    font-style: normal;
    letter-spacing: 0.04em;
    color: var(--ink-soft);
  }
  .fleuron { color: var(--spot); font-size: 0.75rem; }

  /* ── Compact on scroll ── */
  .masthead.compact .masthead-inner {
    padding-top: 0.9rem;
    gap: 1rem;
  }
  .masthead.compact .mast-side   { display: none; }
  .masthead.compact .nameplate   { gap: 10px; }
  .masthead.compact .nameplate-text { font-size: clamp(1.5rem, 4vw, 2.4rem); }
  .masthead.compact .mast-motto  { margin-top: 0.6rem; font-size: 0.76rem; letter-spacing: 0.03em; padding: 0.4rem 0; }

  @media (max-width: 720px) {
    .masthead-inner {
      grid-template-columns: 1fr;
      padding: 1.2rem 0 0;
      gap: 0.5rem;
      border-top: 2px solid var(--ink);
    }
    .mast-side  { flex-direction: row; gap: 8px; justify-content: center; }
    .mast-rule  { width: 16px; }
    .mast-right { display: none; }
    .nameplate  { order: 0; justify-content: center; }
    .mast-left  { order: 1; }
    .nameplate-text { font-size: clamp(2.4rem, 11vw, 4rem); }
    .mast-motto { font-size: 0.80rem; letter-spacing: 0.03em; }
  }
  @media (max-width: 480px) {
    .mast-side  { display: none; }
    .mast-motto { font-size: 0.76rem; letter-spacing: 0.02em; padding: 0.5rem; }
    .nameplate  { gap: 12px; }
  }
</style>
