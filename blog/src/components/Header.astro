---
const p = Astro.url.pathname;
const now = new Date();
const dateStr = now.toLocaleDateString('es-ES', {
  weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
});
---

<div id="scroll-progress"></div>

<!-- ── Dateline bar ── -->
<div class="dateline" id="dateline">
  <div class="container dateline-inner">
    <span class="dateline-left gz-mono">{dateStr}</span>
    <span class="dateline-center">
      <span class="live-pulse">
        <span class="live-dot" aria-hidden="true"></span>
        En directo
      </span>
    </span>
    <span class="dateline-right">
      <a href="/" class={`dateline-link gz-mono${p==='/' ? ' active' : ''}`}>Inicio</a>
      <span class="dateline-div" aria-hidden="true">·</span>
      <a href="/subscribe" class="dateline-link gz-mono">Suscribirse</a>
      <span class="dateline-div" aria-hidden="true">·</span>
      <button class="theme-toggle" id="theme-toggle" aria-label="Cambiar tema" title="Cambiar tema">
        <span class="toggle-opt toggle-latte">LATTE</span>
        <span class="toggle-knob" aria-hidden="true"></span>
        <span class="toggle-opt toggle-espresso">ESPRESSO</span>
      </button>
    </span>
  </div>
</div>

<!-- ── Masthead ── -->
<header class="masthead" id="masthead">
  <div class="container masthead-inner">

    <div class="mast-side mast-left">
      <span class="mast-label gz-mono">EST. 2025</span>
      <span class="mast-rule" aria-hidden="true"></span>
      <span class="mast-tagword gz-mono">LA GACETA</span>
    </div>

    <div class="nameplate">
      <span class="nameplate-cup" aria-hidden="true">
        <span class="cup gz-cup gz-cup-lg">
          <span class="gz-steam" aria-hidden="true">
            <i style="left:18%; animation-delay:.2s; height:14px"></i>
            <i style="left:44%; animation-delay:.8s; height:18px"></i>
            <i style="left:68%; animation-delay:.4s; height:12px"></i>
          </span>
        </span>
      </span>
      <a href="/" class="nameplate-text">First Cup</a>
    </div>

    <div class="mast-side mast-right">
      <span class="mast-label gz-mono">IA · DEV · TECH</span>
      <span class="mast-rule" aria-hidden="true"></span>
      <span class="mast-tagword gz-mono">DIGEST</span>
    </div>

    <div class="mast-motto">
      <span class="fleuron" aria-hidden="true">❧</span>
      &nbsp;Tu café tech de cada mañana — IA, desarrollo y tecnología curada con inteligencia artificial&nbsp;
      <span class="fleuron" aria-hidden="true">❧</span>
    </div>

  </div>
</header>

<script>
  // ── Scroll progress ──
  const bar = document.getElementById('scroll-progress');
  window.addEventListener('scroll', () => {
    if (!bar) return;
    const d = document.documentElement;
    bar.style.width = (d.scrollTop / (d.scrollHeight - d.clientHeight) * 100) + '%';
  }, { passive: true });

  // ── Theme toggle ──
  const html = document.documentElement;
  const btn  = document.getElementById('theme-toggle') as HTMLElement | null;
  const saved = localStorage.getItem('theme') ?? 'latte';
  html.setAttribute('data-theme', saved);
  if (btn) btn.setAttribute('data-on', saved === 'espresso' ? 'true' : 'false');

  btn?.addEventListener('click', () => {
    const curr = html.getAttribute('data-theme') ?? 'latte';
    const next = curr === 'latte' ? 'espresso' : 'latte';
    html.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    btn.setAttribute('data-on', next === 'espresso' ? 'true' : 'false');
  });

  // ── Compact masthead on scroll ──
  const masthead = document.getElementById('masthead');
  window.addEventListener('scroll', () => {
    if (masthead) masthead.classList.toggle('compact', window.scrollY > 80);
  }, { passive: true });
</script>

<style>
  /* ── DATELINE BAR — always dark strip, both themes ── */
  .dateline {
    background: var(--dl-bg);
    color: var(--dl-text);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .dateline-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 32px;
    font-size: 0.6rem;
    letter-spacing: 0.12em;
  }

  .dateline-left {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: oklch(from var(--dl-text) l c h / .6);
    text-transform: capitalize;
    font-family: var(--font-mono);
  }

  .dateline-center { text-align: center; }

  .live-pulse {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: oklch(from var(--dl-text) l c h / .7);
  }

  .live-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--spot);
    flex-shrink: 0;
    animation: blip 2.2s ease-in-out infinite;
  }
  @keyframes blip {
    0%,100% { box-shadow: 0 0 0 0 color-mix(in oklab, var(--spot) 55%, transparent); }
    60%     { box-shadow: 0 0 0 5px transparent; }
  }

  .dateline-right {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.8rem;
  }

  .dateline-link {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: oklch(from var(--dl-text) l c h / .6);
    text-decoration: none;
    transition: color 0.15s;
  }
  .dateline-link:hover { color: var(--dl-text); text-decoration: none; }
  .dateline-link.active { color: var(--spot); }

  .dateline-div {
    color: oklch(from var(--dl-text) l c h / .22);
    font-size: 0.7rem;
  }

  /* ── Theme toggle ── */
  .theme-toggle {
    position: relative;
    display: inline-flex;
    align-items: center;
    height: 18px;
    border: 1px solid oklch(from var(--dl-text) l c h / .30);
    overflow: hidden;
    font-family: var(--font-mono);
    font-size: 0.5rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: none;
    cursor: pointer;
    color: var(--dl-text);
    padding: 0;
    transition: border-color 0.2s;
  }
  .theme-toggle:hover { border-color: oklch(from var(--dl-text) l c h / .6); }

  .toggle-opt {
    position: relative;
    z-index: 2;
    padding: 0 6px;
    line-height: 18px;
    transition: color 0.28s;
    color: oklch(from var(--dl-text) l c h / .45);
  }

  .theme-toggle[data-on="false"] .toggle-latte   { color: var(--dl-bg); }
  .theme-toggle[data-on="true"]  .toggle-espresso { color: var(--dl-bg); }

  .toggle-knob {
    position: absolute;
    top: 0; bottom: 0; left: 0;
    width: 50%;
    background: oklch(from var(--dl-text) l c h / .85);
    z-index: 1;
    transition: transform 0.30s cubic-bezier(.5,1.2,.5,1);
  }
  .theme-toggle[data-on="true"] .toggle-knob { transform: translateX(100%); }

  @media (max-width: 620px) {
    .dateline-center { display: none; }
    .dateline-left   { display: none; }
    .dateline-inner  { grid-template-columns: 1fr auto; }
  }

  /* ── MASTHEAD ── */
  .masthead {
    background: var(--paper);
    border-bottom: 1px solid var(--rule);
    transition: background 0.45s ease;
  }

  .masthead-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    grid-template-rows: auto auto;
    align-items: center;
    gap: 2rem;
    padding: 2.25rem 2.5rem 0;
    border-top: 3px double var(--ink);
  }

  .mast-side {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 7px;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.2em;
    color: var(--ink-soft);
    text-transform: uppercase;
  }

  .mast-rule {
    width: 36px;
    height: 1px;
    background: var(--rule);
    flex-shrink: 0;
  }

  .mast-label { color: var(--ink-faint); }
  .mast-tagword { font-weight: 700; color: var(--ink-soft); }

  /* ── Nameplate ── */
  .nameplate {
    display: flex;
    align-items: flex-end;
    gap: 16px;
    justify-content: center;
  }

  .nameplate-cup {
    position: relative;
    display: inline-flex;
    align-items: flex-end;
    padding-bottom: 0.3rem;
  }

  .gz-cup {
    position: relative;
    display: inline-block;
    background: var(--spot);
    border-radius: 2px 2px 7px 7px;
  }
  .gz-cup-lg {
    width: 28px; height: 22px;
    border-radius: 3px 3px 12px 12px;
  }
  .gz-cup-lg::after {
    content: '';
    position: absolute;
    right: -9px; top: 3px;
    width: 10px; height: 12px;
    border: 3px solid var(--spot);
    border-left: none;
    border-radius: 0 7px 7px 0;
  }

  .gz-steam {
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    display: block;
    color: var(--spot);
    width: 28px;
    height: 22px;
  }
  .gz-steam i {
    position: absolute;
    bottom: -2px;
    width: 3px;
    border-radius: 4px;
    background: currentColor;
    filter: blur(1.5px);
    opacity: 0;
    animation: steam 3.6s ease-in-out infinite;
  }
  @keyframes steam {
    0%   { opacity:0; transform:translateY(3px) scaleY(.5); }
    25%  { opacity:.45; }
    55%  { opacity:.3; transform:translateY(-8px) scaleY(1) translateX(2px); }
    100% { opacity:0; transform:translateY(-18px) scaleY(1.2) translateX(-1px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .gz-steam i { animation: none; opacity: .12; }
  }

  .nameplate-text {
    font-family: 'Bodoni Moda', serif;
    font-optical-sizing: auto;
    font-style: italic;
    font-weight: 900;
    font-size: clamp(3rem, 10vw, 7.5rem);
    line-height: 0.90;
    letter-spacing: -0.02em;
    color: var(--ink);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nameplate-text:hover { color: var(--spot); text-decoration: none; }

  /* ── Motto strip ── */
  .mast-motto {
    grid-column: 1 / -1;
    margin-top: 1.5rem;
    padding: 0.6rem 0;
    border-top: 1px solid var(--ink);
    border-bottom: 3px double var(--ink);
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .fleuron { color: var(--spot); font-size: 0.75rem; }

  /* ── Compact on scroll ── */
  .masthead.compact .masthead-inner {
    padding-top: 0.9rem;
    gap: 1rem;
  }
  .masthead.compact .mast-side  { display: none; }
  .masthead.compact .nameplate  { gap: 10px; }
  .masthead.compact .nameplate-text { font-size: clamp(1.5rem, 4vw, 2.4rem); }
  .masthead.compact .mast-motto { margin-top: 0.7rem; font-size: 0.52rem; padding: 0.45rem 0; }

  @media (max-width: 720px) {
    .masthead-inner {
      grid-template-columns: 1fr;
      padding: 1.4rem 1.25rem 0;
      gap: 0.8rem;
    }
    .mast-side { flex-direction: row; gap: 8px; justify-content: center; }
    .mast-rule { width: 16px; }
    .mast-right { display: none; }
    .nameplate  { order: 0; }
    .mast-left  { order: 1; }
  }

  @media (max-width: 480px) {
    .mast-side { display: none; }
  }
</style>
