---
const p = Astro.url.pathname;
---

<div id="scroll-progress"></div>

<header class="hdr" id="hdr">
  <div class="hdr-accent-line" aria-hidden="true"></div>
  <div class="container hdr-in">

    <a href="/" class="logo">
      <span class="logo-icon">☕</span>
      <span class="logo-txt">First<em>Cup</em></span>
    </a>

    <nav class="nav">
      <a href="/" class={p==='/' ? 'nl active' : 'nl'}>Inicio</a>
      <a href="/subscribe" class="ncta">
        Suscribirse gratis
      </a>
    </nav>
  </div>
</header>

<script>
  const hdr = document.getElementById('hdr');
  window.addEventListener('scroll', () => {
    if (hdr) hdr.classList.toggle('solid', window.scrollY > 30);
  }, { passive: true });

  // Magnetic subscribe button
  const ncta = document.querySelector<HTMLElement>('.ncta');
  if (ncta) {
    ncta.addEventListener('mousemove', (e: MouseEvent) => {
      const r = ncta.getBoundingClientRect();
      const dx = (e.clientX - (r.left + r.width / 2)) * 0.3;
      const dy = (e.clientY - (r.top + r.height / 2)) * 0.3;
      ncta.style.transition = 'transform 0.1s ease, opacity .15s';
      ncta.style.transform = `translate(${dx}px, ${dy}px)`;
    });
    ncta.addEventListener('mouseleave', () => {
      ncta.style.transition = 'transform 0.5s cubic-bezier(.16,1,.3,1), opacity .15s';
      ncta.style.transform = '';
    });
  }
</script>

<style>
  .hdr {
    position: sticky; top: 0; z-index: 100;
    background: rgba(242,234,216,.7);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid transparent;
    transition: background .3s, border-color .3s, box-shadow .3s;
  }
  .hdr.solid {
    background: rgba(242,234,216,.95);
    border-color: var(--border);
    box-shadow: 0 1px 0 var(--border), 0 4px 20px rgba(28,14,5,.06);
  }

  /* Espresso gradient accent line at top */
  .hdr-accent-line {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg,
      transparent 0%,
      var(--amber) 20%,
      var(--accent) 50%,
      var(--amber) 80%,
      transparent 100%
    );
    opacity: .5;
  }

  .hdr-in {
    display: flex; align-items: center;
    justify-content: space-between;
    height: 60px;
  }

  .logo {
    display: flex; align-items: center; gap: .5rem;
    text-decoration: none;
  }

  .logo-icon {
    font-size: 1.2rem;
    line-height: 1;
    transition: transform .4s var(--spring);
  }
  .logo:hover .logo-icon { transform: rotate(-8deg) scale(1.12); }

  .logo-txt {
    font-family: var(--font-display);
    font-size: 1.08rem;
    font-weight: 400;
    color: var(--text);
    letter-spacing: -.01em;
  }
  .logo-txt em {
    font-style: italic;
    color: var(--accent);
    margin-left: .1em;
  }

  .nav { display: flex; align-items: center; gap: .25rem; }

  .nl {
    font-size: .84rem;
    font-weight: 500;
    color: var(--text-2);
    padding: .38rem .75rem;
    border-radius: 6px;
    transition: color .15s, background .15s;
    text-decoration: none;
  }
  .nl:hover, .nl.active { color: var(--text); background: var(--bg-hover); text-decoration: none; }

  .ncta {
    display: inline-flex;
    align-items: center;
    gap: .35rem;
    font-size: .84rem;
    font-weight: 600;
    color: var(--bg);
    background: var(--accent);
    padding: .42rem 1rem;
    border-radius: 7px;
    margin-left: .35rem;
    transition: opacity .15s, transform .25s var(--spring), box-shadow .25s;
    text-decoration: none;
    box-shadow: 0 2px 8px rgba(92,47,14,.2);
  }
  .ncta:hover {
    opacity: .9;
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(92,47,14,.3);
    text-decoration: none;
  }
  .ncta:active { transform: scale(.97); }

  @media (max-width:480px) {
    .logo-txt { display: none; }
    .ncta { padding: .38rem .75rem; font-size: .8rem; }
    .ncta span { display: none; }
  }
</style>
