---
const p = Astro.url.pathname;
const now = new Date();
const dateStr = now.toLocaleDateString('es-ES', {
  weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
});
---

<div id="scroll-progress"></div>

<!-- ── Dateline bar ── -->
<div class="dateline" id="dateline">
  <div class="container dateline-inner">
    <span class="dateline-left gz-mono">{dateStr}</span>
    <span class="dateline-center">
      <span class="live-pulse">
        <span class="live-dot" aria-hidden="true"></span>
        En directo
      </span>
    </span>
    <span class="dateline-right">
      <a href="/" class={`dateline-link gz-mono${p==='/' ? ' active' : ''}`}>Inicio</a>
      <span class="dateline-div" aria-hidden="true">·</span>
      <a href="/subscribe" class="dateline-link gz-mono">Suscribirse</a>
      <span class="dateline-div" aria-hidden="true">·</span>
      <button class="theme-toggle" id="theme-toggle" aria-label="Cambiar tema" title="Cambiar tema">
        <span class="toggle-opt toggle-latte">LATTE</span>
        <span class="toggle-knob" aria-hidden="true"></span>
        <span class="toggle-opt toggle-espresso">ESPRESSO</span>
      </button>
    </span>
  </div>
</div>

<!-- ── Masthead ── -->
<header class="masthead" id="masthead">
  <div class="container masthead-inner">

    <div class="mast-side mast-left">
      <span class="mast-label gz-mono">EST. 2025</span>
      <span class="mast-rule" aria-hidden="true"></span>
      <span class="mast-tagword gz-mono">LA GACETA</span>
    </div>

    <div class="nameplate">
      <span class="nameplate-cup" aria-hidden="true">
        <span class="cup gz-cup gz-cup-lg">
          <span class="gz-steam" aria-hidden="true">
            <i style="left:18%; animation-delay:.2s; height:14px"></i>
            <i style="left:44%; animation-delay:.8s; height:18px"></i>
            <i style="left:68%; animation-delay:.4s; height:12px"></i>
          </span>
        </span>
      </span>
      <a href="/" class="nameplate-text">First Cup</a>
    </div>

    <div class="mast-side mast-right">
      <span class="mast-label gz-mono">IA · DEV · TECH</span>
      <span class="mast-rule" aria-hidden="true"></span>
      <span class="mast-tagword gz-mono">DIGEST</span>
    </div>

    <div class="mast-motto">
      <span class="fleuron" aria-hidden="true">❧</span>
      &nbsp;Tu café tech de cada mañana — IA, desarrollo y tecnología curada con inteligencia artificial&nbsp;
      <span class="fleuron" aria-hidden="true">❧</span>
    </div>

  </div>
</header>

<script>
  // ── Scroll progress ──
  const bar = document.getElementById('scroll-progress');
  window.addEventListener('scroll', () => {
    if (!bar) return;
    const d = document.documentElement;
    bar.style.width = (d.scrollTop / (d.scrollHeight - d.clientHeight) * 100) + '%';
  }, { passive: true });

  // ── Theme toggle ──
  const html = document.documentElement;
  const btn  = document.getElementById('theme-toggle') as HTMLElement | null;
  const saved = localStorage.getItem('theme') ?? 'latte';
  html.setAttribute('data-theme', saved);
  if (btn) btn.setAttribute('data-on', saved === 'espresso' ? 'true' : 'false');

  btn?.addEventListener('click', () => {
    const curr = html.getAttribute('data-theme') ?? 'latte';
    const next = curr === 'latte' ? 'espresso' : 'latte';
    html.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    btn.setAttribute('data-on', next === 'espresso' ? 'true' : 'false');
  });

  // ── Compact masthead on scroll ──
  const masthead = document.getElementById('masthead');
  window.addEventListener('scroll', () => {
    if (masthead) masthead.classList.toggle('compact', window.scrollY > 80);
  }, { passive: true });
</script>

<style>
  /* ── DATELINE ── */
  .dateline {
    background: var(--ink);
    color: var(--paper);
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid oklch(from var(--ink) calc(l + .1) c h);
    transition: background 0.5s ease, color 0.5s ease;
  }

  .dateline-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 34px;
    font-size: 0.65rem;
    letter-spacing: 0.12em;
  }

  .dateline-left {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: oklch(from var(--paper) calc(l - .1) c h / .75);
    text-transform: capitalize;
  }

  .dateline-center {
    text-align: center;
  }

  .live-pulse {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--paper);
    opacity: 0.8;
  }

  .live-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--spot);
    flex-shrink: 0;
    animation: blip 2s infinite;
  }
  @keyframes blip {
    0%   { box-shadow: 0 0 0 0 color-mix(in oklab, var(--spot) 60%, transparent); }
    70%  { box-shadow: 0 0 0 5px transparent; }
    100% { box-shadow: 0 0 0 0 transparent; }
  }

  .dateline-right {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.75rem;
  }

  .dateline-link {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--paper);
    opacity: 0.65;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .dateline-link:hover, .dateline-link.active { opacity: 1; text-decoration: none; }
  .dateline-link.active { color: var(--spot); }

  .dateline-div {
    color: var(--paper);
    opacity: 0.25;
    font-size: 0.75rem;
  }

  /* ── Theme toggle ── */
  .theme-toggle {
    position: relative;
    display: inline-flex;
    align-items: center;
    height: 20px;
    border: 1px solid oklch(from var(--paper) l c h / .4);
    overflow: hidden;
    font-family: var(--font-mono);
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: none;
    cursor: pointer;
    color: inherit;
    border-radius: 0;
    padding: 0;
    transition: border-color 0.2s;
  }
  .theme-toggle:hover { border-color: oklch(from var(--paper) l c h / .7); }

  .toggle-opt {
    position: relative;
    z-index: 2;
    padding: 0 7px;
    line-height: 20px;
    transition: color 0.3s;
  }

  .toggle-latte  { color: oklch(from var(--paper) calc(l - .3) c h); }
  .toggle-espresso { color: var(--paper); }

  .theme-toggle[data-on="true"] .toggle-latte   { color: var(--paper); }
  .theme-toggle[data-on="true"] .toggle-espresso { color: oklch(from var(--paper) calc(l - .3) c h); }

  .toggle-knob {
    position: absolute;
    top: 0; bottom: 0; left: 0;
    width: 50%;
    background: var(--paper);
    z-index: 1;
    opacity: 0.2;
    transition: transform 0.32s cubic-bezier(.5,1.2,.5,1);
  }
  .theme-toggle[data-on="true"] .toggle-knob { transform: translateX(100%); }

  @media (max-width: 620px) {
    .dateline-center { display: none; }
    .dateline-inner  { grid-template-columns: 1fr auto; }
    .dateline-left   { display: none; }
  }

  /* ── MASTHEAD ── */
  .masthead {
    background: var(--paper);
    border-bottom: 1px solid var(--rule);
    transition: background 0.5s ease, padding 0.3s ease;
  }

  .masthead-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    grid-template-rows: auto auto;
    align-items: center;
    gap: 1.5rem;
    padding: 1.75rem 2rem 0;
    border-top: 3px double var(--ink);
  }

  .mast-side {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    color: var(--ink-soft);
    text-transform: uppercase;
  }

  .mast-rule {
    width: 32px;
    height: 1px;
    background: var(--ink);
    flex-shrink: 0;
  }

  .mast-label { color: var(--ink-faint); }
  .mast-tagword { font-weight: 700; color: var(--ink); }

  .nameplate {
    display: flex;
    align-items: flex-end;
    gap: 14px;
    justify-content: center;
  }

  .nameplate-cup {
    position: relative;
    display: inline-flex;
    align-items: flex-end;
    padding-bottom: 0.2rem;
  }

  .gz-cup {
    position: relative;
    display: inline-block;
    background: var(--spot);
    border-radius: 2px 2px 7px 7px;
  }
  .gz-cup-lg { width: 26px; height: 20px; border-radius: 3px 3px 11px 11px; }
  .gz-cup-lg::after {
    content: '';
    position: absolute;
    right: -8px; top: 3px;
    width: 9px; height: 11px;
    border: 3px solid var(--spot);
    border-left: none;
    border-radius: 0 6px 6px 0;
  }

  .gz-steam {
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    display: block;
    color: var(--spot);
    width: 26px;
    height: 20px;
  }
  .gz-steam i {
    position: absolute;
    bottom: -2px;
    width: 3px;
    border-radius: 4px;
    background: currentColor;
    filter: blur(1.5px);
    opacity: 0;
    animation: steam 3.6s ease-in-out infinite;
  }
  @keyframes steam {
    0%   { opacity:0; transform:translateY(3px) scaleY(.5); }
    25%  { opacity:.5; }
    55%  { opacity:.35; transform:translateY(-7px) scaleY(1) translateX(2px); }
    100% { opacity:0; transform:translateY(-16px) scaleY(1.2) translateX(-1px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .gz-steam i { animation: none; opacity: .15; }
  }

  .nameplate-text {
    font-family: 'Bodoni Moda', serif;
    font-optical-sizing: auto;
    font-weight: 900;
    font-size: clamp(2.8rem, 8.5vw, 6rem);
    line-height: 0.92;
    letter-spacing: -0.015em;
    color: var(--ink);
    text-decoration: none;
    transition: color 0.15s;
  }
  .nameplate-text:hover { color: var(--spot-deep); text-decoration: none; }

  .mast-motto {
    grid-column: 1 / -1;
    margin-top: 1.25rem;
    padding: 0.55rem 0;
    border-top: 1px solid var(--ink);
    border-bottom: 3px double var(--ink);
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 0;
  }

  .fleuron { color: var(--spot); }

  /* ── Compact mode when scrolled ── */
  .masthead.compact .masthead-inner {
    padding-top: 0.75rem;
  }
  .masthead.compact .mast-side { display: none; }
  .masthead.compact .nameplate { gap: 8px; }
  .masthead.compact .nameplate-text { font-size: clamp(1.4rem, 4vw, 2rem); }
  .masthead.compact .mast-motto { margin-top: 0.6rem; font-size: 0.55rem; }

  @media (max-width: 720px) {
    .masthead-inner {
      grid-template-columns: 1fr;
      padding: 1.25rem 1rem 0;
      gap: 0.75rem;
    }
    .mast-side { flex-direction: row; gap: 8px; }
    .mast-rule { width: 16px; }
    .mast-left { order: 0; justify-content: center; }
    .nameplate  { order: 1; }
    .mast-right { display: none; }
  }
</style>
