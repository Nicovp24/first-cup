---
const p = Astro.url.pathname;
---

<div id="scroll-progress"></div>

<header class="hdr" id="hdr">
  <div class="container hdr-in">

    <a href="/" class="logo">
      <span class="logo-n">FC</span>
      <span class="logo-txt">First<em>Cup</em></span>
    </a>

    <nav class="nav">
      <a href="/" class={p==='/' ? 'nl active' : 'nl'}>Posts</a>
      <a href="/subscribe" class="ncta">Suscribirse</a>
    </nav>
  </div>
</header>

<script>
  const hdr = document.getElementById('hdr');
  window.addEventListener('scroll', () => {
    if (hdr) hdr.classList.toggle('solid', window.scrollY > 30);
  }, { passive: true });

  // Magnetic subscribe button
  const ncta = document.querySelector<HTMLElement>('.ncta');
  if (ncta) {
    ncta.addEventListener('mousemove', (e: MouseEvent) => {
      const r = ncta.getBoundingClientRect();
      const dx = (e.clientX - (r.left + r.width / 2)) * 0.3;
      const dy = (e.clientY - (r.top + r.height / 2)) * 0.3;
      ncta.style.transition = 'transform 0.1s ease, opacity .15s';
      ncta.style.transform = `translate(${dx}px, ${dy}px)`;
    });
    ncta.addEventListener('mouseleave', () => {
      ncta.style.transition = 'transform 0.5s cubic-bezier(.16,1,.3,1), opacity .15s';
      ncta.style.transform = '';
    });
  }
</script>

<style>
  .hdr {
    position: sticky; top: 0; z-index: 100;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition: background .35s, border-color .35s;
  }
  .hdr.solid {
    background: rgba(242,234,216,.94);
    backdrop-filter: blur(18px);
    border-color: var(--border);
  }

  .hdr-in {
    display: flex; align-items: center;
    justify-content: space-between;
    height: 62px;
  }

  .logo {
    display: flex; align-items: center; gap: .6rem;
    text-decoration: none;
  }

  .logo-n {
    width: 34px; height: 28px;
    background: var(--accent);
    color: var(--bg);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: .68rem;
    letter-spacing: .02em;
    border-radius: 5px;
    display: flex; align-items: center; justify-content: center;
    transition: transform .4s var(--spring), opacity .2s;
  }
  .logo:hover .logo-n {
    transform: rotate(-6deg) scale(1.08);
    opacity: .85;
  }

  .logo-txt {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 400;
    color: var(--text);
    letter-spacing: -.01em;
  }
  .logo-txt em {
    font-style: italic;
    color: var(--accent);
    margin-left: .12em;
  }

  .nav { display: flex; align-items: center; gap: .25rem; }

  .nl {
    font-size: .875rem;
    font-weight: 500;
    color: var(--text-2);
    padding: .38rem .75rem;
    border-radius: 6px;
    transition: color .15s, background .15s;
    text-decoration: none;
  }
  .nl:hover, .nl.active { color: var(--text); background: var(--bg-hover); text-decoration: none; }

  .ncta {
    font-size: .875rem;
    font-weight: 600;
    color: var(--bg);
    background: var(--accent);
    padding: .38rem .9rem;
    border-radius: 6px;
    margin-left: .3rem;
    transition: opacity .15s, transform .25s var(--spring);
    text-decoration: none;
  }
  .ncta:hover { opacity: .85; transform: translateY(-1px); text-decoration: none; }
  .ncta:active { transform: scale(.97); }

  @media (max-width:480px) {
    .logo-txt { display: none; }
    .logo-n { width: 32px; height: 32px; font-size: .95rem; }
  }
</style>
