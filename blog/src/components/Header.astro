---
interface Props { edition?: number; }
const { edition } = Astro.props;

const p = Astro.url.pathname;
const now = new Date();
const dateStr = now.toLocaleDateString('es-ES', {
  weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
});

function toRoman(n: number): string {
  const v = [1000,900,500,400,100,90,50,40,10,9,5,4,1];
  const s = ['M','CM','D','CD','C','XC','L','XL','X','IX','V','IV','I'];
  let r = '';
  for (let i = 0; i < v.length; i++) while (n >= v[i]) { r += s[i]; n -= v[i]; }
  return r;
}
---

<script defer src="/_vercel/insights/script.js"></script>

<!-- ── Dateline bar ── -->
<div class="dateline" id="dateline">
  <div id="scroll-progress"></div>
  <div class="container dateline-inner">
    <span class="dateline-left gz-mono">{dateStr}</span>
    <span class="dateline-center">
      <span class="live-pulse">
        <span class="live-dot" aria-hidden="true"></span>
        En prensa
      </span>
    </span>
    <span class="dateline-right">
      <a href="/" class={`dateline-link gz-mono${p==='/' ? ' active' : ''}`}>Inicio</a>
      <span class="dateline-div" aria-hidden="true">·</span>
      <a href="/subscribe" class={`dateline-link dateline-link--cta gz-mono${p==='/subscribe' ? ' active' : ''}`}>Suscribirse</a>
      <span class="dateline-div" aria-hidden="true">·</span>
      <a href="/bienvenido-a-first-cup" class={`dateline-link dateline-link--about gz-mono${p==='/bienvenido-a-first-cup' ? ' active' : ''}`}>☕ El Barista</a>
      <span class="dateline-div" aria-hidden="true">·</span>
      <div class="theme-switcher gz-mono" id="theme-toggle" role="group" aria-label="Cambiar tema">
        <button class="ts-btn" data-t="latte">LATTE</button>
        <button class="ts-btn" data-t="espresso">ESPRESSO</button>
      </div>
    </span>
  </div>
</div>

<!-- ── Masthead ── -->
<header class="masthead" id="masthead">
  <div class="container masthead-inner">

    <div class="mast-side mast-left">
      <span class="mast-label gz-mono">EST. MMXXVI</span>
      <span class="mast-rule" aria-hidden="true"></span>
      <span class="mast-tagword gz-mono">CÁDIZ</span>
    </div>

    <div class="nameplate">
      <span class="nameplate-cup" aria-hidden="true">
        <span class="cup gz-cup gz-cup-lg">
          <span class="gz-steam" aria-hidden="true">
            <i style="left:18%; animation-delay:.2s; height:14px"></i>
            <i style="left:44%; animation-delay:.8s; height:18px"></i>
            <i style="left:68%; animation-delay:.4s; height:12px"></i>
          </span>
        </span>
      </span>
      <a href="/" class="nameplate-text">First Cup</a>
    </div>

    <div class="mast-side mast-right">
      {edition
        ? <span class="mast-label gz-mono">N° {toRoman(edition)}</span>
        : <span class="mast-label gz-mono">DIARIO</span>
      }
      <span class="mast-rule" aria-hidden="true"></span>
      <span class="mast-tagword gz-mono">DIGITAL</span>
    </div>

    <div class="mast-motto">
      El diario del café tech &nbsp;<span class="fleuron" aria-hidden="true">❦</span>&nbsp; IA · Desarrollo · Tecnología &nbsp;—&nbsp; recién hecho cada mañana por un agente
    </div>

  </div>
</header>

<script>
  // ── Theme ──
  const html = document.documentElement;
  const tsBtns = document.querySelectorAll<HTMLButtonElement>('.ts-btn');

  function applyTheme(t: string) {
    html.setAttribute('data-theme', t);
    localStorage.setItem('theme', t);
    tsBtns.forEach(b => b.setAttribute('aria-pressed', b.dataset.t === t ? 'true' : 'false'));
  }

  applyTheme(localStorage.getItem('theme') ?? 'latte');

  tsBtns.forEach(btn => btn.addEventListener('click', () => applyTheme(btn.dataset.t!)));

  // 'T' key to toggle theme
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key !== 't' || e.ctrlKey || e.metaKey || e.altKey) return;
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
    applyTheme(html.getAttribute('data-theme') === 'latte' ? 'espresso' : 'latte');
  });

  // ── Scroll progress ──
  const bar = document.getElementById('scroll-progress');
  window.addEventListener('scroll', () => {
    if (!bar) return;
    const d = document.documentElement;
    const pct = d.scrollTop / (d.scrollHeight - d.clientHeight) * 100;
    bar.style.width = Math.min(100, pct) + '%';
  }, { passive: true });

  // ── Compact masthead on scroll ──
  const masthead = document.getElementById('masthead');
  window.addEventListener('scroll', () => {
    if (masthead) masthead.classList.toggle('compact', window.scrollY > 80);
  }, { passive: true });
</script>

<style>
  /* ── DATELINE BAR ── */
  .dateline {
    background: var(--dl-bg);
    color: var(--dl-text);
    position: sticky;
    top: 0;
    z-index: 100;
    overflow: hidden;
  }

  /* Scroll progress bar — bottom edge of dateline */
  #scroll-progress {
    position: absolute;
    bottom: 0; left: 0;
    height: 3px; width: 0%;
    background: linear-gradient(90deg, var(--spot-deep) 0%, var(--spot) 100%);
    z-index: 2;
    transition: width 0.08s linear;
    pointer-events: none;
  }

  .dateline-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 52px;
    font-size: 0.82rem;
    letter-spacing: 0.02em;
  }

  .dateline-left {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: oklch(from var(--dl-text) l c h / .72);
    font-family: 'Times New Roman', Times, serif;
  }

  .dateline-center { text-align: center; }

  .live-pulse {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: 'Times New Roman', Times, serif;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: oklch(from var(--dl-text) l c h / .85);
  }

  .live-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--spot);
    flex-shrink: 0;
    animation: blip 2.2s ease-in-out infinite;
  }
  @keyframes blip {
    0%,100% { box-shadow: 0 0 0 0 color-mix(in oklab, var(--spot) 55%, transparent); }
    60%     { box-shadow: 0 0 0 5px transparent; }
  }

  .dateline-right {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 1rem;
  }

  .dateline-link {
    font-family: 'Times New Roman', Times, serif;
    font-size: 0.82rem;
    letter-spacing: 0.01em;
    color: oklch(from var(--dl-text) l c h / .85);
    text-decoration: none;
    transition: color 0.15s;
  }
  .dateline-link:hover { color: var(--dl-text); text-decoration: none; }
  .dateline-link.active { color: var(--spot); }
  .dateline-link--about { font-weight: 700; }

  .dateline-link--cta {
    color: var(--spot) !important;
    border: 1px solid oklch(from var(--spot) l c h / .55);
    padding: 0.2rem 0.6rem;
    letter-spacing: 0.02em;
    font-weight: 700;
    transition: background 0.18s, color 0.18s, border-color 0.18s;
  }
  .dateline-link--cta:hover {
    background: var(--spot);
    color: var(--dl-bg) !important;
    border-color: var(--spot);
    text-decoration: none;
  }
  .dateline-link--cta.active {
    background: var(--spot);
    color: var(--dl-bg) !important;
    border-color: var(--spot);
  }

  .dateline-div {
    color: oklch(from var(--dl-text) l c h / .30);
    font-size: 0.9rem;
  }

  /* ── Theme switcher — two separate buttons ── */
  .theme-switcher {
    display: inline-flex;
    align-items: center;
    height: 26px;
    border: 1px solid oklch(from var(--dl-text) l c h / .45);
    overflow: hidden;
    font-family: 'Times New Roman', Times, serif;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .ts-btn {
    height: 100%;
    padding: 0 9px;
    background: none;
    border: none;
    border-right: 1px solid oklch(from var(--dl-text) l c h / .28);
    color: oklch(from var(--dl-text) l c h / .55);
    cursor: pointer;
    transition: background 0.22s, color 0.22s;
    font: inherit;
    letter-spacing: inherit;
  }
  .ts-btn:last-child { border-right: none; }
  .ts-btn:hover:not([aria-pressed="true"]) { color: var(--dl-text); }
  .ts-btn[aria-pressed="true"] {
    background: oklch(from var(--dl-text) l c h / .90);
    color: var(--dl-bg);
  }

  @media (max-width: 620px) {
    .dateline-center { display: none; }
    .dateline-left   { display: none; }
    .dateline-inner  { grid-template-columns: 1fr auto; }
    .dateline-right  { gap: 0.6rem; }
  }

  @media (max-width: 420px) {
    .dateline-link--about { display: none; }
    .dateline-div:has(+ .dateline-link--about),
    .dateline-link--about + .dateline-div { display: none; }
  }

  /* ── MASTHEAD ── */
  .masthead {
    background: var(--paper);
    transition: background 0.45s ease;
  }

  .masthead-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    grid-template-rows: auto auto;
    align-items: center;
    gap: 2rem;
    padding: 2.25rem 2.5rem 0;
    border-top: 3px double var(--ink);
  }

  .mast-side {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 7px;
    font-family: 'Times New Roman', Times, serif;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: var(--ink-soft);
  }

  .mast-rule {
    width: 36px;
    height: 1px;
    background: var(--rule);
    flex-shrink: 0;
  }

  .mast-label { color: var(--ink-faint); font-style: italic; }
  .mast-tagword { font-weight: 700; color: var(--ink-soft); }

  /* ── Nameplate ── */
  .nameplate {
    display: flex;
    align-items: flex-end;
    gap: 22px;
    justify-content: center;
  }

  .nameplate-cup {
    position: relative;
    display: inline-flex;
    align-items: flex-end;
    padding-bottom: 0.4rem;
  }

  .gz-cup {
    position: relative;
    display: inline-block;
    background: var(--spot);
    border-radius: 2px 2px 7px 7px;
  }
  .gz-cup-lg {
    width: 34px; height: 27px;
    border-radius: 3px 3px 14px 14px;
  }
  .gz-cup-lg::after {
    content: '';
    position: absolute;
    right: -11px; top: 4px;
    width: 12px; height: 15px;
    border: 3px solid var(--spot);
    border-left: none;
    border-radius: 0 8px 8px 0;
  }

  .gz-steam {
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    display: block;
    color: var(--spot);
    width: 34px;
    height: 26px;
  }
  .gz-steam i {
    position: absolute;
    bottom: -2px;
    width: 3px;
    border-radius: 4px;
    background: currentColor;
    filter: blur(1.5px);
    opacity: 0;
    animation: steam 3.6s ease-in-out infinite;
  }
  @keyframes steam {
    0%   { opacity:0; transform:translateY(3px) scaleY(.5); }
    25%  { opacity:.45; }
    55%  { opacity:.3; transform:translateY(-8px) scaleY(1) translateX(2px); }
    100% { opacity:0; transform:translateY(-18px) scaleY(1.2) translateX(-1px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .gz-steam i { animation: none; opacity: .12; }
  }

  .nameplate-text {
    font-family: 'Times New Roman', Times, serif;
    font-weight: 900;
    font-size: clamp(2.75rem, 8.5vw, 6rem);
    line-height: 0.92;
    letter-spacing: -0.02em;
    color: var(--ink);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nameplate-text:hover { color: var(--spot); text-decoration: none; }

  /* ── Motto strip ── */
  .mast-motto {
    grid-column: 1 / -1;
    margin-top: 1.25rem;
    padding: 0.6rem 0;
    border-top: 1px solid var(--ink);
    border-bottom: 3px double var(--ink);
    text-align: center;
    font-family: 'Times New Roman', Times, serif;
    font-size: 0.92rem;
    font-style: italic;
    letter-spacing: 0.04em;
    color: var(--ink-soft);
  }

  .fleuron { color: var(--spot); font-size: 0.75rem; }

  /* ── Compact on scroll ── */
  .masthead.compact .masthead-inner {
    padding-top: 0.9rem;
    gap: 1rem;
  }
  .masthead.compact .mast-side  { display: none; }
  .masthead.compact .nameplate  { gap: 10px; }
  .masthead.compact .nameplate-text { font-size: clamp(1.5rem, 4vw, 2.4rem); }
  .masthead.compact .mast-motto { margin-top: 0.6rem; font-size: 0.76rem; letter-spacing: 0.03em; padding: 0.4rem 0; }

  @media (max-width: 720px) {
    .masthead-inner {
      grid-template-columns: 1fr;
      padding: 1.2rem 0 0;
      gap: 0.5rem;
      border-top: 2px solid var(--ink);
    }
    .mast-side { flex-direction: row; gap: 8px; justify-content: center; }
    .mast-rule { width: 16px; }
    .mast-right { display: none; }
    .nameplate  { order: 0; justify-content: center; }
    .mast-left  { order: 1; }
    .nameplate-text { font-size: clamp(2.4rem, 11vw, 4rem); }
    .mast-motto { font-size: 0.80rem; letter-spacing: 0.03em; }
  }

  @media (max-width: 480px) {
    .mast-side  { display: none; }
    .mast-motto { font-size: 0.76rem; letter-spacing: 0.02em; padding: 0.5rem 0.5rem; }
    .nameplate  { gap: 12px; }
  }
</style>
