---
interface Props {
  title: string;
  slug: string;
  date: Date;
  description: string;
  tags: string[];
  index?: number;
  featured?: boolean;
  editionNum?: number;
  cover?: string;
}

const { title, slug, date, description, tags, index, featured = false, editionNum, cover } = Astro.props;
const d = date.toLocaleDateString('es-ES', { day:'numeric', month:'short', year:'numeric' });
const iso = date.toISOString();
const delay = (index ?? 0) * 50;
const edition = editionNum != null ? `#${String(editionNum).padStart(3, '0')}` : null;
---

<article
  class:list={['story-card', { 'story-card--has-img': !!cover }]}
  style={`animation-delay:${delay}ms`}
  data-tags={tags.join(',')}
>
  <a href={`/${slug}`} class="story-link">

    {cover && (
      <div class="story-img">
        <img src={cover} alt="" loading="lazy" decoding="async" />
      </div>
    )}

    <div class="story-body">
      <div class="story-top">
        {tags.slice(0,2).map(t => <span class="kicker story-kicker">{t}</span>)}
        {edition && <span class="edition-chip gz-mono">{edition}</span>}
      </div>

      <h2 class="story-title">{title}</h2>

      <p class="story-stand">{description.length > 100 ? description.slice(0, 100) + '…' : description}</p>

      <div class="story-foot">
        <time class="story-date gz-mono rel-time" datetime={iso}>{d}</time>
        <span class="story-readon gz-mono">Leer →</span>
      </div>
    </div>

  </a>
</article>

<script>
  function relTime(iso: string): string {
    const diff = (Date.now() - new Date(iso).getTime()) / 1000;
    if (diff < 3600)    return `hace ${Math.round(diff / 60)}m`;
    if (diff < 86400)   return `hace ${Math.round(diff / 3600)}h`;
    if (diff < 604800)  return `hace ${Math.round(diff / 86400)}d`;
    if (diff < 2592000) return `hace ${Math.round(diff / 604800)} sem`;
    return new Date(iso).toLocaleDateString('es-ES', { day:'numeric', month:'short', year:'numeric' });
  }
  document.querySelectorAll<HTMLElement>('.rel-time').forEach(el => {
    const iso = el.getAttribute('datetime');
    if (iso) el.textContent = relTime(iso);
  });
</script>

<style>
  .story-card {
    position: relative;
    opacity: 0;
    animation: fade-up .55s var(--spring) both;
    animation-play-state: paused;
    border-right: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    background: var(--paper);
    transition: background 0.2s, box-shadow 0.25s;
  }
  .story-card.in-view { animation-play-state: running; }
  .story-card:hover {
    background: var(--paper-sink);
    box-shadow: inset 0 2px 0 var(--spot);
  }

  .story-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }
  .story-link:hover { text-decoration: none; }

  .story-img {
    margin: 0;
    height: 200px;
    overflow: hidden;
    border-bottom: 1px solid var(--rule);
    flex-shrink: 0;
    position: relative;
    background: var(--paper-sink);
  }
  .story-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 30%;
    transition: transform 0.55s var(--spring);
    display: block;
  }
  .story-card:hover .story-img img { transform: scale(1.04); }

  .story-body {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    padding: 1.25rem 1.4rem 1.4rem;
    flex: 1;
  }

  .story-top {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    flex-wrap: wrap;
  }

  .story-kicker {
    font-size: 0.6rem;
  }

  .edition-chip {
    font-size: 0.58rem;
    color: var(--ink-faint);
    letter-spacing: 0.06em;
    margin-left: auto;
  }

  .story-title {
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 1.7vw, 1.25rem);
    font-weight: 700;
    color: var(--ink);
    line-height: 1.28;
    letter-spacing: -0.012em;
    transition: color 0.18s;
    flex: 1;
  }
  .story-card:hover .story-title { color: var(--spot); }

  .story-stand {
    font-size: 0.85rem;
    color: var(--ink-soft);
    line-height: 1.6;
    font-style: italic;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .story-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: 0.65rem;
    border-top: 1px solid var(--rule-soft);
  }

  .story-date {
    font-size: 0.64rem;
    color: var(--ink-faint);
    letter-spacing: 0.04em;
  }

  .story-readon {
    font-size: 0.64rem;
    font-weight: 700;
    color: var(--spot);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.15s;
  }
  .story-card:hover .story-readon { color: var(--spot-deep); }
</style>
