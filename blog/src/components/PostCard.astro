---
interface Props {
  title: string;
  slug: string;
  date: Date;
  description: string;
  tags: string[];
  index?: number;
  featured?: boolean;
  editionNum?: number;
  cover?: string;
}

const { title, slug, date, description, tags, index, featured = false, editionNum, cover } = Astro.props;
const d = date.toLocaleDateString('es-ES', { day:'numeric', month:'short', year:'numeric' });
const iso = date.toISOString();
const delay = (index ?? 0) * 60;
const edition = editionNum != null ? `#${String(editionNum).padStart(3, '0')}` : null;
const preview = description.length > 90 ? description.slice(0, 90) + '…' : description;
---

<article
  class:list={['card', { 'card--featured': featured, 'card--has-img': !!cover }]}
  style={`animation-delay:${delay}ms`}
  data-tags={tags.join(',')}
>
  <a href={`/${slug}`} class="card-link">

    {cover && (
      <div class="card-img">
        <img src={cover} alt="" loading="lazy" decoding="async" />
      </div>
    )}

    <div class="card-body">
      <div class="card-top">
        <div class="card-meta">
          {edition && <span class="card-edition">{edition}</span>}
          <time class="card-date rel-time" datetime={iso}>{d}</time>
        </div>
        <div class="card-tags">
          {tags.slice(0,3).map(t => <span class="tag">{t}</span>)}
        </div>
      </div>

      <h2 class="card-title">{title}</h2>

      {featured && <p class="card-desc">{description}</p>}

      <div class="card-foot">
        <span class="card-read">Leer artículo</span>
        <svg class="card-arr" width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>

    {!featured && (
      <div class="card-preview" aria-hidden="true">{preview}</div>
    )}

  </a>
</article>

<script>
  // Update relative times client-side so they stay accurate
  function relTime(iso: string): string {
    const diff = (Date.now() - new Date(iso).getTime()) / 1000;
    if (diff < 3600)    return `hace ${Math.round(diff / 60)}m`;
    if (diff < 86400)   return `hace ${Math.round(diff / 3600)}h`;
    if (diff < 604800)  return `hace ${Math.round(diff / 86400)}d`;
    if (diff < 2592000) return `hace ${Math.round(diff / 604800)} sem`;
    return new Date(iso).toLocaleDateString('es-ES', { day:'numeric', month:'short', year:'numeric' });
  }
  document.querySelectorAll<HTMLElement>('.rel-time').forEach(el => {
    const iso = el.getAttribute('datetime');
    if (iso) el.textContent = relTime(iso);
  });
</script>

<style>
  .card {
    position: relative;
    opacity: 0;
    animation: fade-up .6s var(--spring) both;
    animation-play-state: paused;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color .25s, transform .3s var(--spring), box-shadow .3s;
  }
  .card.in-view { animation-play-state: running; }

  .card:hover {
    border-color: rgba(92,47,14,.28);
    transform: translateY(-4px) scale(1.008);
    box-shadow:
      0 20px 48px rgba(28,14,5,.14),
      0 8px 16px rgba(28,14,5,.08),
      0 0 0 1px rgba(92,47,14,.14);
  }

  /* Featured variant */
  .card--featured {
    background: var(--surface);
    border-color: rgba(201,165,116,.2);
  }

  .card--featured .card-title {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 900;
  }

  .card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
    position: relative;
  }
  .card-link:hover { text-decoration: none; }

  /* Cover image */
  .card-img {
    height: 168px;
    overflow: hidden;
    flex-shrink: 0;
    border-radius: 11px 11px 0 0;
  }
  .card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform .5s var(--spring);
  }
  .card:hover .card-img img { transform: scale(1.05); }

  /* Featured cards get a taller image */
  .card--featured .card-img { height: 240px; }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: .85rem;
    padding: 1.25rem 1.6rem 1.6rem;
    flex: 1;
  }

  /* When there's no image, restore normal padding */
  .card:not(.card--has-img) .card-body {
    padding: 1.6rem;
  }

  .card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: .5rem;
    flex-wrap: wrap;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: .4rem;
    flex-wrap: wrap;
    flex-shrink: 0;
  }

  .card-edition {
    font-family: var(--font-mono);
    font-size: .62rem;
    font-weight: 600;
    color: var(--amber);
    background: var(--amber-dim);
    border: 1px solid rgba(201,165,116,.25);
    border-radius: 3px;
    padding: .05rem .32rem;
    letter-spacing: .04em;
  }

  .card-date {
    font-family: var(--font-mono);
    font-size: .68rem;
    color: var(--text-2);
    letter-spacing: .03em;
  }

  .card-tags { display: flex; gap: .3rem; flex-wrap: wrap; }

  .card-title {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.35;
    letter-spacing: -.01em;
    transition: color .18s;
    flex: 1;
  }

  .card:hover .card-title { color: var(--accent); }

  .card-desc {
    font-size: .875rem;
    color: var(--text-2);
    line-height: 1.65;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-foot {
    display: flex;
    align-items: center;
    gap: .35rem;
    margin-top: auto;
    padding-top: .75rem;
    border-top: 1px solid var(--border-mid);
  }

  .card-read {
    font-size: .78rem;
    font-weight: 600;
    color: var(--text-2);
    letter-spacing: .02em;
    transition: color .15s;
  }

  .card-arr {
    color: var(--text-2);
    transition: color .15s, transform .3s var(--spring);
  }

  .card:hover .card-read,
  .card:hover .card-arr { color: var(--accent); }
  .card:hover .card-arr { transform: translateX(5px); }

  /* ── Hover preview overlay ── */
  .card-preview {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    padding: 1.5rem 1.6rem 1.35rem;
    font-size: .82rem;
    line-height: 1.65;
    color: var(--text-2);
    /* Cream gradient — readable on latte cards */
    background: linear-gradient(to top,
      rgba(232,222,200,.99) 0%,
      rgba(232,222,200,.94) 38%,
      rgba(232,222,200,.60) 62%,
      transparent 100%
    );
    opacity: 0;
    transform: translateY(5px);
    transition: opacity .28s ease, transform .4s var(--spring);
    pointer-events: none;
    border-radius: inherit;
  }
  .card:hover .card-preview {
    opacity: 1;
    transform: translateY(0);
  }

  /* Image cards: dark gradient so description is readable over photos */
  .card--has-img .card-preview {
    background: linear-gradient(to top,
      rgba(20,10,3,.97) 0%,
      rgba(20,10,3,.82) 38%,
      rgba(20,10,3,.32) 65%,
      transparent 100%
    );
    color: rgba(245,238,216,.9);
    font-size: .84rem;
  }
</style>
