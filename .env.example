# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── GitHub ──────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...

# Blog repo in owner/repo format
BLOG_GITHUB_REPO=your-user/nexus-digest
# Token with write access to push new posts (can be the same as GITHUB_TOKEN)
BLOG_GITHUB_TOKEN=ghp_...
# Absolute path to the local blog clone (inside the Docker volume)
BLOG_REPO_PATH=/app/blog

# ─── Reddit OAuth2 ───────────────────────────────────────────────────────────
# Create an app at https://www.reddit.com/prefs/apps (script type)
REDDIT_CLIENT_ID=...
REDDIT_CLIENT_SECRET=...
REDDIT_USER_AGENT=first-cup/1.0 by your-reddit-username

# ─── Scheduler ───────────────────────────────────────────────────────────────
DAILY_RUN_HOUR=7
DAILY_RUN_MINUTE=0
TIMEZONE=Europe/Madrid

# ─── Optional: email delivery (Resend) ───────────────────────────────────────
# RESEND_API_KEY=re_...
# EMAIL_FROM=hola@firstcup.dev

# ─── Optional: Telegram ──────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHANNEL_ID=@firstcup
# TELEGRAM_PREMIUM_GROUP_ID=-100...

